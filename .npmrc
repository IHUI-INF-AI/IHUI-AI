shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
node-linker=isolated
prefer-workspace-packages=true

# 供应链安全(D29-H5):build script 防护配置
# 禁止未授权依赖自动执行 postinstall/preinstall 脚本,防供应链投毒
# 不设 ignore-scripts=true(会破坏 argon2/sharp 等 native 依赖 build)
# 改用 onlyBuiltDependencies 白名单:pnpm 只允许以下依赖执行 build script,其他自动跳过
# 如有新依赖需要 build script,在此追加并 review
onlyBuiltDependencies[]=argon2
onlyBuiltDependencies[]=sharp
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=playwright
