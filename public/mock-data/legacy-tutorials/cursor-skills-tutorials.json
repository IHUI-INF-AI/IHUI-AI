    "description": "安装Cursor Skills的步骤",
    "steps": [
      {
        "step": 1,
        "title": "切换到Nightly渠道",
        "description": "在Cursor设置中切换到Nightly更新渠道"
      },
      {
        "step": 2,
        "title": "启用Agent Skills",
        "description": "在设置中开启Agent Skills功能"
      },
      {
        "step": 3,
        "title": "安装OpenSkills工具",
        "command": "npm i -g openskills"
      },
      {
        "step": 4,
        "title": "安装官方Skills",
        "command": "openskills install anthropics/skills"
      },
      {
        "step": 5,
        "title": "同步技能文件",
        "command": "openskills sync"
      }
    ]
  },
