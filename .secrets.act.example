# 本地 act 演练 secrets 模板
# 复制为 .secrets.act 并填入真实值后再运行 act
# .secrets.act 已在 .gitignore 中忽略

# 数据库密码(测试环境)
POSTGRES_PASSWORD=postgres

# JWT 密钥(测试环境,非生产)
JWT_SECRET=local-act-test-secret-not-for-production
JWT_ISSUAR=ihui-ai-local

# 加密密钥(测试环境,非生产)
CREDENTIALS_ENCRYPTION_KEY=local-act-test-key-not-for-production-32b

# AI 服务密钥(测试环境用 stub,无需真实 key)
OPENAI_API_KEY=stub
ANTHROPIC_API_KEY=stub
STEPFUN_API_KEY=stub
