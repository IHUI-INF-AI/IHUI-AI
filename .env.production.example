# P14.5 生产环境配置样例
# 复制为 .env.production 后填入实际值

# 域名
DOMAIN=aizhs.top
APP_TITLE=智汇AI社区

# 数据库
DB_PASSWORD=<your-db-password>

# Redis
REDIS_PASSWORD=<your-redis-password>

# JWT (至少32字符的随机字符串)
JWT_SECRET=<generate-random-256bit-key>

# Session (至少32字符的随机字符串)
SESSION_SECRET=<generate-random-session-key>

# MinIO 对象存储
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>

# CORS (生产环境的允许来源)
CORS_ORIGINS=https://aizhs.top

# 后端端口
BACKEND_PORT=8000

# 前端端口
FRONTEND_PORT=80

# 环境标识
ENV=production

# ==================== AI 服务密钥 (按需配置) ====================
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
DOUBAO_API_KEY=
DEEPSEEK_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
OPENROUTER_API_KEY=

# ==================== 微信 ====================
WX_MINI_APPID=
WX_MINI_SECRET=
WX_PC_APPID=
WX_PC_SECRET=
WX_PAY_APPID=
WX_PAY_MCHID=
WX_PAY_API_KEY=
WX_PAY_V3_KEY=
WX_PAY_CERT_SERIAL=
WX_PAY_PRIVATE_KEY_PATH=

# ==================== 支付宝 ====================
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ==================== Coze API ====================
COZE_API_BASE=https://api.coze.cn
COZE_OAUTH_APP_ID=

# ==================== 第三方登录 ====================
FEISHU_APP_ID=
FEISHU_SECRET=
GOOGLE_APP_ID=
GOOGLE_SECRET=

# ==================== 阿里云短信 ====================
ALI_SMS_ACCESS_KEY_ID=
ALI_SMS_ACCESS_KEY_SECRET=
