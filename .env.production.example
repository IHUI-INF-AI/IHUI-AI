# IHUI-AI 生产环境配置样例(新架构: Fastify + Next.js + FastAPI)
# 复制为 .env.production 后填入实际值
# 旧架构(Python FastAPI server/ + Vue client/)已弃用,旧变量已清理

# ==================== 基础 ====================
DOMAIN=aizhs.top
APP_TITLE=智汇AI社区
# 前端端口(docker-compose web 服务映射)
WEB_PORT=3000

# ==================== 数据库 ====================
DB_USER=ihui
DB_PASSWORD=<your-db-password>
DB_NAME=ihui

# ==================== Redis ====================
REDIS_PASSWORD=<your-redis-password>

# ==================== 认证加密 ====================
# JWT 密钥(至少 32 字符随机字符串)
JWT_SECRET=<generate-random-256bit-key>
JWT_EXPIRES_IN=7d
# 凭证加密密钥(至少 32 字符,用于加密第三方 OAuth 凭证等敏感数据)
CREDENTIALS_ENCRYPTION_KEY=<generate-random-256bit-encryption-key>

# ==================== CORS ====================
# 注意:config/index.ts 用 CORS_ORIGIN(单数)
CORS_ORIGIN=https://aizhs.top

# ==================== 分域 SSO 架构 (2026-07-21 立,生产必填) ====================
# 主域:aizhs.top / 认证子域:bsm.aizhs.top
# Cookie 域:.aizhs.top → 主域+子域互通,登录一次两边都生效
# 部署:Nginx 需配 bsm.aizhs.top 子域(见 deploy/nginx/conf.d/bsm-subdomain.conf)
COOKIE_DOMAIN=.aizhs.top

# ==================== 飞书 OAuth (2026-07-21 OIDC v2 协议已修复) ====================
# 凭据获取:https://open.feishu.cn/app → 创建企业自建应用 → 凭证与基础信息
# 飞书后台「安全设置 → 重定向 URL」白名单必须加:
#   http://localhost:3000/callback?platform=feishu       (本地开发)
#   https://bsm.aizhs.top/callback?platform=feishu       (生产)
FEISHU_APP_ID=<your-feishu-app-id>
FEISHU_APP_SECRET=<your-feishu-app-secret>
FEISHU_REDIRECT_URI=https://bsm.aizhs.top/callback?platform=feishu

# ==================== AI 服务密钥(用户 plan 套餐优先,免费 provider 备选) ====================
# 任选一个 provider 配置即可激活真实 AI 调用,全部为空降级 stub 模式(返回模拟响应)

# --- 用户 plan 套餐(复制此文件为 .env.production 后填入真实 key) ---
# StepFun(默认 provider)
STEPFUN_API_KEY=<your-stepfun-api-key>
STEPFUN_API_BASE=https://api.stepfun.com/step_plan/v1
# Agnes AI(备用,部分网络环境可能需要代理)
AGNES_API_KEY=<your-agnes-api-key>
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# --- 免费 provider(备选,需自行注册) ---
# Groq(免费 30 RPM): https://console.groq.com/keys
GROQ_API_KEY=
# Gemini(免费 15 RPM): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OpenRouter free tier: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- 付费 provider(可选) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LiteLLM 模型名(前缀决定 provider,默认 StepFun)
# StepFun: stepfun/step-3.7-flash / stepfun/step-3.5-flash / stepfun/step-router-v1
# Agnes:   agnes/<model-name>(需确认 agnes endpoint 支持的模型)
# Groq:    groq/llama-3.3-70b-versatile
# Gemini:  gemini/gemini-1.5-flash
LITELLM_MODEL=stepfun/step-3.7-flash

# ==================== SMTP 邮件(按需配置) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ihui.ai
SMTP_ENABLED=false

# ==================== 监控(APM) ====================
# Prometheus 端口(默认 9091 避免与 Node Exporter 9100 冲突)
PROMETHEUS_PORT=9091
# Grafana 端口(默认 3001 避免与 web 3000 冲突)
GRAFANA_PORT=3001
# Grafana 管理员账号
GRAFANA_ADMIN_USER=admin
# Grafana 管理员密码(生产环境务必修改)
GRAFANA_ADMIN_PASSWORD=ihui-admin
# Node Exporter 端口
NODE_EXPORTER_PORT=9100

# ==================== 异步任务队列(BullMQ) ====================
# 是否在本实例启动 Worker 消费者(默认 true)
# 多实例部署时可将部分实例设为 false 仅做生产者,集中消费避免重复处理
ENABLE_WORKER=true

# ==================== AI 回调安全(可选) ====================
# 共享密钥:配置后 ai-service 回调 /api/ai/callback 需携带 X-Internal-Secret 头
# 为空则不校验(仅靠网络隔离)。生产环境建议配置随机字符串
AI_CALLBACK_SECRET=

# ==================== Stock 分析服务(可选) ====================
# Stock 分析 AI 模型配置(未配置时降级为本地基础分析)
STOCK_API_KEY=
STOCK_API_BASE=https://api.openai.com/v1
STOCK_MODEL_ID=gpt-4o-mini

# ==================== 数据库读写分离(可选) ====================
# 读副本 URL(未配置时读操作回退主库)
DATABASE_READ_REPLICA_URL=

# ========== 微信支付 V3 配置(生产环境必填,缺失时降级 mock) ==========
# 必填项:商户号 + V3 密钥 + 私钥(内容或路径任一)+ 平台证书(内容或路径任一)
# 启动期硬约束(apps/api/src/index.ts checkProductionConfig):
#   - 生产环境私钥未配置 → 启动中止(无法调用真实支付 API)
#   - 生产环境平台证书未配置 → 启动中止(回调验签失败,订单无法自动标记为 paid)
# 证书放置位置:项目内 cert/ 目录(gitignored,不入库)
#   - .gitignore 已配置 cert/ + **/cert/ + *.pem + *.p12 + *.key + apiclient_*
#   - 证书放置后 isWechatPayConfigured() / isPlatformCertConfigured() 自动返回 true,无需重启或改代码
#
# WX_API_BASE=https://api.mch.weixin.qq.com
# WX_MINI_APPID=<your-wechat-mini-appid>
# WX_MINI_SECRET=<your-wechat-mini-secret>
# WX_APP_APPID=<your-wechat-app-appid>
# WX_SHOP_ID=<your-wechat-mch-id>
# WX_PAY_V3_KEY=<your-wechat-apiv3-key-32-bytes>
# WX_PAY_CERT_SERIAL=<your-wechat-cert-serial>
# WX_PAY_PRIVATE_KEY=<your-wechat-private-key-pem-content>
# WX_PAY_PRIVATE_KEY_PATH=./cert/apiclient_key.pem  # 项目内 cert/ 目录(gitignored)
# WX_PAY_PLATFORM_CERT=<your-wechat-platform-cert-pem-content>
# WX_PAY_PLATFORM_CERT_PATH=./cert/platform_cert.pem  # 项目内 cert/ 目录(gitignored)
# WX_PAY_NOTIFY_URL=https://api.example.com/api/payments/wechat/notify
# WX_PAY_COURSE_NOTIFY_URL=https://api.example.com/api/payments/wechat/notify/course
# WX_ANDROID_NOTIFY_URL=https://api.example.com/api/payments/wechat/notify/android
#
# ── 平台证书获取步骤(微信支付 V3 回调验签必需) ──
# 1. 登录商户平台 https://pay.weixin.qq.com → API 安全 → 平台证书
# 2. 下载 platform_cert.pem(公钥,DER/PEM 格式)
# 3. 放置到项目内 cert/platform_cert.pem
# 4. .env 配置 WX_PAY_PLATFORM_CERT_PATH=./cert/platform_cert.pem
# 5. 重启 API 服务,验证 /api/health/ready 的 checks.wechatPay.status = 'ok'
# 注意:平台证书有效期约 5 年,过期前需重新下载并替换文件
