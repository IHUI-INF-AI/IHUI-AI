      },
      "targets": [
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"funnel_payment_checkout_click\"}[1h]))",
          "legendFormat": "1. checkout_click",
          "refId": "A"
        },
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"funnel_payment_pay_submit\"}[1h])) / clamp_min(sum(increase(zhs_business_events_total{event=\"funnel_payment_checkout_click\"}[1h])), 1)",
          "legendFormat": "2. checkout→submit 转化率",
          "refId": "B"
        },
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"payment_success\"}[1h])) / clamp_min(sum(increase(zhs_business_events_total{event=\"funnel_payment_pay_submit\"}[1h])), 1)",
          "legendFormat": "3. submit→success 转化率",
          "refId": "C"
        }
      ]
    },
    {
      "id": 22,
      "title": "支付成功 vs 失败 (1h)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"payment_success\"}[1h]))",
          "legendFormat": "成功",
          "refId": "A"
        },
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"payment_fail\"}[1h]))",
          "legendFormat": "失败",
          "refId": "B"
        }
      ]
    },
    {
      "id": 23,
      "title": "支付平均处理耗时 (s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 29},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zhs_business_latency_seconds_bucket{event=\"payment_create\"}[5m])))",
          "legendFormat": "P95 - 支付创建",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zhs_business_latency_seconds_bucket{event=\"payment_success\"}[5m])))",
          "legendFormat": "P95 - 支付成功",
          "refId": "B"
        }
      ]
    },
    {
      "title": "登录漏斗 + 用户行为",
