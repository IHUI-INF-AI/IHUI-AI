  "description": "ZHS 业务转化漏斗大盘 - 涵盖 chat / payment / login 三大核心漏斗",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "大盘概览 - 核心指标",
      "type": "row",
      "id": 1,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "今日活跃用户数 (DAU)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count by (user_id) (increase(zhs_business_events_total{event=~\"chat_send|user_login|payment_create\"}[1d])))",
          "legendFormat": "DAU",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "今日支付成功订单数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"payment_success\"}[1d]))",
          "legendFormat": "支付成功",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "今日 Chat 调用次数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"chat_send\"}[1d]))",
          "legendFormat": "Chat 调用",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "今日新注册用户",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"user_register\"}[1d]))",
          "legendFormat": "新注册",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Chat 漏斗: send → receive",
      "type": "row",
      "id": 10,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Chat 漏斗转化率 (1h)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.8}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"chat_send\"}[1h]))",
          "legendFormat": "1. chat_send",
          "refId": "A"
        },
        {
          "expr": "sum(increase(zhs_business_events_total{event=\"chat_receive\"}[1h])) / clamp_min(sum(increase(zhs_business_events_total{event=\"chat_send\"}[1h])), 1)",
          "legendFormat": "2. send→receive 转化率",
          "refId": "B"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showValue": "auto"
      }
    },
    {
      "id": 12,
      "title": "Chat 各渠道分布 (1h)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "sum by (channel) (increase(zhs_business_events_total{event=~\"chat_send|chat_receive\"}[1h]))",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 13,
      "title": "Chat 平均响应延迟 (s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 14},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(zhs_business_latency_seconds_bucket{event=\"chat_send\"}[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zhs_business_latency_seconds_bucket{event=\"chat_send\"}[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(zhs_business_latency_seconds_bucket{event=\"chat_send\"}[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "支付漏斗: checkout → pay_success",
      "type": "row",
      "id": 20,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20},
      "collapsed": false
    },
    {
      "id": 21,
      "title": "支付漏斗转化率 (1h)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
