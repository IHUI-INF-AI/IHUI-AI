{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "WebSocket 自动恢复系统大盘 - 涵盖队列水位/恢复成功率/监控任务健康度/异常分布/恢复耗时分布",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["zhs", "websocket", "auto-recovery", "ops"],
  "timezone": "browser",
  "title": "ZHS WebSocket Auto Recovery",
  "uid": "zhs-ws-auto-recovery",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "prometheus"}
      }
    ]
  },
  "panels": [
    {
      "title": "核心状态概览",
      "type": "row",
      "id": 1,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "系统是否运行中",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {"options": {"0": {"text": "已停止", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "运行中", "color": "green"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_is_running)",
          "legendFormat": "运行状态",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "服务健康度",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {"options": {"0": {"text": "降级/异常", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "Healthy", "color": "green"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_service_status)",
          "legendFormat": "服务状态",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "活跃 WS 连接数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_active_connections)",
          "legendFormat": "活跃连接",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "累计恢复次数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_recovery_count)",
          "legendFormat": "恢复次数",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "连续错误数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_consecutive_errors)",
          "legendFormat": "连续错误",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "title": "进程内存 (MB)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1024},
              {"color": "red", "value": 2048}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_memory_usage_mb)",
          "legendFormat": "RSS 内存",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "面板 A: 出箱消息队列水位",
      "type": "row",
      "id": 10,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "队列容量 / 当前大小 / 队列满次数",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_queue_capacity)",
          "legendFormat": "队列容量",
          "refId": "A"
        },
        {
          "expr": "max(zhs_ws_auto_recovery_queue_size)",
          "legendFormat": "当前大小",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "last"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 12,
      "title": "队列满累计次数 (rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "max(rate(zhs_ws_auto_recovery_queue_full_count[5m]))",
          "legendFormat": "队列满/秒",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "title": "面板 B: 恢复操作成功率 (1 - 失败率)",
      "type": "row",
      "id": 20,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "恢复事件 - 触发 / 成功 / 失败 (5m rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(zhs_ws_auto_recovery_events_total{event_type=\"triggered\"}[5m]))",
          "legendFormat": "触发",
          "refId": "A"
        },
        {
          "expr": "sum(rate(zhs_ws_auto_recovery_events_total{event_type=\"succeeded\"}[5m]))",
          "legendFormat": "成功",
          "refId": "B"
        },
        {
          "expr": "sum(rate(zhs_ws_auto_recovery_events_total{event_type=\"failed\"}[5m]))",
          "legendFormat": "失败",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 22,
      "title": "恢复成功率 (1 - 失败/(成功+失败))",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.8},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(zhs_ws_auto_recovery_events_total{event_type=\"failed\"}[15m])) / clamp_min(sum(rate(zhs_ws_auto_recovery_events_total{event_type=~\"succeeded|failed\"}[15m])), 0.001))",
          "legendFormat": "成功率",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "面板 C: 监控任务健康度",
      "type": "row",
      "id": 30,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "监控任务数 (总数 / 活跃 / 失败)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "stacking": {"mode": "none"}
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_monitor_tasks_total)",
          "legendFormat": "总数",
          "refId": "A"
        },
        {
          "expr": "max(zhs_ws_auto_recovery_monitor_tasks_active)",
          "legendFormat": "活跃",
          "refId": "B"
        },
        {
          "expr": "max(zhs_ws_auto_recovery_monitor_tasks_failed)",
          "legendFormat": "失败",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "last"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 32,
      "title": "处理中后台任务数 vs 高水位阈值",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 500}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_processing_tasks)",
          "legendFormat": "处理中任务",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "title": "面板 D: 异常类型分布 (按 monitor / exception_type)",
      "type": "row",
      "id": 40,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "title": "近 1h 异常 Top 10 (按 exception_type)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "showPoints": "never",
            "stacking": {"mode": "normal"}
          }
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (exception_type) (increase(zhs_ws_auto_recovery_exceptions_total[1h])))",
          "legendFormat": "{{exception_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["max", "sum"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 42,
      "title": "近 1h 异常按 monitor 分布",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (monitor) (increase(zhs_ws_auto_recovery_exceptions_total[1h]))",
          "legendFormat": "{{monitor}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "right"},
        "tooltip": {"mode": "single", "sort": "desc"}
      }
    },
    {
      "title": "面板 E: 恢复操作耗时分布 (Histogram)",
      "type": "row",
      "id": 50,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 51,
      "title": "恢复耗时 P50 / P95 / P99 (按 result)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, result) (rate(zhs_ws_auto_recovery_recovery_duration_seconds_bucket[10m])))",
          "legendFormat": "P50 ({{result}})",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, result) (rate(zhs_ws_auto_recovery_recovery_duration_seconds_bucket[10m])))",
          "legendFormat": "P95 ({{result}})",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, result) (rate(zhs_ws_auto_recovery_recovery_duration_seconds_bucket[10m])))",
          "legendFormat": "P99 ({{result}})",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "last"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 52,
      "title": "恢复耗时平均 (按 result)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 42},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(zhs_ws_auto_recovery_recovery_duration_seconds_sum[5m])) / clamp_min(sum by (result) (rate(zhs_ws_auto_recovery_recovery_duration_seconds_count[5m])), 0.001)",
          "legendFormat": "avg ({{result}})",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "title": "面板 F: 运行时细节 (活动度 / 在飞调用 / 累计计数)",
      "type": "row",
      "id": 60,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 61,
      "title": "在飞 API 调用数",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 51},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_active_api_calls)",
          "legendFormat": "在飞 API 调用",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 62,
      "title": "累计入队消息数 vs 累计错误数",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 51},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_total_messages_queued)",
          "legendFormat": "累计入队消息",
          "refId": "A"
        },
        {
          "expr": "max(zhs_ws_auto_recovery_total_errors)",
          "legendFormat": "累计错误",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "last"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 63,
      "title": "业务静默时长 / 健康检查 / 活动间隔",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 51},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "max(zhs_ws_auto_recovery_inactive_seconds)",
          "legendFormat": "静默时长 (s)",
          "refId": "A"
        },
        {
          "expr": "time() - max(zhs_ws_auto_recovery_last_health_check_timestamp)",
          "legendFormat": "距上次健康检查 (s)",
          "refId": "B"
        },
        {
          "expr": "time() - max(zhs_ws_auto_recovery_last_activity_timestamp)",
          "legendFormat": "距上次活动 (s)",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "last"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    }
  ]
}
