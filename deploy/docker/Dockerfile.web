FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@9.15.0

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json ./apps/web/
# 复制所有 workspace 包的 package.json(--no-frozen-lockfile 需要全部 workspace 声明)
COPY packages/types/package.json ./packages/types/
COPY packages/config/package.json ./packages/config/
COPY packages/database/package.json ./packages/database/
COPY packages/auth/package.json ./packages/auth/
COPY packages/ui/package.json ./packages/ui/
COPY packages/ui-primitives/package.json ./packages/ui-primitives/
COPY packages/ui-native/package.json ./packages/ui-native/
COPY packages/api-client/package.json ./packages/api-client/
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/eslint-config/package.json ./packages/eslint-config/
COPY packages/tsconfig/package.json ./packages/tsconfig/
# --no-frozen-lockfile: 允许安装 package.json 中新增的 @lobehub/icons 依赖
RUN pnpm install --no-frozen-lockfile

FROM base AS builder
WORKDIR /app
# 复制 deps 阶段整个 /app(含所有 workspace 包的 node_modules + package.json)
# .dockerignore 已排除本地 node_modules,后续 COPY . . 不会覆盖
COPY --from=deps /app/ ./
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
# 构建期固化 rewrites 代理地址为 Docker 内网地址(next.config.ts rewrites 在 build 时求值)
ENV API_URL=http://api:8080
ENV AI_SERVICE_URL=http://ai-service:8000
# next build 需要大内存(默认 ~2GB 会 OOM);4096 仍会 OOM,恢复到 8192(2026-07-20)
ENV NODE_OPTIONS=--max-old-space-size=8192
# 清理可能残留的 .tsbuildinfo(2026-07-20 修复:避免 tsc 增量编译跳过文件,
# 导致 @ihui/api-client/dist/endpoints 等产物缺失,引发 next build 模块解析失败)
RUN find packages apps -name "*.tsbuildinfo" -type f -delete 2>/dev/null || true
# --filter @ihui/web... :先 build @ihui/web 的所有 workspace 依赖(@ihui/ui-react / @ihui/design-tokens / @ihui/api-client 等),再 build web
RUN pnpm --filter @ihui/web... run build

# A 套壳架构(2026-07-24):output:'export' 静态导出,nginx 提供静态文件 + API 反向代理
# 替代原 standalone + node server.js 方案,因为 output:'export' 不生成 server.js
FROM nginx:1.27-alpine AS runner
WORKDIR /usr/share/nginx/html
# 复制静态导出产物(out/ 已包含 public/ 内容,Next.js export 时自动合并)
COPY --from=builder /app/apps/web/out/ ./
# nginx 配置:静态文件 + API/AI-service 反向代理(替代 next rewrites,output:export 不支持 rewrites)
COPY deploy/docker/nginx.web.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
