# IHUI-AI SaaS 托管平台 — 全局配置
# 复制此文件为 .env 并填写实际值: cp .env.example .env

# ==================== 域名与证书 ====================
# 基础域名,客户子域名 = {slug}.${BASE_DOMAIN}
# 例: BASE_DOMAIN=saas.example.com, 客户 demo 的访问域名为 demo.saas.example.com
BASE_DOMAIN=saas.example.com

# 根域管理后台域名(可选,用于未来阶段 2 租户管理后台)
ADMIN_DOMAIN=admin.saas.example.com

# ACME 邮箱(Let's Encrypt 证书通知)
ACME_EMAIL=ops@example.com

# Let's Encrypt 环境:staging(测试) / production(正式)
# 首次部署先用 staging,验证通过后切 production
LETSENCRYPT_ENV=staging

# ==================== DNS Provider(用于 DNS-01 挑战)====================
# 通配符证书必须用 DNS-01 挑战,需提供 DNS API 凭证
# 支持: alidns(阿里云) / cloudflare / dnspod / godaddy / route53
DNS_PROVIDER=alidns

# 阿里云 DNS(默认)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-hangzhou

# Cloudflare(可选,切换 DNS_PROVIDER=cloudflare 时使用)
# CLOUDFLARE_API_EMAIL=
# CLOUDFLARE_API_KEY=

# ==================== Traefik ====================
# Traefik Dashboard 认证(bcrypt 哈希,生成: htpasswd -nb admin password | sed -e s/\\$/\\$\\$/g)
# 留空则禁用 Dashboard 鉴权(仅本地开发用)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxxx

# ==================== Docker 镜像 ====================
# 租户部署时使用的镜像标签(从 CI/CD 构建推送后填写)
IMAGE_TAG=latest

# ==================== 资源默认值(租户未指定时使用)====================
# 单租户默认资源限制
DEFAULT_MEMORY_LIMIT=2G
DEFAULT_CPU_LIMIT=1.0
DEFAULT_STORAGE_LIMIT=20G

# ==================== Admin API(P1 阶段 2.1)====================
# 管理 API 鉴权密钥(至少 32 字符随机)
# 生成: openssl rand -hex 32
# 留空则首次启动自动生成(只输出到 stdout,需手动持久化到 .env)
ADMIN_API_KEY=

# Admin API 日志级别
ADMIN_API_LOG_LEVEL=info

# Admin API CORS 允许来源(本地管理 UI)
ADMIN_CORS_ORIGIN=http://localhost:3000

# ==================== Admin API 安全(P1-2.2)====================
# 允许通过 web 端调用 admin-api 的用户白名单(逗号分隔,默认 superadmin)
# 鉴权流程:web middleware 检查 cookie 中 auth_user_role ∈ {superadmin, system_admin},
#         通过后注入 X-Admin-User 头给下游 Route Handler
ADMIN_USER_WHITELIST=admin

# 是否启用操作审计日志(JSON Lines 写入 admin-api-audit.log,gitignore)
ENABLE_AUDIT_LOG=true

# ==================== P1-2.3 资源监控 ====================
# Grafana 管理员账号
GRAFANA_ADMIN_USER=admin
# Grafana 管理员密码(生产环境必须修改为强密码,首次启动后生效)
GRAFANA_ADMIN_PASSWORD=admin
# Prometheus 时序数据保留时间(默认 7d,长期存储需外挂 Thanos/VictoriaMetrics)
PROMETHEUS_RETENTION=7d

# ==================== Web 端(apps/web/.env.local)====================
# NEXT_PUBLIC_GRAFANA_BASE=http://127.0.0.1:3001
# ADMIN_API_URL=http://127.0.0.1:8081
# ADMIN_SAAS_API_KEY=<same-as-ADMIN_API_KEY>
