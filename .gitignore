# ============================================================================
# 运行时产物 / 临时文件
# ============================================================================
logs/
tmp/
*.log
test_*.json
test_*.log
# API/web 服务重启日志(其他会话 dev server 重启遗留,文件名 logs-*-restart*.txt)
logs-*-restart*.txt
# 例外:apps/web/app/**/logs/ 是 Next.js 路由目录(如 models/logs/page.tsx),不是日志目录
!apps/web/app/**/logs/
!apps/web/app/**/logs/**

# Agent 工具临时产物(守门结果/扫描摘要/验证脚本/commit 消息暂存等)
# 防止 P44/P45/P46 等会话遗留 __*.txt/__*.md/__*.bat/__*.ps1 回潮
# 根目录锚定(/__*),避免误伤 apps/**/__tests__/ 等合法测试目录
/__*

# act 本地 CI 演练 secrets(从 .secrets.act.example 复制)
.secrets.act
.env.act.local

# 2026-07-21 安全审计加固:测试环境密钥文件不应入库(2026-07-21 安全审计发现
# 之前 .env.act 含 DATABASE_URL, apps/api/.env.test 含 JWT_SECRET +
# CREDENTIALS_ENCRYPTION_KEY,均为已知弱密钥,任何能访问仓库的人都能伪造 token)。
# 本地保留文件(不被删除),仅从 git 索引移除。
.env.act
**/.env.test
**/.env.test.local
**/.env.tests
**/.env.staging
**/.env.staging.local

# /goal 目标驱动模式运行时临时文件位于 .trae-cn/goal-runtime/,
# 已被上方 .trae-cn/ 整体忽略规则覆盖,无需单独列出。

