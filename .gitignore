patches/
unfound-zh.txt
unfound-en.txt
unfound-ja.txt
unfound-ko.txt
unfound-zh-TW.txt

# 数据库 schema 备份(脚本生成,不入库)
scripts/backup-*.sql

# ============================================================================
# 微信支付 API 证书(敏感,禁止入库)
# ============================================================================
# 证书文件位于项目内 cert/ 目录(本机路径 g:\IHUI-AI\cert\),整目录被 .gitignore 忽略
# 路径由 .env 的 WX_PAY_PRIVATE_KEY_PATH 指定,换机器只需改 .env,无需改代码
cert/
**/cert/
*.pem
*.p12
*.key
apiclient_*

