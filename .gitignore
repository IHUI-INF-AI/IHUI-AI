# ============================================================================
# 运行时产物 / 临时文件
# ============================================================================
logs/
tmp/
*.log
test_*.json
test_*.log
# API/web 服务重启日志(其他会话 dev server 重启遗留,文件名 logs-*-restart*.txt)
logs-*-restart*.txt

# Agent 工具临时产物(守门结果/扫描摘要/验证脚本/commit 消息暂存等)
# 防止 P44/P45/P46 等会话遗留 __*.txt/__*.md/__*.bat/__*.ps1 回潮
# 根目录锚定(/__*),避免误伤 apps/**/__tests__/ 等合法测试目录
/__*

# act 本地 CI 演练 secrets(从 .secrets.act.example 复制)
.secrets.act
.env.act.local

# /goal 目标驱动模式运行时临时文件位于 .trae-cn/goal-runtime/,
# 已被上方 .trae-cn/ 整体忽略规则覆盖,无需单独列出。

# ============================================================================
# 构建产物
# ============================================================================
dist/
build/
*.egg-info/
__pycache__/
*.pyc
*.pyo
.next/
.turbo/
# TypeScript 增量构建缓存
*.tsbuildinfo
# WXT 浏览器扩展生成产物
.wxt/
.output/

# ============================================================================
# 环境配置
# ============================================================================
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.production

# CLI 项目级配置(包含 apiKey 等敏感字段,禁止入库)
# 但 .ihui/skills/*.md 是团队共享的 skill 定义,允许入库
.ihui/*
!.ihui/skills/

