{
  "name": "@ihui/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./auth/*": {
      "types": "./src/auth/*.ts",
      "import": "./dist/auth/*.js"
    },
    "./notifications/*": {
      "types": "./src/notifications/*.ts",
      "import": "./dist/notifications/*.js"
    },
    "./validation/*": {
      "types": "./src/validation/*.ts",
      "import": "./dist/validation/*.js"
    },
    "./workflows/*": {
      "types": "./src/workflows/*.ts",
      "import": "./dist/workflows/*.js"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "import": "./dist/utils/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules"
  },
  "dependencies": {
    "xstate": "^5.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "eslint": "^9.16.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
