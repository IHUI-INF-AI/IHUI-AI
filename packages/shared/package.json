{
  "name": "@ihui/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth/*": {
      "types": "./dist/auth/*.d.ts",
      "import": "./dist/auth/*.js"
    },
    "./notifications/*": {
      "types": "./dist/notifications/*.d.ts",
      "import": "./dist/notifications/*.js"
    },
    "./validation/*": {
      "types": "./dist/validation/*.d.ts",
      "import": "./dist/validation/*.js"
    },
    "./workflows/*": {
      "types": "./dist/workflows/*.d.ts",
      "import": "./dist/workflows/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./skills/*": {
      "types": "./dist/skills/*.d.ts",
      "import": "./dist/skills/*.js"
    },
    "./tasks/*": {
      "types": "./dist/tasks/*.d.ts",
      "import": "./dist/tasks/*.js"
    },
    "./design/*": {
      "types": "./dist/design/*.d.ts",
      "import": "./dist/design/*.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./memory/*": {
      "types": "./dist/memory/*.d.ts",
      "import": "./dist/memory/*.js"
    },
    "./subagents": {
      "types": "./dist/subagents/index.d.ts",
      "import": "./dist/subagents/index.js"
    },
    "./subagents/*": {
      "types": "./dist/subagents/*.d.ts",
      "import": "./dist/subagents/*.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js"
    },
    "./context/*": {
      "types": "./dist/context/*.d.ts",
      "import": "./dist/context/*.js"
    },
    "./spec": {
      "types": "./dist/spec/index.d.ts",
      "import": "./dist/spec/index.js"
    },
    "./spec/*": {
      "types": "./dist/spec/*.d.ts",
      "import": "./dist/spec/*.js"
    },
    "./plan": {
      "types": "./dist/plan/index.d.ts",
      "import": "./dist/plan/index.js"
    },
    "./plan/*": {
      "types": "./dist/plan/*.d.ts",
      "import": "./dist/plan/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules"
  },
  "dependencies": {
    "xstate": "^5.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "eslint": "^9.16.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
