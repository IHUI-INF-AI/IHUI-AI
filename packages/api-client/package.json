{
  "name": "@ihui/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./api-error": {
      "types": "./dist/api-error.d.ts",
      "import": "./dist/api-error.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./endpoints/*": {
      "types": "./dist/endpoints/*.d.ts",
      "import": "./dist/endpoints/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules"
  },
  "dependencies": {
    "@ihui/types": "workspace:*"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "typescript": "^5.7.2",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
