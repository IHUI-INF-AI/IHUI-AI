{
  "name": "@ihui/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./user": {
      "types": "./src/user.ts",
      "import": "./src/user.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "import": "./src/api.ts"
    },
    "./ai": {
      "types": "./src/ai.ts",
      "import": "./src/ai.ts"
    },
    "./message-repair": {
      "types": "./src/message-repair.ts",
      "import": "./src/message-repair.ts"
    },
    "./workspace": {
      "types": "./src/workspace.ts",
      "import": "./src/workspace.ts"
    },
    "./api-contracts": {
      "types": "./src/api-contracts.ts",
      "import": "./src/api-contracts.ts"
    },
    "./subagent-dispatch": {
      "types": "./src/subagent-dispatch.ts",
      "import": "./src/subagent-dispatch.ts"
    },
    "./orchestration": {
      "types": "./src/orchestration.ts",
      "import": "./src/orchestration.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
