{
  "name": "@ihui/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./user": {
      "types": "./src/user.ts",
      "import": "./dist/user.js"
    },
    "./api": {
      "types": "./src/api.ts",
      "import": "./dist/api.js"
    },
    "./ai": {
      "types": "./src/ai.ts",
      "import": "./dist/ai.js"
    },
    "./message-repair": {
      "types": "./src/message-repair.ts",
      "import": "./dist/message-repair.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
