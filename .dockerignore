# Docker 构建上下文排除(Monorepo 新架构)

# 版本控制
.git/
.gitattributes
.github/

# 依赖目录(镜像内重新安装)
**/node_modules/
**/.venv/
**/venv/

# 构建产物
**/dist/
**/build/
**/*.egg-info/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.next/
**/.turbo/

# 测试产物
**/test-results/
**/playwright-report/
**/coverage/

# IDE / 编辑器
.idea/
.vscode/
**/.cursorrules
**/.editorconfig

# 日志 / 运行时数据
logs/
**/logs/
**/*.log

# 临时文件
*.txt
*.html
*.cjs
tmp/
