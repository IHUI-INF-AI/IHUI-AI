#!/bin/sh
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"

# ─── 全量 typecheck 强制门 ────────────────────────────────────────────
# 背景:第 11-12 轮发现 subagent 报告"全绿"靠 .tsbuildinfo 缓存假象
#      pre-push 强制清缓存 + 串行全量 typecheck 修复该问题
# 跳过的方法:HUSKY_SKIP_TYPECHECK=1(紧急 push 时使用,但建议修复后正常 push)
# 注意:用 printf >&2 替代 echo,避免 Windows git hooks stdout 关闭导致 Bad file descriptor
if [ "${HUSKY_SKIP_TYPECHECK:-0}" = "1" ]; then
  printf '%s\n' "⚠️  HUSKY_SKIP_TYPECHECK=1 — 已跳过全量 typecheck 验证(不推荐)" >&2
else
  printf '\n%s\n' "🔍 全量 typecheck 验证(清 .tsbuildinfo 缓存后)..." >&2
  cd "$(git rev-parse --show-toplevel)" || { printf '%s\n' "❌ 无法定位仓库根目录" >&2; exit 1; }
  pnpm typecheck:full || { printf '%s\n' "❌ 全量 typecheck 失败,推送已阻止" >&2; exit 1; }
  printf '%s\n' "✅ 全量 typecheck 验证通过" >&2
fi
