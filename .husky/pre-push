#!/bin/sh

# ============================================================================
# Pre-push 钩子 (合并版)
# 1. Git LFS pre-push (大文件管理)
# 2. 前端代码检查 (TypeScript / 样式审计 / 设计 tokens)
# ============================================================================

# --- 1. Git LFS ---
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"

# --- 2. 前端代码检查 ---
# 只在有 client 目录的文件变更时才执行检查
CLIENT_STAGED=$(git diff --cached --name-only | grep "^client/" || true)
CLIENT_RECENT=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep "^client/" || true)
if [ -z "$CLIENT_STAGED" ] && [ -z "$CLIENT_RECENT" ]; then
  echo "✓ 没有 client 目录的文件变更，跳过前端检查"
  exit 0
fi

echo "▶ 切换到 client 目录执行前端检查..."
cd client

echo "▶ Running vue-tsc type check (this may take a while)..."
npm run typecheck --silent

echo "▶ Running style audit (no-important / colors / font-size)..."
CHECK_NO_IMPORTANT_BASELINE=1 CHECK_COLORS=1 CHECK_FONT_SIZE=1 npm run check:no-important --silent

echo "▶ Running design tokens check..."
npm run check:el-token --silent

echo "✓ 所有前端检查通过"
