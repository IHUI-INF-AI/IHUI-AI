#!/usr/bin/env sh
# 根目录 Pre-push 钩子
# 作用：推送代码前自动检查，防止有问题的代码进入远端分支
# 检查内容：
#   1. TypeScript 类型检查
#   2. 样式审计（no-important / colors / font-size）
#   3. 设计 tokens 检查
#   4. 高特异性选择器检测
# 注意：检查脚本在 client 目录，需要切换到 client 目录执行

set -e

# 只在有 client 目录的文件变更时才执行检查
CLIENT_STAGED=$(git diff --cached --name-only | grep "^client/" || true)
CLIENT_RECENT=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep "^client/" || true)
if [ -z "$CLIENT_STAGED" ] && [ -z "$CLIENT_RECENT" ]; then
  echo "✓ 没有 client 目录的文件变更，跳过前端检查"
  exit 0
fi

echo "▶ 切换到 client 目录执行前端检查..."
cd client

echo "▶ Running vue-tsc type check (this may take a while)..."
npm run typecheck --silent

echo "▶ Running style audit (no-important / colors / font-size)..."
CHECK_NO_IMPORTANT_BASELINE=1 CHECK_COLORS_BASELINE=1 CHECK_FONTSIZE_BASELINE=1 npm run style:audit --silent

echo "▶ Running design tokens check..."
npm run tokens:check --silent
npm run tokens:naming --silent

echo "▶ Running high specificity selector check..."
HIGH_SPECIFICITY_THRESHOLD=0 npm run check:high-specificity --silent

echo "✓ 所有前端检查通过，可以推送"
