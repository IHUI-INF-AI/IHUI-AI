#!/usr/bin/env node
// Pre-commit 守门钩子（跨平台兼容 Windows）
// 防止 API key 泄露 + i18n 键完整性
const { execSync } = require('child_process')

function run(label, cmd) {
  console.log(label)
  try {
    execSync(cmd, { stdio: 'inherit', cwd: process.cwd() })
    return true
  } catch (e) {
    console.error(`❌ ${label}失败，提交已阻止`)
    return false
  }
}

// 1. API key 泄露检查
if (!run('🔐 检查 API key 泄露...', 'node scripts/check-api-key-leak.mjs --staged')) {
  process.exit(1)
}

// 2. i18n 键完整性检查
if (!run('🌐 检查 i18n 键完整性...', 'node scripts/check-i18n-keys.mjs --staged')) {
  process.exit(1)
}

// 3. schema drift 检查（TS schema 表名 vs migration SQL 表名）
if (!run('🗄️ 检查 schema drift...', 'node scripts/check-db-schema-drift.mjs')) {
  process.exit(1)
}

// 4. lint-staged：对暂存文件运行 eslint --fix 和 prettier --write
if (!run('🎨 运行 lint-staged...', 'npx lint-staged')) {
  process.exit(1)
}

// 5. skipResponseSanitization 一致性检查（防止 token 被脱敏为 *** 导致功能损坏）
if (!run('🛡️ 检查 skipResponseSanitization...', 'node scripts/check-sanitizer-bypass.mjs --staged')) {
  process.exit(1)
}

// 6. 依赖版本碎片化检查（仅当 pnpm-lock.yaml 变更时）
if (!run('📦 检查依赖碎片化...', 'node scripts/check-dedupe.mjs --staged')) {
  process.exit(1)
}

console.log('✅ Pre-commit 检查通过')
