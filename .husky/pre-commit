#!/usr/bin/env node
// Pre-commit 守门钩子（跨平台兼容 Windows）
// 防止 API key 泄露 + i18n 键完整性 + zh-TW 简体字 + 陈旧 dist + 前端↔后端路由 + safeParse 静默忽略
const { execSync } = require('child_process')

function run(label, cmd) {
  console.log(label)
  try {
    execSync(cmd, { stdio: 'inherit', cwd: process.cwd() })
    return true
  } catch (e) {
    console.error(`❌ ${label}失败，提交已阻止`)
    return false
  }
}

// 1. API key 泄露检查
if (!run('🔐 检查 API key 泄露...', 'node scripts/check-api-key-leak.mjs --staged')) {
  process.exit(1)
}

// 2. i18n 键完整性检查
if (!run('🌐 检查 i18n 键完整性...', 'node scripts/check-i18n-keys.mjs --staged')) {
  process.exit(1)
}

// 2b. zh-TW 简体字残留检查（opencc-js cn→tw 对比）
// 通用 i18n 守门工具，替代专用脚本 scan-zh-tw-simp.mjs
if (!run('🔍 检查 zh-TW 简体字残留...', 'node scripts/scan-i18n-zh-residue.mjs zh-TW --staged')) {
  process.exit(1)
}

// 2c. ko.json 中文残留检查（防止韩语翻译文件出现未翻译的中文）
// 通用 i18n 守门工具，替代专用脚本 scan-ko-zh-residue.mjs
if (!run('🔍 检查 ko.json 中文残留...', 'node scripts/scan-i18n-zh-residue.mjs ko --staged')) {
  process.exit(1)
}

// 2d. ja.json 中文残留检查（warn-only，不阻塞但提醒）
// 日文汉字词（登録/確認/削除等）太多，charRange 启发式假阳性海量，
// 改为 warnOnly 模式：所有汉字只 warn 不阻塞，避免无效拦截
run('🔍 检查 ja.json 中文残留(warn-only)...', 'node scripts/scan-i18n-zh-residue.mjs ja --staged')

// 2e. en.json 破碎机翻英文检查（阻塞，防止 AgentDevPlatform/BigModelAppDev 等机翻拼接积累）
if (!run('🔍 检查 en.json 破碎英文...', 'node scripts/check-i18n-broken-en.mjs --staged')) {
  process.exit(1)
}

// 3. schema drift 检查（TS schema 表名 vs migration SQL 表名）
if (!run('🗄️ 检查 schema drift...', 'node scripts/check-db-schema-drift.mjs --staged')) {
  process.exit(1)
}

// 4. packages 陈旧 dist 检查(防止 export 缺失导致 module not found)
if (!run('📦 检查 packages 陈旧 dist...', 'node scripts/check-stale-dist.mjs')) {
  process.exit(1)
}

// 4b. packages/*/dist UTF-8 BOM 检查(2026-07-19 admin-auth.js 踩坑落地)
// 防止 PowerShell WriteAllText 默认 UTF-16 LE BOM 编码导致 Turbopack 解析失败
// 阻断策略:扫描所有 packages/*/dist/** 下的 .js .mjs .cjs .ts .map 文件,前 3 字节含 BOM 则 exit 1
if (!run('🔤 检查 dist 文件 UTF-8 BOM...', 'node scripts/check-dist-encoding.mjs')) {
  process.exit(1)
}

// 4c. packages/api-client 源码字节级 UTF-8 完整性检查(2026-07-19 share.ts 损坏踩坑落地)
// 防止 endpoints/*.ts 中文注释字符级丢失(如"内容 *"丢失换行符导致 source map vlq 异常,
// Turbopack rope 合并时 "invalid utf-8 sequence" build 失败)
// 守门:扫描 src/endpoints/*.ts 字节序列,检测非法 UTF-8 continuation bytes
if (!run('🔤 检查 api-client 源码 UTF-8 完整性...', 'node scripts/check-api-client-utf8.mjs')) {
  process.exit(1)
}

// 5. lint-staged：对暂存文件运行 eslint --fix 和 prettier --write
if (!run('🎨 运行 lint-staged...', 'npx lint-staged')) {
  process.exit(1)
}

// 6. skipResponseSanitization 一致性检查（防止 token 被脱敏为 *** 导致功能损坏）
if (!run('🛡️ 检查 skipResponseSanitization...', 'node scripts/check-sanitizer-bypass.mjs --staged')) {
  process.exit(1)
}

// 7. 依赖版本碎片化检查（仅当 pnpm-lock.yaml 变更时）
if (!run('📦 检查依赖碎片化...', 'node scripts/check-dedupe.mjs --staged')) {
  process.exit(1)
}

// 8. 前端↔后端路由一致性（strict，0 缺失后阻止回归）
if (!run('🔗 检查前端↔后端路由一致性...', 'node scripts/check-api-routes.mjs')) {
  process.exit(1)
}

// 9. safeParse silent-ignore 巡检(warn-only, 仅打印风险点)
run('🔍 safeParse 静默忽略巡检(warn-only)...', 'node scripts/check-safe-parse.mjs')

// 10. OpenAPI spec 存在性检查(informational)
run('📋 OpenAPI spec 检查(informational)...', 'node scripts/openapi-check.mjs')

// 11. 容器圆角守门(AGENTS.md 第 4 节强制规则)
// 防止新增 rounded-full / rounded-pill / 9999px / 50% 用于容器
// 豁免: img / Switch Thumb / Radio / Avatar shape=circle / <=14px 装饰点 / 红点底 / animate-spin
if (!run('⭕ 检查容器圆角违规...', 'node scripts/check-rounded-full.mjs --staged')) {
  process.exit(1)
}

// 12. 交付报告一致性守门(AGENTS.md 第 11 节强制规则)
// 防止"无后续建议/完整收尾"与"P1-P5/优化项/TODO"在同一份 .md 报告中同时出现
// 豁免: 讨论 AGENTS.md 第 11 节本身的章节 / check-delivery-report-consistency 守门脚本章节
// 增量扫描: staged 模式只检查含新增行(+)的章节,历史违规不阻塞新 commit
if (!run('📋 检查交付报告一致性...', 'node scripts/check-delivery-report-consistency.mjs --staged')) {
  process.exit(1)
}

// 13b. PROJECT_PLAN.md 长度守门(2026-07-19 根因诊断落地)
// 防止 PROJECT_PLAN.md 膨胀超过 50KB 导致 AI 上下文窗口撑爆,模型被迫停止响应
// 阈值: 50KB(约 1250 行),超出则阻止 commit,强制归档历史条目至 .trae-cn/archive/
if (!run('📐 检查 PROJECT_PLAN.md 体积...', 'node scripts/check-project-plan-size.mjs')) {
  process.exit(1)
}

// 13c. PROJECT_PLAN.md 已完成任务条目防误删守门(2026-07-20 立)
// 防止归档精简操作误删已完成任务条目(CLI 配置导入任务条目历史上被两次误删)
// 规则: ### XXX(已完成 ✅ ...) 标题行被删除时,必须在 diff 中有 <!-- 已归档 占位注释
// 合规操作: 移动完整条目到 .trae-cn/archive/ + 在原位置留归档占位注释
if (!run('🗂️  检查 PROJECT_PLAN.md 已完成任务防误删...', 'node scripts/check-project-plan-archive.mjs --staged')) {
  process.exit(1)
}

// 14. (已移除) 根路径 / 路由守门
// 原计划引用 scripts/check-root-route-redirect.mjs,但该脚本从未创建,
// 且 AGENTS.md 第 4 节实际为"前端 UI 约束"(无"根路径硬约束"规则)。
// (marketing) 路由组为合法根路径营销页,redirects.config 含 73 条合法重定向。
// 移除此死代码引用以解除 commit 阻塞(2026-07-19)。

// 15. 迁移完整性守门(M-63 落地, 7 大类 29 子项)
// 防止 oauth_private_keys/agent_billings 表回退 + agents.ts 8 端点回退 + 25 处 100% 声明无证据
// --staged 模式:仅当 PROJECT_PLAN.md 被 staged 时强制审计报告存在性;无关 commit 跳过此环境检查
// 退出码 0/1: 0=pass, 1=fail 阻断 commit
if (!run('📊 检查迁移完整性(7 大类 29 子项)...', 'node scripts/check-api-migration-completeness.mjs --staged')) {
  process.exit(1)
}

// 17. CSS 颜色 token 嵌套守门(2026-07-19 登录框描边样式回归落地)
// 防止新增 `hsl(var(--xxx))` / `rgb(var(--xxx))` 嵌套形式
// 根因: Tailwind v4 @theme 把 --color-* 序列化为 hsl(),外层包裹会变成 hsl(hsl(...)) 非法被浏览器静默丢弃
// 正确写法: 直接 var(--color-*) 引用,需要透明度用 color-mix(in srgb, var(--xxx) 60%, transparent)
if (!run('🎨 检查 CSS 颜色 token 嵌套...', 'node scripts/check-input-border-var.mjs --staged')) {
  process.exit(1)
}

// 18. 原生 title tooltip 守门(2026-07-20 hover 提示统一项目样式落地)
// 防止新增 HTML title 属性用于 hover 提示(浏览器原生样式与项目 <Tooltip> 不一致)
// 规则: <Button title="..."> / <button title="..."> / <td|div|span|p|a|img title="..."> → 用 <Tooltip> 包裹
// 豁免: <Modal/Alert/StatCard> 等 component 自带 title prop / <Button asChild title>(透传) / <iframe title>(a11y)
if (!run('🖱️  检查原生 title tooltip 违规...', 'node scripts/check-native-title-tooltip.mjs --staged')) {
  process.exit(1)
}

// 19. Staged 污染预警 (warn-only, 2026-07-20 立)
// 防止多 agent 并行时误把其他 agent 改动一起 commit (污染事故, AGENTS.md §16)
// 启发式: staged > 10 文件 + 跨 ≥ 3 个一级子目录 → 打印警告 (不阻塞)
// 配套工具: scripts/guard-push-other-agent-changes.mjs (白名单模式, 阻塞)
run('⚠️  检查 staged 污染预警(warn-only)...', 'node scripts/check-staged-pollution.mjs')

// 20. Tailwind class 冲突守门(2026-07-21 M-64 修复同步立,PageIndicator h-4/h-2 + w-1.5/w-2 冲突教训)
// 防止 className 模板字面量 BASE/BRANCH 出现多套 size 类导致后值覆盖前值,UI 实际渲染与设计意图脱节
// 检测:  className={`base ${cond ? '' : 'other'}`} 形式 + BASE/BRANCH h-X/w-Y 不一致
// 豁免:  行内/上方一行 // tailwind-class-conflict-allow | 纯三元 | 纯字符串 | cn() 调用
if (!run('🎯 检查 Tailwind class 冲突...', 'node scripts/check-tailwind-class-conflict.mjs --staged')) {
  process.exit(1)
}

// 21. 多端同步开发守门(warn-only, 2026-07-21 立, AGENTS.md §9 升级配套)
// 检测 staged 文件跨端分布, 单端改动未在 PROJECT_PLAN.md 标注"平台独占/仅 X 端"时 warn
// 4 场景: 纯豁免目录 pass / packages/* 未标注 warn / ≥2 端 pass / 1 端已标注 pass 未标注 warn
// 不阻塞 commit, 提醒 agent 按 §9 默认全端连通或显式补标注
run('🌐 检查多端同步开发守门(warn-only)...', 'node scripts/check-multi-end-sync.mjs')

// 22. README 同步守门(warn-only, 2026-07-22 立, AGENTS.md §22)
// 检测 staged 中 apps/*/src 或 packages/*/src 功能代码改动但 README.md 未在 staged 中
// 触发条件: 新功能模块 / 现有功能重大调整 / 守门规则新增 / 对外能力清单变化
// 豁免: bug 修复 / 重构 / 测试 / 配置 / 单端内部优化 / 文档 / 守门脚本本身
// 不阻塞 commit, 提醒 agent 按 §22 同步更新 README.md(功能开发后强制 README + git 同 commit)
// 反面案例: 2026-07-22 P3 深度层三大壁垒交付后 README 未同步, 用户在远端看不到最新能力清单
run('📖 检查 README 同步守门(warn-only)...', 'node scripts/check-readme-sync.mjs --staged')

// 24. 侧边栏宽度一致性守门(2026-07-22 立, 防回归)
// 防止 design-tokens.css 的 --sidebar-width 与 sidebar.tsx 的 SIDEBAR_WIDTH 不一致,
// 导致首屏 CSS 预设值 → JS useEffect 覆盖值的宽度跳变闪烁
// 根因案例: design-tokens.css 有 200px, sidebar.tsx SIDEBAR_WIDTH=130, CSS 先渲染 200px 再跳到 130px
if (!run('📏 检查侧边栏宽度一致性...', 'node scripts/check-sidebar-width-consistency.mjs --staged')) {
  process.exit(1)
}

// 23. Staged 文件清单打印(lightweight, 2026-07-21 立)
// commit 前最后看一眼 staged 清单, 杜绝"混入其他 agent 改动"污染事故
// 与第 19 项 check-staged-pollution 互补: 19 是跨端超阈值 warn, 23 是无条件打印清单
// info-only, 始终 exit 0, 不影响其他守门
run('📋 打印 staged 文件清单(info)...', 'node scripts/check-staged-files.mjs')

// 16. 条件 typecheck 闸门(仅 staged 涉及 apps/web 时跑 web typecheck)
// 防止"commit 通过但 push 失败"的循环(f21dc473 commit 漏掉 import 的教训)
// 只在 staged 文件涉及 apps/web 时跑,避免影响其他包的 commit 速度
try {
  const stagedOutput = execSync('git diff --cached --name-only --diff-filter=ACMR', {
    encoding: 'utf8',
    cwd: process.cwd(),
  })
  const stagedFiles = stagedOutput.split('\n').filter(Boolean)
  const involvesWeb = stagedFiles.some((f) => f.startsWith('apps/web/') || f.startsWith('apps\\web\\'))
  if (involvesWeb) {
    if (!run('🔍 条件 typecheck 闸门(apps/web staged)...', 'pnpm --filter @ihui/web run typecheck')) {
      console.error('❌ apps/web typecheck 失败,提交已阻止(请在本地修复后再 commit)')
      process.exit(1)
    }
  } else {
    console.log('⏭  条件 typecheck 闸门(无 apps/web staged 改动, 跳过)')
  }

  // 16b. 条件 database 重建闸门(仅 staged 涉及 packages/database/src/ 时跑)
  // 防止"schema 加字段但 dist 未重建导致运行时字段缺失"的循环(0108 icon_svg 字段踩坑)
  // database 包的 package.json 配置 import: ./dist/index.js,运行时加载 dist 而非 src
  // typecheck 用 src 不会报错,但 api 运行时用 dist 会字段缺失
  const involvesDatabase = stagedFiles.some(
    (f) => f.startsWith('packages/database/src/') || f.startsWith('packages\\database\\src\\'),
  )
  if (involvesDatabase) {
    if (!run('📦 条件 database 重建闸门(packages/database/src staged)...', 'pnpm --filter @ihui/database build')) {
      console.error('❌ @ihui/database build 失败,提交已阻止(请修复 schema 编译错误后再 commit)')
      process.exit(1)
    }
  } else {
    console.log('⏭  条件 database 重建闸门(无 packages/database/src staged 改动, 跳过)')
  }
} catch (e) {
  // 非 git 环境,跳过
  console.log('⏭  条件 typecheck/database 闸门(非 git 环境, 跳过)')
}

console.log('✅ Pre-commit 检查通过')
