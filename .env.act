# 本地 act 演练环境变量(与 GitHub Actions vars 对齐)
# 此文件用于 nektos/act 本地 CI 演练,不含敏感信息
# 敏感 secrets 请放在 .secrets.act(已被 .gitignore 忽略)

NODE_ENV=test
CI=true
TURBO_TELEMETRY_DISABLED=1
NEXT_TELEMETRY_DISABLED=1

# 数据库(本地 Docker)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ihui_test
REDIS_URL=redis://localhost:6379/1

# AI 服务
AI_SERVICE_URL=http://localhost:8000
STUB_MODE_LLM=true

# 前端
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=IHUI-AI-Local-Act

# 测试
PLAYWRIGHT_BROWSERS_PATH=/cache/ms-playwright
