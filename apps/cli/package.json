{
  "name": "@ihui/cli",
  "version": "1.0.0",
  "description": "IHUI AI Coding Agent CLI — 对标 Claude Code / Codex",
  "private": true,
  "type": "module",
  "bin": {
    "ihui": "./dist/index.js"
  },
  "scripts": {
