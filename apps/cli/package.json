{
  "name": "@ihui/cli",
  "version": "1.0.0",
  "description": "IHUI AI Coding Agent CLI — 对标 Claude Code / Codex",
  "private": false,
  "type": "module",
  "bin": {
    "ihui": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -b tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@ihui/api-client": "workspace:*",
    "@ihui/context-compaction": "workspace:*",
    "@ihui/types": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "gpt-tokenizer": "^3.4.0",
    "inquirer": "^12.3.0",
    "ora": "^8.1.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.10.0",
    "minimumVersion": "1.0.0"
  }
}
