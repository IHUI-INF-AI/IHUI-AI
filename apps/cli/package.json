    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.10.0"
  }
