{
  "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
  "version": "1.0.0",
  "description": "IHUI AI Coding Agent CLI — 对标 Claude Code / Codex",
  "homepage": "https://ihui.ai",
  "license": "MIT",
  "notes": "安装后运行 ihui 启动。如未加入 PATH,请确保 npm 全局 bin 在 PATH(npm prefix -g)。",
  "depends": "nodejs-lts",
  "url": "https://registry.npmjs.org/@ihui/cli/-/cli-1.0.0.tgz",
  "hash": "",
  "post_install": [
    "npm install -g \"$dir\\package.tgz\" 2>$null",
    "if (Test-Path \"$dir\\package\") { Copy-Item \"$dir\\package\\*\" \"$dir\" -Recurse -Force }"
  ],
  "bin": "ihui.cmd",
  "checkver": {
    "url": "https://registry.npmjs.org/@ihui/cli",
    "jsonpath": "$.['dist-tags'].latest"
  },
  "autoupdate": {
    "url": "https://registry.npmjs.org/@ihui/cli/-/cli-$version.tgz"
  }
}
