# IHUI-AI API 服务环境变量样例(新架构 Fastify)
# 复制为 .env 后按需修改

NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# 数据库(PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ihui_ai

# Redis
REDIS_URL=redis://localhost:6379

# 认证
JWT_SECRET=change-me-to-a-32-char-secret-string
JWT_EXPIRES_IN=7d
# 凭证加密密钥(至少 32 字符,生产环境必须修改)
CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-32-char-encryption-key

# AI 服务地址(FastAPI ai-service)
AI_SERVICE_URL=http://localhost:8000

# SMTP 邮件(可选,默认禁用)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ihui.ai
SMTP_ENABLED=false

# API 日志采样(可选)
API_LOG_SAMPLE_RATE=0.1
API_LOG_ENABLED=true
API_LOG_BATCH_SIZE=100
API_LOG_FLUSH_INTERVAL_MS=5000

# BullMQ Worker 开关(可选,默认 true)
# 多实例部署时可设为 false 仅做生产者
ENABLE_WORKER=true

# AI 回调共享密钥(可选,为空则不校验)
# 配置后 ai-service 回调 /api/ai/callback 需携带 X-Internal-Secret 头
AI_CALLBACK_SECRET=

# =============================================================================
# AI 服务密钥
# =============================================================================
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DOUBAO_API_KEY=your-doubao-api-key-here
BAILIAN_APP_ID=your-bailian-app-id-here
BAILIAN_API_KEY=your-bailian-api-key-here
KLING_ACCESS_KEY=your-kling-access-key-here
KLING_SECRET_KEY=your-kling-secret-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
ZHIPU_API_KEY=your-zhipu-api-key-here
QWEN_API_KEY=your-qwen-api-key-here
COZE_API_BASE=https://api.coze.cn
COZE_API_KEY=your-coze-api-key-here
COZE_PRIVATE_KEY=your-coze-private-key-here
COZE_BASE_URL=https://api.coze.cn

# =============================================================================
# N8N / LangChain
# =============================================================================
N8N_BASE_URL=your-n8n-base-url-here
N8N_WEBHOOK_PATH=/webhook/chat
FREELLMAPI_BASE_URL=your-freelmapi-base-url-here
LANGCHAIN_BASE_URL=your-langchain-base-url-here

# =============================================================================
# 腾讯云
# =============================================================================
TENCENT_SECRET_ID=your-tencent-secret-id-here
TENCENT_SECRET_KEY=your-tencent-secret-key-here

# =============================================================================
# 阿里短信
# =============================================================================
ALI_SMS_ACCESS_KEY_ID=your-ali-sms-access-key-id-here
ALI_SMS_ACCESS_KEY_SECRET=your-ali-sms-access-key-secret-here
SMS_API_BASE_URL=your-sms-api-base-url-here

# =============================================================================
# 股票分析
# =============================================================================
STOCK_API_KEY=your-stock-api-key-here
STOCK_API_BASE=https://api.openai.com/v1
STOCK_MODEL_ID=gpt-4o-mini

# =============================================================================
# GitHub
# =============================================================================
GITHUB_TOKEN=your-github-token-here

# =============================================================================
# 文件上传
# =============================================================================
UPLOAD_DIR=./uploads
FILE_UPLOAD_URL=your-file-upload-url-here
FILE_UPLOAD_NETWORK_URL=your-file-upload-network-url-here

# =============================================================================
# OpenTelemetry
# =============================================================================
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=ihui-api

# =============================================================================
# ELK 日志
# =============================================================================
ELK_LOG_ENABLED=false
ELK_LOG_SAMPLE_RATE=0.1

# =============================================================================
# DB 监控
# =============================================================================
N1_QUERY_THRESHOLD=20
SLOW_SQL_THRESHOLD_MS=1000

# =============================================================================
# 告警通知
# =============================================================================
ALERT_EMAIL_TO=alert@example.com
DINGTALK_WEBHOOK=your-dingtalk-webhook-here
DINGTALK_SECRET=your-dingtalk-secret-here
WECHAT_WORK_WEBHOOK=your-wechat-work-webhook-here
FEISHU_WEBHOOK=your-feishu-webhook-here
SLACK_WEBHOOK=your-slack-webhook-here
TEAMS_WEBHOOK=your-teams-webhook-here
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key-here
PAGERDUTY_API_URL=https://events.pagerduty.com
GENERIC_WEBHOOK_URL=your-generic-webhook-url-here
GENERIC_WEBHOOK_AUTH_HEADER=your-generic-webhook-auth-header-here

# =============================================================================
# Computer Use
# =============================================================================
IHUI_COMPUTER_USE_ENABLED=0
