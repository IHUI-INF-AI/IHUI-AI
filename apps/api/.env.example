NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ihui
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-in-production-min-32-chars

# OpenTelemetry 分布式追踪（R74 P2）
# 启用门控：配置 OTEL_EXPORTER_OTLP_ENDPOINT 即启用；OTEL_ENABLED=false 显式禁用
# 未配置时降级为 no-op，不阻塞启动
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=@ihui/api
# 采样率：默认 10%（生产环境足够；traceidratio 采样器）
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ===== 邮件服务商 =====
# auto=按收件域名智能路由(国内→tencent,国外→resend);smtp/resend/tencent=强制指定
MAIL_PROVIDER=auto
# SMTP 兜底通道(SMTP_ENABLED=true 时启用)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ihui.ai
# Resend 通道(国外优先)
RESEND_API_KEY=
RESEND_FROM=
# 腾讯云 SES 通道(国内优先)
TENCENT_SES_SECRET_ID=
TENCENT_SES_SECRET_KEY=
TENCENT_SES_FROM=noreply@example.com
TENCENT_SES_REGION=ap-hongkong
# 腾讯云 SES 邮件模板 ID(在腾讯云 SES 控制台 → 邮件模板 创建审核通过后获得)
# 配置后验证码邮件走 Template 模式(腾讯云默认权限);未配置则 fallback Simple(需申请权限)
TENCENT_SES_TEMPLATE_REGISTER=
TENCENT_SES_TEMPLATE_LOGIN=
TENCENT_SES_TEMPLATE_RESET=

# ============================================================================
# OAuth 网页扫码登录 (2026-07-21 增补)
# ----------------------------------------------------------------------------
# 未配置时相关平台的 is<Provider>Configured() 返回 false,API 返回 mock 响应
# 凭据获取详见各平台开发者后台:
#   - 微信开放平台:https://open.weixin.qq.com/ → 管理中心 → 网站应用
#   - 钉钉开发者后台:https://open-dev.dingtalk.com/ → 应用开发 → 企业内部开发
#   - 企业微信管理后台:https://work.weixin.qq.com/ → 我的企业 + 应用管理 → 自建应用
# ============================================================================

# 微信网站扫码登录(开放平台 - 网站应用)
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 钉钉扫码登录(企业内部应用)
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_REDIRECT_URI=http://localhost:3000/callback?platform=dingtalk

# 企业微信扫码登录(自建应用)
# WECOM_CORP_ID 来自 "我的企业 → 企业信息 → 企业 ID"
# WECOM_AGENT_ID / WECOM_SECRET 来自 "应用管理 → 自建应用 → 应用详情"
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_REDIRECT_URI=http://localhost:3000/callback?platform=enterpriseWechat

# 飞书扫码登录(自建应用)
# 凭据获取:https://open.feishu.cn → 开发者后台 → 应用详情 → 凭证与基础信息
# redirect_uri 在飞书后台 "安全设置 → 重定向 URL" 中配置,需与本处一致
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ============================================================================
# GitHub API Token (2026-07-22 增补,AI 世界热度同步用)
# ----------------------------------------------------------------------------
# 用途:apps/api/src/jobs/ai-world-sync.ts 抓取 GitHub 仓库 stars/forks 元数据
# 未配置:GitHub API 限额 60 次/小时(共享 IP,易被限流)
# 已配置:限额提升到 5000 次/小时(稳定生产可用)
# 获取方式:https://github.com/settings/tokens → Fine-grained tokens
#   - Token type: Fine-grained
#   - Repository access: Public Repositories (read-only)
#   - Permissions: Contents: Read
#   - 有效期建议:90 天(到期前 7 天控制台提醒)
# ============================================================================
GITHUB_TOKEN=

# ============================================================================
# ElasticSearch 全文检索 (2026-07-21 增补,迁移自 edu service search-service)
# ----------------------------------------------------------------------------
# 未配置时 SearchEsService 自动降级到 PostgreSQL 全文检索(不影响功能)
# 启用步骤:
#   1. 部署 ElasticSearch 7.x+ (本地或远程)
#   2. 配置 ELASTICSEARCH_URL 指向 ES 服务地址
#   3. 可选: pnpm --filter @ihui/api add @elastic/elasticsearch
#      (未安装时 SearchEsService 用 dynamic import + try/catch 降级)
#   4. 调用 POST /api/search/reindex 触发全量索引(articles/news/resources/asks)
#   5. 调用 GET /api/search/status 查看索引状态
# ============================================================================
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX_PREFIX=ihui
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
