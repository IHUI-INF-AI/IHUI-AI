{
  "name": "@ihui/miniapp-taro",
  "version": "0.0.0",
  "private": true,
  "description": "IHUI-AI 小程序端 (Taro 4 + React + TypeScript + Tailwind)",
  "scripts": {
    "dev": "taro build --type weapp --watch",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:alipay": "taro build --type alipay --watch",
    "dev:swan": "taro build --type swan --watch",
    "dev:tt": "taro build --type tt --watch",
    "dev:h5": "taro build --type h5 --watch",
    "build": "taro build --type weapp",
    "build:weapp": "taro build --type weapp",
    "build:alipay": "taro build --type alipay",
    "build:swan": "taro build --type swan",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .swc .turbo node_modules"
  },
  "dependencies": {
    "@babel/runtime": "^7.21.5",
    "@ihui/api-client": "workspace:*",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-html": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "@tarojs/cli": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/vite-runner": "4.2.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-preset-taro": "4.2.0",
    "eslint": "^9.16.0",
    "react-refresh": "^0.14.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^4.5.5",
    "vitest": "^2.1.8"
  }
}
