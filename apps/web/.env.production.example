# ============================================================================
# 第三方登录生产环境配置模板 (填好后复制为 .env.production 或 .env.local)
# ----------------------------------------------------------------------------
# 使用方法:
#   1. 按下面 8 个平台的提示去对应开发者后台注册应用、获取凭据
#   2. 把所有 _PLACEHOLDER_ 替换为真实值
#   3. 复制为 apps/web/.env.local 或部署平台的 secret 管理
#   4. 生产部署前必须确认: NEXT_PUBLIC_DEMO_MODE=false (默认就是 false,见下方)
# ============================================================================

# ----------------------------------------------------------------------------
# API 地址(生产)
# ----------------------------------------------------------------------------
# 生产:api 走主域 /api/ 路径(Nginx 反代到 api server),避免跨子域 Cookie 问题
NEXT_PUBLIC_API_URL=https://aizhs.top
API_URL=http://127.0.0.1:8080

# ----------------------------------------------------------------------------
# 分域 SSO 架构 (2026-07-21 立,生产必填)
# ----------------------------------------------------------------------------
# 主域:aizhs.top (用户日常访问)
# 认证子域:bsm.aizhs.top (只承载登录/OAuth 回调,主功能 307 跳回主域)
# Cookie 域:.aizhs.top → aizhs.top + bsm.aizhs.top 互通,登录一次两边都生效
# 部署:Nginx 需配置 bsm.aizhs.top 子域(见 deploy/nginx/conf.d/bsm-subdomain.conf)
NEXT_PUBLIC_AUTH_SUBDOMAIN=https://bsm.aizhs.top
NEXT_PUBLIC_MAIN_DOMAIN=https://aizhs.top
NEXT_PUBLIC_COOKIE_DOMAIN=.aizhs.top

# ----------------------------------------------------------------------------
# 全局:演示模式开关
# ----------------------------------------------------------------------------
# 生产环境: 保持 false (缺省) 或 注释掉 —— demo 模式会让任何人点登录都直接绕过真实授权!
# 开发环境: 设置 true,任何未配真凭据的平台会本地 mock 登录成功
# 安全门: 代码内已硬性约束, NODE_ENV=production 时强制关闭 demo,无法绕过
# NEXT_PUBLIC_DEMO_MODE=false

# ----------------------------------------------------------------------------
# 1. Google 登录
# ----------------------------------------------------------------------------
# 凭据获取: https://console.cloud.google.com/apis/credentials
# 步骤: 创建项目 → OAuth 同意屏幕(外部) → 凭据 → 创建 OAuth 客户端 ID(Web 应用)
# 回调 URL 必须包含以下两个(逗号分隔) + 生产域名
NEXT_PUBLIC_GOOGLE_ENABLED=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3001/google/callback
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ----------------------------------------------------------------------------
# 2. Apple 登录 (最复杂,需要 Apple Developer 付费账号 688/年)
# ----------------------------------------------------------------------------
# 凭据获取: https://developer.apple.com/account/resources/identifiers/list
# 步骤: 创建 Services ID → 创建 Key(勾选 Sign In with Apple)→ 下载 .p8 私钥
# 重要: APPLE_CLIENT_SECRET 不是写死的,需要用 Team ID/Key ID/Private Key
#       签 JWT 生成。运行: node scripts/generate-apple-secret.mjs
NEXT_PUBLIC_APPLE_ENABLED=true
NEXT_PUBLIC_APPLE_CLIENT_ID=com.yourcompany.ihui.web
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3001/apple/callback
APPLE_TEAM_ID=YOUR_10_CHAR_TEAM_ID
APPLE_KEY_ID=YOUR_10_CHAR_KEY_ID
# 私钥: .p8 文件内容(包含 BEGIN/END 标记),多行用 \n 转义
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBAD...你的私钥内容...-----END PRIVATE KEY-----"
APPLE_CLIENT_SECRET=运行generate-apple-secret.mjs后粘贴JWT

# ----------------------------------------------------------------------------
# 3. 微信扫码登录 (国内基础)
# ----------------------------------------------------------------------------
# 凭据获取: https://open.weixin.qq.com/  → 管理中心 → 网站应用 → 创建
# 必须备案域名 + 微信开放平台 300 元认证
NEXT_PUBLIC_WECHAT_ENABLED=true
NEXT_PUBLIC_WECHAT_APP_ID=wx3c37d94ee8f70148
NEXT_PUBLIC_WECHAT_REDIRECT_URI=http://localhost:3001/callback?platform=wechat
NEXT_PUBLIC_WECHAT_SCOPE=snsapi_login
WECHAT_APP_SECRET=YOUR_WECHAT_APP_SECRET

# ----------------------------------------------------------------------------
# 4. 钉钉扫码登录 (企业用户)
# ----------------------------------------------------------------------------
# 凭据获取: https://open-dev.dingtalk.com/  → 应用开发 → 企业内部应用
# 回调域名需在"安全设置"中配置
NEXT_PUBLIC_DINGTALK_ENABLED=true
NEXT_PUBLIC_DINGTALK_APP_ID=YOUR_DINGTALK_APP_ID
NEXT_PUBLIC_DINGTALK_CLIENT_ID=YOUR_DINGTALK_APP_ID
NEXT_PUBLIC_DINGTALK_REDIRECT_URI=http://localhost:3001/callback?platform=dingtalk
NEXT_PUBLIC_DINGTALK_SCOPE=openid
DINGTALK_APP_SECRET=YOUR_DINGTALK_APP_SECRET

# ----------------------------------------------------------------------------
# 5. 企业微信扫码登录
# ----------------------------------------------------------------------------
# 凭据获取: https://work.weixin.qq.com/wework_admin/  → 应用管理 → 创建应用
# 需配置"网页授权及 JS-SDK"的可信域名
NEXT_PUBLIC_ENTERPRISE_WECHAT_ENABLED=true
NEXT_PUBLIC_ENTERPRISE_WECHAT_APP_ID=YOUR_CORP_ID
NEXT_PUBLIC_ENTERPRISE_WECHAT_AGENT_ID=YOUR_AGENT_ID
NEXT_PUBLIC_ENTERPRISE_WECHAT_REDIRECT_URI=http://localhost:3001/callback?platform=enterpriseWechat
NEXT_PUBLIC_ENTERPRISE_WECHAT_SCOPE=snsapi_privateinfo
ENTERPRISE_WECHAT_CORP_SECRET=YOUR_CORP_SECRET

# ----------------------------------------------------------------------------
# 6. GitHub 登录 (海外开发者最爱,3 分钟搞定)
# ----------------------------------------------------------------------------
# 凭据获取: https://github.com/settings/developers  → New OAuth App
# 步骤: 填 Homepage URL + Authorization callback URL,立即获得 Client ID/Secret
NEXT_PUBLIC_GITHUB_ENABLED=true
NEXT_PUBLIC_GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:3001/callback?platform=github
NEXT_PUBLIC_GITHUB_SCOPE=read:user user:email
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ----------------------------------------------------------------------------
# 7. 飞书登录 (需要飞书企业账号)
# ----------------------------------------------------------------------------
# 凭据获取: https://open.feishu.cn/app  → 创建企业自建应用
# 步骤: 凭证与基础信息 → 拿 App ID + App Secret → 权限管理开通用户基本信息
NEXT_PUBLIC_FEISHU_ENABLED=true
NEXT_PUBLIC_FEISHU_APP_ID=YOUR_FEISHU_APP_ID
NEXT_PUBLIC_FEISHU_CLIENT_ID=YOUR_FEISHU_APP_ID
NEXT_PUBLIC_FEISHU_REDIRECT_URI=http://localhost:3001/callback?platform=feishu
NEXT_PUBLIC_FEISHU_SCOPE=contact:user.base:readonly
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET

# ----------------------------------------------------------------------------
# 8. 支付宝登录 (需要企业营业执照)
# ----------------------------------------------------------------------------
# 凭据获取: https://open.alipay.com/develop/manage  → 创建网页&移动应用
# 步骤: 选 RSA2 加签 → 下载密钥工具生成密钥对 → 上传公钥拿支付宝公钥
NEXT_PUBLIC_ALIPAY_ENABLED=true
NEXT_PUBLIC_ALIPAY_APP_ID=YOUR_ALIPAY_APPID
NEXT_PUBLIC_ALIPAY_REDIRECT_URI=http://localhost:3001/callback?platform=alipay
NEXT_PUBLIC_ALIPAY_SCOPE=auth_user
ALIPAY_APP_ID=YOUR_ALIPAY_APPID
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAA...你的私钥...-----END RSA PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY=YOUR_ALIPAY_PUBLIC_KEY
