    "dev:stable": "rimraf .next .dev.lock && node scripts/check-lock.js dev && next dev -p 8801",
    "prebuild": "node scripts/check-lock.js build",
    "build": "next build",
    "build:analyze": "pnpm exec next experimental-analyze",
    "start": "next start -p 8801",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "clean": "rimraf .next .turbo node_modules",
    "storybook": "storybook dev -p 6006",
