# ============================================================================
# IHUI-AI Web (Next.js 15) 环境变量示例
# ----------------------------------------------------------------------------
# 使用方法: cp .env.example .env.local, 然后替换为实际值
# ============================================================================

# --- 后端服务地址 (next.config.ts rewrites 使用, 服务端变量, 不暴露到浏览器) ---
API_URL=http://localhost:8080
AI_SERVICE_URL=http://localhost:8000

# --- Google 登录 ---
NEXT_PUBLIC_GOOGLE_ENABLED=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/google/callback
NEXT_PUBLIC_GOOGLE_SCOPE=openid email profile

# --- Apple 登录 ---
NEXT_PUBLIC_APPLE_ENABLED=true
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3000/apple/callback
NEXT_PUBLIC_APPLE_SCOPE=name email

# --- 钉钉登录 ---
NEXT_PUBLIC_DINGTALK_ENABLED=true
NEXT_PUBLIC_DINGTALK_APP_ID=your-dingtalk-app-id
NEXT_PUBLIC_DINGTALK_CLIENT_ID=your-dingtalk-client-id
NEXT_PUBLIC_DINGTALK_REDIRECT_URI=http://localhost:3000/dingtalk/callback
NEXT_PUBLIC_DINGTALK_SCOPE=openid corpid

# --- 企业微信登录 ---
NEXT_PUBLIC_ENTERPRISE_WECHAT_ENABLED=true
NEXT_PUBLIC_ENTERPRISE_WECHAT_APP_ID=your-enterprise-wechat-app-id
NEXT_PUBLIC_ENTERPRISE_WECHAT_AGENT_ID=your-enterprise-wechat-agent-id
NEXT_PUBLIC_ENTERPRISE_WECHAT_REDIRECT_URI=http://localhost:3000/enterprise/callback
NEXT_PUBLIC_ENTERPRISE_WECHAT_SCOPE=snsapi_privateinfo

# --- 微信登录 ---
NEXT_PUBLIC_WECHAT_ENABLED=true
NEXT_PUBLIC_WECHAT_APP_ID=your-wechat-app-id
NEXT_PUBLIC_WECHAT_REDIRECT_URI=http://localhost:3000/wechat/callback
NEXT_PUBLIC_WECHAT_SCOPE=snsapi_login

# --- GitHub 登录 ---
NEXT_PUBLIC_GITHUB_ENABLED=true
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:3000/github/callback
NEXT_PUBLIC_GITHUB_SCOPE=read:user user:email
