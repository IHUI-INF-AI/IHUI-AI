# ============================================================================
# IHUI-AI Web (Next.js 15) 环境变量示例
# ----------------------------------------------------------------------------
# 使用方法: cp .env.example .env.local, 然后替换为实际值
# ============================================================================

# --- 后端服务地址 (next.config.ts rewrites 使用, 服务端变量, 不暴露到浏览器) ---
API_URL=http://localhost:8802
AI_SERVICE_URL=http://localhost:8803

# --- SaaS 部署层管理后台 (P1-2.2) ---
# SaaS Admin API 地址(默认本地 8830)
ADMIN_API_URL=http://127.0.0.1:8830
# 与 admin-api 的 ADMIN_API_KEY 一致;留空则代理请求将全部 401
ADMIN_SAAS_API_KEY=

# --- Google 登录 ---
NEXT_PUBLIC_GOOGLE_ENABLED=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:8801/google/callback
NEXT_PUBLIC_GOOGLE_SCOPE=openid email profile

# --- Apple 登录 ---
NEXT_PUBLIC_APPLE_ENABLED=true
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:8801/apple/callback
NEXT_PUBLIC_APPLE_SCOPE=name email

# --- 钉钉登录(扫码:DTFrameLogin SDK 内嵌二维码) ---
NEXT_PUBLIC_DINGTALK_ENABLED=true
NEXT_PUBLIC_DINGTALK_APP_ID=your-dingtalk-app-id
NEXT_PUBLIC_DINGTALK_CLIENT_ID=your-dingtalk-client-id
# redirect_uri 必须与钉钉开放平台"授权回调域"一致,默认走统一 /callback?platform=dingtalk
NEXT_PUBLIC_DINGTALK_REDIRECT_URI=http://localhost:8801/callback?platform=dingtalk
NEXT_PUBLIC_DINGTALK_SCOPE=openid corpid

# --- 企业微信登录(扫码:wwLogin SDK 内嵌二维码,自建应用 PC 网页扫码) ---
NEXT_PUBLIC_ENTERPRISE_WECHAT_ENABLED=true
NEXT_PUBLIC_ENTERPRISE_WECHAT_APP_ID=your-wecom-corp-id
NEXT_PUBLIC_ENTERPRISE_WECHAT_AGENT_ID=your-wecom-agent-id
# redirect_uri 必须与企业微信后台"可信域名"一致,默认走统一 /callback?platform=enterpriseWechat
NEXT_PUBLIC_ENTERPRISE_WECHAT_REDIRECT_URI=http://localhost:8801/callback?platform=enterpriseWechat
NEXT_PUBLIC_ENTERPRISE_WECHAT_SCOPE=snsapi_privateinfo

# --- 微信登录(扫码:WxLogin.js 内嵌二维码) ---
NEXT_PUBLIC_WECHAT_ENABLED=true
NEXT_PUBLIC_WECHAT_APP_ID=your-wechat-app-id
# redirect_uri 必须与微信开放平台"授权回调域"一致,默认走统一 /callback?platform=wechat
NEXT_PUBLIC_WECHAT_REDIRECT_URI=http://localhost:8801/callback?platform=wechat
NEXT_PUBLIC_WECHAT_SCOPE=snsapi_login

# --- 飞书登录(扫码:QRLogin SDK 内嵌二维码) ---
NEXT_PUBLIC_FEISHU_ENABLED=true
NEXT_PUBLIC_FEISHU_APP_ID=your-feishu-app-id
NEXT_PUBLIC_FEISHU_CLIENT_ID=your-feishu-client-id
# redirect_uri 必须与飞书开放平台"重定向 URL"一致,默认走统一 /callback?platform=feishu
NEXT_PUBLIC_FEISHU_REDIRECT_URI=http://localhost:8801/callback?platform=feishu
NEXT_PUBLIC_FEISHU_SCOPE=contact:user.base:readonly

# --- GitHub 登录 ---
NEXT_PUBLIC_GITHUB_ENABLED=true
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:8801/github/callback
NEXT_PUBLIC_GITHUB_SCOPE=read:user user:email

# --- 支付宝登录(网页授权:openauth.alipay.com/oauth2/publicAppAuthorize.htm) ---
# 支付宝登录使用 auth_code 模式(非标准 OAuth2 跳转),前端拿到 auth_code 后
# 直接走 /api/auth/alipay/callback,后端用应用私钥换 access_token + user_id。
# 与扫码登录不同,支付宝是网页授权(无二维码),redirect_uri 在支付宝开放平台
# "应用详情 → 授权回调地址" 中配置,需与本处一致。
NEXT_PUBLIC_ALIPAY_ENABLED=true
NEXT_PUBLIC_ALIPAY_APP_ID=your-alipay-app-id
NEXT_PUBLIC_ALIPAY_REDIRECT_URI=http://localhost:8801/callback?platform=alipay
NEXT_PUBLIC_ALIPAY_SCOPE=auth_user
