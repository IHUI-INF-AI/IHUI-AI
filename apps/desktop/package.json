{
  "name": "@ihui/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/with-rust.ps1 dev",
    "build": "powershell -ExecutionPolicy Bypass -File ./scripts/with-rust.ps1 build",
    "build:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/with-rust.ps1 build --debug",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "icons:regen": "powershell -ExecutionPolicy Bypass -File ./scripts/regen-icons.ps1",
    "clean": "rimraf dist node_modules .turbo src-tauri/target"
  },
  "dependencies": {
    "@ihui/api-client": "workspace:*",
    "@ihui/shared": "workspace:*",
    "@ihui/types": "workspace:*",
    "@ihui/ui": "workspace:*",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-http": "^2.0.1",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-store": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@ihui/eslint-config": "workspace:*",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
