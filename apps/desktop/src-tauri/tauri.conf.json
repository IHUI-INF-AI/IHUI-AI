{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IHUI AI",
  "version": "0.1.0",
  "identifier": "com.ihui.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @ihui/web dev",
    "beforeBuildCommand": "pnpm --filter @ihui/web build",
    "devUrl": "http://localhost:8801",
    "frontendDist": "../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "IHUI AI 桌面端",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      },
      {
        "label": "admin",
        "title": "IHUI AI 管理后台",
        "url": "/admin",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://127.0.0.1:8802 https:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8802 http://localhost:8802 http://127.0.0.1:8803 http://localhost:8803 https:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    },
    "updater": {
      "endpoints": ["https://releases.ihui.ai/desktop/latest.json"],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "IHUI AI 桌面端",
    "longDescription": "IHUI AI 多端平台桌面客户端,基于 Tauri 2 + WebView2"
  }
}
