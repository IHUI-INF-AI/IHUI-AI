NODE_ENV=development
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/ihui_ai
REDIS_URL=redis://localhost:6379

# LLM 密钥(用户 plan 套餐优先,免费 provider 备选)
# 任选一个 provider 配置即可激活真实调用,全部为空降级 stub 模式

# 用户 plan 套餐(复制此文件为 .env 后填入真实 key)
STEPFUN_API_KEY=<your-stepfun-api-key>  # 申请: https://api.stepfun.com/step_plan/v1
STEPFUN_API_BASE=https://api.stepfun.com/step_plan/v1
AGNES_API_KEY=<your-agnes-api-key>  # 申请: https://apihub.agnes-ai.com/v1
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# 免费 provider(备选,需自行注册 key)
GROQ_API_KEY=  # 免费 https://console.groq.com/keys
GEMINI_API_KEY=  # 免费 https://aistudio.google.com/apikey
OPENROUTER_API_KEY=  # 有 free tier https://openrouter.ai/keys

# 免费 / 试用 credits provider(2026-07-22 接入,参考 cheahjs/free-llm-api-resources)
# Cloudflare Workers AI(10,000 neurons/day 免费)
CLOUDFLARE_API_TOKEN=  # https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=  # https://dash.cloudflare.com/ 右侧 Account ID
# NVIDIA NIM(40 req/min 免费)
NVIDIA_API_KEY=  # https://build.nvidia.com/explore/discover
# GitHub Models(Copilot Free tier 可用)
GITHUB_TOKEN=  # https://github.com/settings/tokens
# Vercel AI Gateway($5/月免费额度)
VERCEL_AI_GATEWAY_KEY=  # https://vercel.com/docs/ai-gateway
# OpenCode Zen(完全免费)
# 示例 key(可能已失效,请自行注册): sk-GyX66j2M7ohdzry8z1MVGZxwbzn5SkbWVBYFCw8qiEnb5We64Kt0n5xpek6R3z6l
OPENCODE_ZEN_KEY=  # https://opencode.ai/docs/zen/
# Modal($5/月注册赠送)
MODAL_API_KEY=  # https://modal.com/settings/tokens
# Inference.net($1 注册送 + 回邮件调查 +$25)
INFERENCE_NET_API_KEY=  # https://inference.net
# NLP Cloud($15 注册送)
NLP_CLOUD_API_KEY=  # https://nlpcloud.com/home
# Scaleway(1M tokens 免费)
SCALEWAY_API_KEY=  # https://console.scaleway.com/generative-api/models
# Alibaba Cloud International Model Studio(1M tokens/模型免费)
ALIBABA_INTL_API_KEY=  # https://bailian.console.alibabacloud.com/

# Provider 连通性测试结果(2026-07-16 本地 PowerShell 实测):
# - StepFun:   200 OK,连通正常(step-3.7-flash)
# - Agnes:     503 model_not_found — key 有效但 gpt-4o 在当前 plan(cachellm group)下不可用,
#               生产环境需确认 plan 支持的模型清单或更换模型名
# - Groq:      本地未配置 key,需注册后填入;LiteLLM 原生支持,生产 Docker 可通
# - Gemini:    本地未配置 key,需注册后填入;LiteLLM 原生支持,生产 Docker 可通
# - OpenRouter: 本地未配置 key,需注册后填入;LiteLLM 原生支持,生产 Docker 可通

# 付费(可选)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 模型名(前缀决定 provider,默认 StepFun)
LITELLM_MODEL=stepfun/step-3.7-flash

# 后端 API 地址(ai-service 回调 apps/api 用,本地开发端口 3001)
API_SERVICE_URL=http://localhost:3001

# AI 回调共享密钥(可选,与后端 AI_CALLBACK_SECRET 一致)
# 配置后回调 /api/ai/callback 时携带 X-Internal-Secret 头;为空则不发送
AI_CALLBACK_SECRET=

# 火山引擎实时语音(可选)
VOLC_APP_ID=
VOLC_ACCESS_KEY=
VOLC_APP_KEY=

# 凭据加密密钥(必填,与 apps/api 的 CREDENTIALS_ENCRYPTION_KEY 共享)
# 用于解密 ai_model_config 表中的 api_key_enc 字段;至少 32 字符
CREDENTIALS_ENCRYPTION_KEY=

# OpenTelemetry 分布式追踪（R74 P2）
# 启用门控：配置 OTEL_EXPORTER_OTLP_ENDPOINT 即启用；OTEL_ENABLED=false 显式禁用
# 未配置时降级为 no-op，不阻塞启动
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=@ihui/ai-service
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
