{
  "version": "1.0.0",
  "updatedAt": "2026-07-19",
  "description": "Java Spring 路由前缀 → IHUI-AI Fastify 路由映射规则表。基于 v1 审计 970 缺失端点(806 真实缺失)分析得出,用于 v2 比对脚本将路径风格差异从真实缺失中剥离。",
  "notes": [
    "规则按 strategies 数组顺序应用:先 prefix_strip / prefix_rewrite 处理 Java 微服务前缀,再 module_rewrite 处理业务模块命名差异",
    "策略 prefix_strip: 剥离 Java 前缀(如 /auth-api/member → /member),IHUI-AI 用中间件鉴权",
    "策略 prefix_rewrite: 替换 Java 前缀为 IHUI-AI 等价前缀(如 /sso → /auth-sso)",
    "策略 module_rewrite: 替换路径第 1 段业务模块名(单数→复数 / snake_case→kebab-case / 业务重命名)",
    "策略 skip_module: 跳过该模块(开发态/调试用,不计入真实缺失)",
    "每条规则有 reason + hits 字段,hits 在 v2 脚本运行后回写实际命中端点数"
  ],
  "prefixRules": [
    {
      "javaPrefix": "/public-api",
      "ihuiPrefix": "",
      "strategy": "prefix_strip",
      "reason": "Java edu service 对外公开接口前缀,IHUI-AI 直接挂业务模块(/public-api/member → /member),鉴权由中间件统一处理",
      "hits": 122
    },
    {
      "javaPrefix": "/auth-api",
      "ihuiPrefix": "",
      "strategy": "prefix_strip",
      "reason": "Java 需鉴权接口前缀,IHUI-AI 用 packages/auth 中间件统一鉴权,路径直接挂业务模块(/auth-api/invoice → /invoice)",
      "hits": 143
    },
    {
      "javaPrefix": "/open-api",
      "ihuiPrefix": "",
      "strategy": "prefix_strip",
      "reason": "Java open-api 前缀,与 public-api 同义,IHUI-AI 直接挂业务模块",
      "hits": 0
    },
    {
      "javaPrefix": "/openapi",
      "ihuiPrefix": "",
      "strategy": "prefix_strip",
      "reason": "Java openapi 前缀变体,与 public-api 同义,IHUI-AI 直接挂业务模块",
      "hits": 0
    },
    {
      "javaPrefix": "/sso",
      "ihuiPrefix": "/auth-sso",
      "strategy": "prefix_rewrite",
      "reason": "SSO 单点登录已合并到 apps/api/src/routes/auth-extended.ts 和 auth-sso.ts,前缀由 /sso 重写为 /auth-sso",
      "hits": 5
    },
    {
      "javaPrefix": "/webrtc",
      "ihuiPrefix": "/live",
      "strategy": "prefix_rewrite",
      "reason": "WebRTC 微服务已合并到 live 模块(webrtc 主要用于直播场景,IHUI-AI live.ts 统一承载)",
      "hits": 0
    },
    {
      "javaPrefix": "/pay-callback",
      "ihuiPrefix": "/webhooks/pay",
      "strategy": "prefix_rewrite",
      "reason": "支付回调已重构到 payment-gateway.ts 的 /webhooks/pay/* 路径",
      "hits": 0
    },
    {
      "javaPrefix": "/behaviors",
      "ihuiPrefix": "/behavior",
      "strategy": "prefix_rewrite",
      "reason": "Behavior 微服务已合并到 behavior 子模块",
      "hits": 0
    },
    {
      "javaPrefix": "/api",
      "ihuiPrefix": "",
      "strategy": "prefix_strip",
      "reason": "Java 部分 controller 用 /api 前缀,IHUI-AI 默认全部路由走 /api 前缀(由 Fastify register 自动加),无需显式声明",
      "hits": 7
    }
  ],
