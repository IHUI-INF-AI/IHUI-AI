# IHUI-AI 开发环境配置样例(新架构: Fastify + Next.js + FastAPI)
# 复制为 .env 后填入实际值
# 生产环境请使用 .env.production.example → .env.production

# ==================== 基础 ====================
DOMAIN=localhost
APP_TITLE=智汇AI社区(开发)
NODE_ENV=development
# 前端端口(web 服务)
WEB_PORT=3000
# 后端端口(api 服务)
API_PORT=3001
# AI 服务端口(ai-service)
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000

# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=ihui
DB_PASSWORD=<your-dev-db-password>
DB_NAME=ihui_dev
DATABASE_URL=postgresql://ihui:<your-dev-db-password>@localhost:5432/ihui_dev

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ==================== 认证加密 ====================
# JWT 密钥(至少 32 字符随机字符串)
JWT_SECRET=<generate-random-256bit-key-for-dev>
JWT_EXPIRES_IN=7d
# 凭证加密密钥(至少 32 字符,用于加密第三方 OAuth 凭证等敏感数据)
CREDENTIALS_ENCRYPTION_KEY=<generate-random-256bit-encryption-key>

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000

# ==================== AI 服务密钥(用户 plan 套餐优先,免费 provider 备选) ====================
# 任选一个 provider 配置即可激活真实 AI 调用,全部为空降级 stub 模式(返回模拟响应)

# --- 用户 plan 套餐 ---
# StepFun(默认 provider)
STEPFUN_API_KEY=<your-stepfun-api-key>
STEPFUN_API_BASE=https://api.stepfun.com/step_plan/v1
# Agnes AI(备用)
AGNES_API_KEY=<your-agnes-api-key>
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# --- 免费 provider(备选) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ==================== 第三方登录(可选) ====================
# 飞书 OAuth
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Coze OAuth
COZE_CLIENT_ID=
COZE_CLIENT_SECRET=

# ==================== 支付(可选) ====================
# 微信支付
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_APP_ID=

# ==================== 对象存储(可选) ====================
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-beijing

# ==================== 短信/邮件(可选) ====================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ==================== 监控(可选,开发环境通常关闭) ====================
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=false
