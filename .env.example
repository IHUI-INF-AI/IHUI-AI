# IHUI-AI 开发环境配置样例(新架构: Fastify + Next.js + FastAPI)
# 复制为 .env 后填入实际值
# 生产环境请使用 .env.production.example → .env.production

# ==================== 基础 ====================
DOMAIN=localhost
APP_TITLE=智汇AI社区(开发)
NODE_ENV=development
# 前端端口(web 服务)
WEB_PORT=3000
# 后端端口(api 服务)
API_PORT=3001
# AI 服务端口(ai-service)
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8803

# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=ihui
DB_PASSWORD=<your-dev-db-password>
DB_NAME=ihui_dev
DATABASE_URL=postgresql://ihui:<your-dev-db-password>@localhost:8810/ihui_dev

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:8811

# ==================== 认证加密 ====================
# JWT 密钥(至少 32 字符随机字符串)
JWT_SECRET=<generate-random-256bit-key-for-dev>
JWT_EXPIRES_IN=7d
# 凭证加密密钥(至少 32 字符,用于加密第三方 OAuth 凭证等敏感数据)
CREDENTIALS_ENCRYPTION_KEY=<generate-random-256bit-encryption-key>

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000

# ==================== AI 服务密钥(用户 plan 套餐优先,免费 provider 备选) ====================
# 任选一个 provider 配置即可激活真实 AI 调用,全部为空降级 stub 模式(返回模拟响应)

# --- 用户 plan 套餐 ---
# StepFun(默认 provider)
STEPFUN_API_KEY=<your-stepfun-api-key>
STEPFUN_API_BASE=https://api.stepfun.com/step_plan/v1
# Agnes AI(备用)
AGNES_API_KEY=<your-agnes-api-key>
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# --- 免费 provider(备选) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ==================== 第三方登录(可选) ====================
# 飞书 OAuth
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Coze OAuth
COZE_CLIENT_ID=
COZE_CLIENT_SECRET=

# ==================== 支付(可选) ====================
# 微信支付(命名与生产 .env.production.example 对齐,代码读取 WX_* 前缀)
WX_SHOP_ID=
WX_PAY_V3_KEY=
WX_PAY_CERT_SERIAL=
WX_PAY_PRIVATE_KEY=
WX_MINI_APPID=
# 移动应用 AppID(微信开放平台注册的移动应用,与小程序 AppID 不同;RN 端 APP 支付必需)
WX_APP_APPID=
# APP 支付回调地址(公网 HTTPS,微信服务器回调后端)
WX_ANDROID_NOTIFY_URL=

# ==================== 对象存储(可选) ====================
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-beijing

# ==================== 短信/邮件(可选) ====================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ==================== 监控(可选,开发环境通常关闭) ====================
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=false

# ==================== Registry Sync(资源上游自动同步中心)====================
# GitHub API Token(避免 rate limit,未认证 60/h,认证后 5000/h)
GITHUB_TOKEN=

# 自建 registry URL(默认 https://registry.ihui.ai/api/registry/items)
IHUI_CUSTOM_REGISTRY_URL=

# Webhook HMAC-SHA256 签名密钥(接收上游 push 事件,各源独立)
GITHUB_WEBHOOK_SECRET=
NPM_WEBHOOK_SECRET=
MCP_MARKETPLACE_WEBHOOK_SECRET=
CUSTOM_WEBHOOK_SECRET=

# 同步任务开关(默认 true,设为 false 禁用定时同步)
REGISTRY_SYNC_ENABLED=true
# 同步间隔(小时,默认 6)
REGISTRY_SYNC_INTERVAL_HOURS=6
