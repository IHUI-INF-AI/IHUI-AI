# ===================================================================
# IHUI AI Platform - 环境变量示例
# ===================================================================
# 复制本文件为 .env 后填入实际值, 启动服务时自动加载.
# 生产环境复制为 .env.production, 配合 ENV=production.
#
# 优先级: 操作系统环境变量 > .env 文件 > Pydantic 默认值
# ===================================================================

# ===================================================================
# DATABASE (PostgreSQL)
# ===================================================================
DB1_URL=postgresql://zhs:password@127.0.0.1:5432/zhs_platform
DB1_POOL_SIZE=50
DB1_MAX_OVERFLOW=200
DB1_POOL_RECYCLE=3600

DB2_URL=postgresql://zhs:password@127.0.0.1:5432/zhs_center
DB2_POOL_SIZE=20
DB2_MAX_OVERFLOW=80

DB3_URL=postgresql://zhs:password@127.0.0.1:5432/zhs_course
DB3_POOL_SIZE=15
DB3_MAX_OVERFLOW=45

# ===================================================================
# REDIS
# ===================================================================
REDIS_URL=redis://:password@127.0.0.1:6379/0
REDIS_PREFIX=public_socket:

# ===================================================================
# APP
# ===================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4
ENV=production
JWT_SECRET_KEY=replace-me-with-random-64-chars
SESSION_SECRET_KEY=replace-me-with-different-random-64-chars
INTERNAL_AUTH_KEY=replace-me-with-another-random-key

# ===================================================================
# NOTIFICATION (站内信 P1 封版 047)
# ===================================================================
# admin 接收方 UUID (站内信推送统一进他的 inbox, 多副本必须一致)
# 固定值: 00000000-0000-0000-0000-000000000001
NOTIFY_RECIPIENT_UUID=00000000-0000-0000-0000-000000000001
# 站内信最大保留数 (FIFO 淘汰非置顶, 默认 1000)
NOTIFY_MAX=1000
# 站内信归档天数 (已读超过 N 天的非置顶消息会被自动清理, 默认 7)
# 范围: [1, 365], 置顶消息永不被归档
NOTIFY_ARCHIVE_DAYS=7
# 站内信归档 dry-run 模式 (1/true/yes = 只统计不删, 0/false = 实际删除)
# 生产建议先开启 dry-run 预演, 确认数量后改为 0
NOTIFY_ARCHIVE_DRY_RUN=0

# ===================================================================
# CELERY (异步任务 / 定时调度)
# ===================================================================
# 对账任务周期: 每 6 小时执行一次, 推送告警到站内信
RECONCILE_CRON_HOURS=6
# Celery broker (与后端共用 Redis, 部署时必须与 celery worker/beat 一致)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ===================================================================
# ALEMBIC
# ===================================================================
# 部署 PG 后执行: alembic upgrade head
ALEMBIC_DATABASE=ai  # ai / center / course
