# ==================== 数据库 (PostgreSQL) ====================
# 已完成 MySQL → PG 迁移, 3 套引擎通过 schema 隔离
# Database 1: zhs_platform - ai 域 (agents, payments, users)
DB1_URL=postgresql+psycopg2://zhs:<your-password>@127.0.0.1:5432/zhs_platform
DB1_POOL_SIZE=50
DB1_MAX_OVERFLOW=200
DB1_POOL_RECYCLE=3600
DB1_PRE_PING=true

# Database 2: zhs_platform - center 域 (accounts, auth, tokens)
DB2_URL=postgresql+psycopg2://zhs:<your-password>@127.0.0.1:5432/zhs_platform
DB2_POOL_SIZE=20
DB2_MAX_OVERFLOW=80
DB2_POOL_RECYCLE=3600
DB2_PRE_PING=true

# Database 3: zhs_platform - course 域 (courses, videos, education)
DB3_URL=postgresql+psycopg2://zhs:<your-password>@127.0.0.1:5432/zhs_platform
DB3_POOL_SIZE=15
DB3_MAX_OVERFLOW=45
DB3_POOL_RECYCLE=3600
DB3_PRE_PING=true

# ==================== Redis ====================
# 生产推荐: 使用 REDIS_URL 完整连接串 (包含密码/SSL)
# 格式: redis://[:password@]host:port/db 或 rediss:// (SSL)
REDIS_URL=redis://:password@localhost:6379/0
# 单项配置 (REDIS_URL 为空时使用)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=public_socket:

# ==================== Coze API ====================
COZE_API_BASE=https://api.coze.cn
COZE_COM_BASE_URL=https://api.coze.com
COZE_OAUTH_APP_ID=
COZE_OAUTH_APP_AUD=api.coze.cn
COZE_OAUTH_TOKEN_URL=https://api.coze.cn/api/permission/oauth2/token
COZE_PUBLIC_KEY_ID=
COZE_ACCOUNT_ID=
# COZE_PRIVATE_KEY must contain the full PEM private key for JWT signing

# ---------- COZE OAuth 多模式 (设备端 / Web / PKCE / JWT 独立凭证) ----------
COZE_DEVICE_OAUTH_CLIENT_ID=
COZE_WEB_OAUTH_CLIENT_ID=
COZE_WEB_OAUTH_CLIENT_SECRET=
COZE_WEB_OAUTH_REDIRECT_URI=
COZE_PKCE_OAUTH_CLIENT_ID=
COZE_JWT_OAUTH_CLIENT_ID=
COZE_JWT_OAUTH_PRIVATE_KEY=
COZE_JWT_OAUTH_PRIVATE_KEY_FILE_PATH=
COZE_JWT_OAUTH_PUBLIC_KEY_ID=

