# ==================== 业务通知邮件 (历史 ihui-ai-edu-notification-service 迁移) ====================
# 与告警 SMTP 分开, 用于业务通知 (注册/订单/课程等)
NOTIFY_SMTP_HOST=smtp.exmail.qq.com
NOTIFY_SMTP_PORT=465
NOTIFY_SMTP_USER=notice@chawind.com
NOTIFY_SMTP_PASSWORD=
NOTIFY_SMTP_PROTOCOL=smtps
NOTIFY_SMTP_DEFAULT_ENCODING=utf-8
NOTIFY_EMAIL_FROM=notice@chawind.com

# ==================== 253 短信平台 (历史 ihui-ai-edu-notification-service 迁移) ====================
SMS_253_URL=http://smssh1.253.com/msg/send/json
SMS_253_ACCOUNT=
SMS_253_PASSWORD=
SMS_253_TEMPLATE=Your verification code is: 
# 无锡物业短信 (备用通道)
SMS_WUXI_API_HOST=
SMS_WUXI_CLIENT_ID=
SMS_WUXI_CLIENT_SECRET=
SMS_WUXI_PREFIX=[Notice]
SMS_WUXI_REGISTER_TEMPLATE=Your verification code is %s, valid for 5 minutes.

# ==================== 消息队列 (历史 RocketMQ 替代方案) ====================
# 使用 Redis Stream 作为轻量消息队列 (无需额外部署 RabbitMQ)
MQ_ENABLED=false
MQ_BACKEND=redis_stream
MQ_REDIS_STREAM_PREFIX=learning_
MQ_RABBIT_URL=

# Aliyun Identity Auth (optional)
# ALI_AUTH_APP_URL=
# ALI_AUTH_APP_KEY=
# ALI_AUTH_APP_SECRET=
# ALI_AUTH_APP_CODE=

# Aliyun Access Key (optional)
# ALI_ACCESS_KEY=
# ALI_ACCESS_SECRET=

# ==================== Third Party ====================
FEISHU_APP_ID=
FEISHU_SECRET=
FEISHU_OAUTH=
FEISHU_INFO=
GOOGLE_APP_ID=
GOOGLE_SECRET=
WECOM_SUITE_SECRET=

# ==================== App ====================
# 2026-06-24 联调: 补齐 ENV 和 CORS_ORIGINS, 生产环境必须显式配置
# ENV: dev / test / staging / production (生产环境启动会强制校验 CORS_ORIGINS 和 JWT_SECRET_KEY)
ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false
API_WORKERS=4
API_TITLE=ZHS Platform
# JWT 密钥: >=32 字符的强随机串, 不可为默认值, 否则启动报 RuntimeError
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=<CHANGE-ME-GENERATE-RANDOM-256BIT-KEY>
JWT_EXPIRE_MINUTES=60
SESSION_SECRET_KEY=<CHANGE-ME-GENERATE-RANDOM-KEY>
CHAT_ROOM_ADMIN_UUID=
# CORS 允许的前端源 (逗号分隔), 生产环境必须显式配置, 禁止用 *
# 示例: https://www.example.com,https://admin.example.com
CORS_ORIGINS=

# ==================== SMS ====================
SMS_API_BASE_URL=
SMS_VERIFY_ENDPOINT=/ai/login/pwd/smsVerify
SMS_CODE_VERIFY_ENDPOINT=/ai/login/pwd/verify

# ==================== File Upload ====================
FILE_UPLOAD_BASE_URL=
FILE_UPLOAD_URL=
FILE_UPLOAD_NETWORK_URL=

# ==================== SRS Media Server ====================
SRS_HOST=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_API_PORT=1985

# ==================== Token Pricing ====================
TOKEN_NORMAL_USER_PER_YUAN=20000
TOKEN_VIP_USER_PER_YUAN=20000
TOKEN_TRADER_USER_PER_YUAN=80000
TOKEN_PROMOTION_PER_YUAN=80000
TOKEN_BASE_MULTIPLIER=2.0

# ==================== Feature Flags ====================
FEATURE_AUTH_ENABLED=true
FEATURE_AGENTS_ENABLED=true
FEATURE_COZE_BOTS_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_AI_PROXIES_ENABLED=true
FEATURE_COURSES_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_CMS_ENABLED=true

# ==================== AI ====================
# AI first-time gift settings
AI_FIRST_GIFT_ID=20954cb5-7179-4985-b9d8-1d0b5c956005
AI_FIRST_GIFT_TOKENS=18888
AI_COMMISSION_DAY=7

# ==================== 迁移: client/backend → server/app ====================
# 以下为原 client/backend/ 的环境变量，已迁移至 server/app/
# 前端无需任何代码改动，所有 legacy 路由直接注册在原始路径 /api/<domain>/*
LEGACY_API_DOMAIN=127.0.0.1:8000
LEGACY_UPLOAD_DIR=uploads
LEGACY_LOCAL_UPLOADS_DIR=./local_uploads
