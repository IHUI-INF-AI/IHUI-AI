WX_PAY_PRIVATE_KEY_PATH=/ai_zhs/cert/zhsLogin_private.pem
WX_PAY_CERT_PASS=
WX_PAY_NOTIFY_URL=
WX_PAY_COURSE_NOTIFY_URL=
WX_ANDROID_NOTIFY_URL=

