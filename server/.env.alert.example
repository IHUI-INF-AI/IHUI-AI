# 真实生产告警 webhook 配置模板
# 生成时间: 2026-06-18T08:06:13.786962+00:00
# 必填项 (required=True) 必须配置, 否则告警无法投递
# 选填项 (required=False) 可后续按需补齐

# ============ 钉钉 (dingtalk) ============
# 必填: True, 方法: POST
# URL 格式: ^https://oapi\.dingtalk\.com/robot/send\?access_token=.+$
DINGTALK_WEBHOOK=

# ============ 微信企业版 (wechat_work) ============
# 必填: True, 方法: POST
# URL 格式: ^https://qyapi\.weixin\.qq\.com/cgi-bin/webhook/send\?key=.+$
WECHAT_WORK_WEBHOOK=

# ============ 飞书 (feishu) ============
# 必填: True, 方法: POST
# URL 格式: ^https://open\.feishu\.cn/open-apis/bot/v2/hook/.+$
FEISHU_WEBHOOK=

# ============ Slack (slack) ============
# 必填: False, 方法: POST
# URL 格式: ^https://hooks\.slack\.com/services/.+$
SLACK_WEBHOOK=

# ============ Teams (teams) ============
# 必填: False, 方法: POST
# URL 格式: ^https://.*\.webhook\.office\.com/webhookb2/.+$
TEAMS_WEBHOOK=

# ============ PagerDuty (pagerduty) ============
# 必填: False, 方法: POST
# URL 格式: ^[a-f0-9]{32}$
PAGERDUTY_INTEGRATION_KEY=

# ============ 邮件 (email) ============
# 必填: False, 方法: SMTP
# URL 格式: ^smtp\..+\..+$
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=alert@your-domain.com
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=alert@your-domain.com

# ============ Generic (generic) ============
# 必填: False, 方法: POST
# URL 格式: ^https?://.+$
GENERIC_WEBHOOK_URL=
