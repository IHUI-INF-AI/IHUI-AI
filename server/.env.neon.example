# ============================================================
# Neon 开发环境配置模板 (Serverless PostgreSQL 免费层)
# ============================================================
# 使用方法:
# 1. 在 Neon 注册并创建项目 (https://neon.tech, 免费无需信用卡)
# 2. 复制本文件为 .env (开发环境)
# 3. 在 Neon Dashboard → Connection Details 复制连接串, 填入下方 DB1/2/3_URL
# 4. 确保 DB_KEEP_ALIVE_ENABLED=True (Neon 5分钟休眠需保活)

ENV=dev

# --- Neon PostgreSQL 连接 ---
# Neon 连接串格式 (注意必须加 ?sslmode=require, Neon 强制 SSL):
#   postgresql+psycopg2://USER:PASSWORD@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require
DB1_URL=postgresql+psycopg2://YOUR_NEON_USER:YOUR_NEON_PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DB2_URL=postgresql+psycopg2://YOUR_NEON_USER:YOUR_NEON_PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DB3_URL=postgresql+psycopg2://YOUR_NEON_USER:YOUR_NEON_PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon 连接池调小 (免费层限制 100 CU-hr/月, 大连接池会快速耗尽)
DB1_POOL_SIZE=5
DB1_MAX_OVERFLOW=10
DB2_POOL_SIZE=3
DB2_MAX_OVERFLOW=5
DB3_POOL_SIZE=3
DB3_MAX_OVERFLOW=5

# --- Neon 保活 (关键!) ---
# Neon 免费层 5 分钟无连接即休眠, 下次查询冷启动 1-3 秒
# 开启后后台线程每 4 分钟 SELECT 1 保持活跃
DB_KEEP_ALIVE_ENABLED=True
DB_KEEP_ALIVE_INTERVAL_SECONDS=240

# --- Redis (开发环境可用 fakeredis 降级, 无需真实 Redis) ---
# 留空 REDIS_URL 时, 后端自动降级到 fakeredis (内存模拟)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (开发用, 生产必须换强随机密钥) ---
JWT_SECRET_KEY=dev-only-change-this-to-random-string
SESSION_SECRET_KEY=dev-only-change-this-too

# --- 调试 ---
API_DEBUG=True
API_RELOAD=True
API_WORKERS=1

# --- 多租户 (开发默认关闭) ---
MULTI_TENANT_ENABLED=False
