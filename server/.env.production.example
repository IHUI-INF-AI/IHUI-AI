# ========================================
# IHUI-AI FastAPI 后端 生产环境配置模板
# ========================================
# 来源: 整合 H:\历史项目存档 中所有 Java 微服务 application-prod.yml
# 创建日期: 2026-06-25
# 部署前请复制为 .env.production 并填入实际敏感值
# 真实敏感凭证: docs/PRODUCTION_CREDENTIALS.md（gitignored）
# ========================================

# ========================================
# 应用基本信息
# ========================================
APP_NAME=IHUI-AI
APP_ENV=production
APP_VERSION=1.0.0
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# ========================================
# 数据库 (PostgreSQL)
# ========================================
# 主库 (用户/会员/订单/支付/AI)
DB1_URL=postgresql+asyncpg://<PG_USER>:<PG_PASSWORD>@<PG_HOST>:<PG_PORT>/<PG_DATABASE>
DB1_POOL_SIZE=50
DB1_MAX_OVERFLOW=200
DB1_POOL_RECYCLE=3600
DB1_PRE_PING=true

# 业务库 (教育/课程/考试/直播)
DB2_URL=postgresql+asyncpg://<PG_USER>:<PG_PASSWORD>@<PG_HOST>:<PG_PORT>/<PG_DATABASE>
DB2_POOL_SIZE=20
DB2_MAX_OVERFLOW=80

# 行为/统计/日志库
DB3_URL=postgresql+asyncpg://<PG_USER>:<PG_PASSWORD>@<PG_HOST>:<PG_PORT>/<PG_DATABASE>
DB3_POOL_SIZE=15
DB3_MAX_OVERFLOW=45

# 多租户 (102 阶段 1)
MULTI_TENANT_ENABLED=false

# PostgreSQL 直连
PG_HOST=<PG_HOST>
PG_PORT=5432
PG_USER=<PG_USER>
PG_PASSWORD=<PG_PASSWORD>
PG_DATABASE=<PG_DATABASE>

# ========================================
# Redis
# ========================================
# 生产推荐: redis://:password@host:port/db
REDIS_URL=redis://:<REDIS_PASSWORD>@<REDIS_HOST>:<REDIS_PORT>/0
REDIS_HOST=<REDIS_HOST>
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_DB=0
REDIS_PREFIX=public_socket:

# ========================================
# Coze
# ========================================
COZE_API_BASE=https://api.coze.cn
COZE_COM_BASE_URL=https://api.coze.com
COZE_OAUTH_APP_ID=<COZE_OAUTH_APP_ID>
COZE_OAUTH_APP_AUD=api.coze.cn
COZE_OAUTH_TOKEN_URL=https://api.coze.cn/api/permission/oauth2/token
COZE_PUBLIC_KEY_ID=<COZE_PUBLIC_KEY_ID>
COZE_ACCOUNT_ID=<COZE_ACCOUNT_ID>
COZE_PRIVATE_KEY=<COZE_PRIVATE_KEY>

# ========================================
# 微信支付 / 小程序
# ========================================
WX_MINI_APPID=wx27028e276ffdbc5d
WX_MINI_SECRET=<WX_MINI_SECRET>
WX_PC_APPID=<WX_PC_APPID>
WX_PC_SECRET=<WX_PC_SECRET>
WX_APP_APPID=<WX_APP_APPID>
WX_SHOP_ID=<WX_SHOP_ID>
WX_PAY_V3_KEY=<WX_PAY_V3_KEY>
WX_PAY_PUB_KEY_ID=<WX_PAY_PUB_KEY_ID>
WX_PAY_CERT_SERIAL=<WX_PAY_CERT_SERIAL>
WX_PAY_PRIVATE_KEY_PATH=/ai_zhs/cert/zhsLogin_private.pem
WX_PAY_CERT_PASS=<WX_PAY_CERT_PASS>
WX_PAY_NOTIFY_URL=https://<BACKEND_DOMAIN>/api/v1/payments/wechat/notify
WX_PAY_COURSE_NOTIFY_URL=https://<BACKEND_DOMAIN>/api/v1/payments/wechat/course/notify
WX_ANDROID_NOTIFY_URL=https://<BACKEND_DOMAIN>/api/v1/payments/wechat/android/notify
WX_PAY_PLATFORM_CERT_PATH=/ai_zhs/cert/wxpay_cert.pem
WX_API_BASE=https://api.mch.weixin.qq.com

# ========================================
# AI 多厂商
# ========================================
N8N_BASE_URL=<N8N_BASE_URL>
N8N_WEBHOOK_PATH=/webhook/chat
N8N_API_KEY=<N8N_API_KEY>
LANGCHAIN_BASE_URL=<LANGCHAIN_BASE_URL>
LANGCHAIN_API_KEY=<LANGCHAIN_API_KEY>

# 阿里通义
DASHSCOPE_API_KEY=<DASHSCOPE_API_KEY>
# 智谱
ZHIPU_API_KEY=<ZHIPU_API_KEY>
# 豆包
DOUBAO_API_KEY=<DOUBAO_API_KEY>
DOUBAO_MODEL_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_JM_API_KEY=<DOUBAO_JM_API_KEY>
DOUBAO_JM_SECRET_KEY=<DOUBAO_JM_SECRET_KEY>
DOUBAO_IMAGE_API_URL=<DOUBAO_IMAGE_API_URL>
# DeepSeek
DEEPSEEK_API_KEY=<DEEPSEEK_API_KEY>
# 可灵
KLING_ACCESS_KEY=<KLING_ACCESS_KEY>
KLING_SECRET_KEY=<KLING_SECRET_KEY>
KLING_ALT_ACCESS_KEY=<KLING_ALT_ACCESS_KEY>
KLING_ALT_SECRET_KEY=<KLING_ALT_SECRET_KEY>
# OpenRouter
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
# LUYALA
LUYALA_API_KEY=<LUYALA_API_KEY>
# 腾讯云
TENCENT_SECRET_ID=<TENCENT_SECRET_ID>
TENCENT_SECRET_KEY=<TENCENT_SECRET_KEY>
# TBox 事件通知 HMAC 签名
TBOX_NOTIFY_SECRET=<TBOX_NOTIFY_SECRET>
# 百度
BAIDU_API_KEY=<BAIDU_API_KEY>
# Suno / Sora2 / Gemini
SUNO_API_KEY=<SUNO_API_KEY>
SORA2_API_KEY=<SORA2_API_KEY>
GEMINI_API_KEY=<GEMINI_API_KEY>
# 阿里百炼
BAILIAN_APP_ID=<BAILIAN_APP_ID>
# 火山引擎
VOLC_APP_KEY=<VOLC_APP_KEY>

# 特殊智能体ID
SPECIAL_BOT_IDS=
# 聊天室系统管理员UUID
CHAT_ROOM_ADMIN_UUID=<CHAT_ROOM_ADMIN_UUID>
N8N_TOKEN_COUNTING_UNIT=3
AI_AGENT_USE_HISTORY=10

# ========================================
# 支付宝
# ========================================
ALIPAY_APP_ID=<ALIPAY_APP_ID>
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_PRIVATE_KEY_PATH=/ai_zhs/cert/appSecretRSA2048.txt
ALIPAY_PUBLIC_KEY_PATH=/ai_zhs/cert/alipayPublicKey_RSA2.txt
ALIPAY_MERCHANT_PRIVATE_KEY=<ALIPAY_MERCHANT_PRIVATE_KEY>
ALIPAY_PUBLIC_KEY=<ALIPAY_PUBLIC_KEY>
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_NOTIFY_URL=https://<BACKEND_DOMAIN>/api/v1/payments/alipay/notify
ALIPAY_RETURN_URL=https://<FRONTEND_DOMAIN>/payment/success

# ========================================
# MinIO 对象存储
# ========================================
MINIO_URL=https://minio.<DOMAIN>
MINIO_ENDPOINT=https://minio.<DOMAIN>
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>
MINIO_BUCKET=sys-mini
MINIO_FILE_URL=https://minio.<DOMAIN>/sys-mini

# ========================================
# 告警通道
# ========================================
DINGTALK_WEBHOOK=<DINGTALK_WEBHOOK>
DINGTALK_SECRET=<DINGTALK_SECRET>
WECHAT_WORK_WEBHOOK=<WECHAT_WORK_WEBHOOK>
FEISHU_WEBHOOK=<FEISHU_WEBHOOK>
ALERT_EMAIL_TO=ops@<DOMAIN>
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=465
SMTP_USER=<SMTP_USER>
SMTP_PASSWORD=<SMTP_PASSWORD>
PAGERDUTY_API_URL=https://events.pagerduty.com/v2/enqueue
PAGERDUTY_ROUTING_KEY=<PAGERDUTY_ROUTING_KEY>
SLACK_WEBHOOK=<SLACK_WEBHOOK>
TEAMS_WEBHOOK=<TEAMS_WEBHOOK>
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_AUTH_HEADER=

# AlertManager Webhook 签名
ALERTMANAGER_WEBHOOK_SECRET=<ALERTMANAGER_WEBHOOK_SECRET>

# ========================================
# 安全 / JWT
# ========================================
JWT_SECRET_KEY=<JWT_SECRET_KEY>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ========================================
# CORS
# ========================================
CORS_ALLOW_ORIGINS=https://<FRONTEND_DOMAIN>,https://<ADMIN_DOMAIN>,https://<H5_DOMAIN>
CORS_ALLOW_CREDENTIALS=true

# ========================================
# 日志
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/ihui-ai/app.log

# ========================================
# 短信 / 邮箱
# ========================================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=<SMS_ACCESS_KEY>
SMS_ACCESS_SECRET=<SMS_ACCESS_SECRET>
SMS_SIGN_NAME=<SMS_SIGN_NAME>
SMS_TEMPLATE_CODE=<SMS_TEMPLATE_CODE>

# ========================================
# Elasticsearch / ELK
# ========================================
ELASTICSEARCH_HOST=<ES_HOST>
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=<ES_USERNAME>
ELASTICSEARCH_PASSWORD=<ES_PASSWORD>
ELASTICSEARCH_INDEX_PREFIX=ihui-ai
