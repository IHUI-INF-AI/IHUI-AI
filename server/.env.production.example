KLING_MODEL_DOMAIN=https://api-beijing.klingai.com

# ==================== 流式响应事件名与超时 [可选] ====================
DOUBAO_STREAM_EVENT_THINKING=conversation.message.delta
DOUBAO_STREAM_EVENT_COMPLETED=conversation.chat.completed
COMMON_STREAM_EVENT_ERROR=system.error
