MQ_BACKEND=redis_stream
MQ_REDIS_STREAM_PREFIX=learning_
MQ_RABBIT_URL=

# ==================== 安全密钥 [必填] ====================
# TBox 通知 HMAC 签名密钥 (生成: python -c "import secrets; print(secrets.token_urlsafe(48))")
TBOX_NOTIFY_SECRET=<FILL_IN>
# 内部服务间认证密钥 (生成: python -c "import secrets; print(secrets.token_urlsafe(48))")
INTERNAL_AUTH_KEY=<FILL_IN>
# 初始化管理员密码 (生成: python -c "import secrets; print(secrets.token_urlsafe(24))")
SEED_ADMIN_PWD=<FILL_IN>
# 初始化运营账号密码 (生成: python -c "import secrets; print(secrets.token_urlsafe(24))")
SEED_RY_PWD=<FILL_IN>

# ==================== 微信公众号 JSAPI [可选] ====================
