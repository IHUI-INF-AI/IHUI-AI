# ==================== 告警通道 - monitor-ops [可选] ====================
# 钉钉群 webhook (监听器告警专用群, 格式: https://oapi.dingtalk.com/robot/send?access_token=XXXXXX)
ZHS_MONITOR_DINGTALK_WEBHOOK=<FILL_IN>
ZHS_MONITOR_DINGTALK_SECRET=<FILL_IN>
# 企业微信 (critical 告警用)
ZHS_MONITOR_CORP_ID=<FILL_IN>
ZHS_MONITOR_AGENT_ID=<FILL_IN>
ZHS_MONITOR_API_SECRET=<FILL_IN>
# @所有人 (true/false, 默认 true 让 oncall 收到)
ZHS_MONITOR_AT_ALL=true
# 告警抑制开关 (1=禁用, 0=启用, 默认 0)
ZHS_MONITOR_INHIBIT_ENABLED=0

# ==================== 通用告警通道 [可选] ====================
DINGTALK_WEBHOOK=<FILL_IN>
