COZE_PUBLIC_KEY_ID=<FILL_IN>
COZE_ACCOUNT_ID=<FILL_IN>
# 私钥需包含完整 PEM (含换行 \n)
COZE_PRIVATE_KEY=<FILL_IN>

# ==================== 微信支付 [必填-若启用支付] ====================
