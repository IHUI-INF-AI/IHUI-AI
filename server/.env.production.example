# ==================== SRS 流媒体 [可选] ====================
SRS_HOST=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_API_PORT=1985

# ==================== Token 定价 ====================
TOKEN_NORMAL_USER_PER_YUAN=20000
TOKEN_VIP_USER_PER_YUAN=20000
TOKEN_TRADER_USER_PER_YUAN=80000
TOKEN_PROMOTION_PER_YUAN=80000
TOKEN_BASE_MULTIPLIER=2.0

# ==================== 功能开关 ====================
FEATURE_AUTH_ENABLED=true
FEATURE_AGENTS_ENABLED=true
FEATURE_COZE_BOTS_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_AI_PROXIES_ENABLED=true
FEATURE_COURSES_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_CMS_ENABLED=true

# ==================== AI 业务 ====================
# 新用户首充礼包 ID (留空则不发放)
AI_FIRST_GIFT_ID=<FILL_IN>
AI_FIRST_GIFT_TOKENS=18888
AI_COMMISSION_DAY=7

# ==================== 股票分析 [可选] ====================
STOCK_ANALYSE_API_URL=<FILL_IN>
STOCK_ANALYSE_API_TOKEN=<FILL_IN>
STOCK_ANALYSE_PROJECT_ID=<FILL_IN>

# ==================== 性格分析 (n8n) [可选] ====================
PERSONALITY_N8N_URL=<FILL_IN>
PERSONALITY_N8N_TOKEN=<FILL_IN>

# ==================== 多租户 (默认关闭, 与原 MySQL 行为一致) ====================
MULTI_TENANT_ENABLED=false

# ==================== 日志配置 ====================
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 日志格式: text (人类可读) / json (Loki/Grafana 采集)
LOG_FORMAT=text
# 日志目录 (相对于项目根目录)
LOG_DIR=logs
# 日志文件轮转大小
LOG_ROTATION_SIZE=20 MB
# 日志保留天数
LOG_RETENTION_DAYS=14 days
# 是否启用日志脱敏 (password/token/phone 等)
LOG_MASK_ENABLED=true
# 是否桥接标准库 logging -> loguru (统一 uvicorn/gunicorn 等输出)
LOG_INTERCEPT_STDLIB=true

# ==================== 视频存储 ====================
VIDEO_ROOT=/data/videos

# ==================== 腾讯云直播 [可选-若启用直播] ====================
# 来源: 历史 ihui-ai-edu-live-service
TENCENT_LIVE_SECRET_ID=<FILL_IN>
TENCENT_LIVE_SECRET_KEY=<FILL_IN>
TENCENT_LIVE_ENDPOINT=live.ap-guangzhou.tencentcloudapi.com
TENCENT_LIVE_REGION=ap-guangzhou
TENCENT_LIVE_PUSH_DOMAIN=<FILL_IN>
TENCENT_LIVE_PULL_DOMAIN=<FILL_IN>
TENCENT_LIVE_CALLBACK_KEY=<FILL_IN>

# ==================== 腾讯云 COS 对象存储 [可选-若使用 COS] ====================
# 来源: 历史 ihui-ai-edu-oss-service
TENCENT_COS_SECRET_ID=<FILL_IN>
TENCENT_COS_SECRET_KEY=<FILL_IN>
