TENCENT_COS_REGION=<FILL_IN>
TENCENT_COS_VISIT_PATH=<FILL_IN>
TENCENT_COS_CDN_VISIT_PATH=<FILL_IN>

# ==================== OSS 文件存储模式 [必填-若启用文件上传] ====================
# 文件存储模式: Local / AliYun / Minio / TencentCOS
OSS_FILE_MODE=AliYun
OSS_FILE_ROOT_PATH=cloud-learning
OSS_VISIT_PATH=<FILL_IN>
# 2026-06-25 修复: 留空让代码用 tempfile.gettempdir() 跨平台默认目录
# 生产环境推荐: /var/lib/zhs/local_files (Linux) / D:\zhs\local_files (Windows Server)
# 注意: 不要再填 /tmp/filetmp, 否则在 Windows 上会创建到当前盘根 (G:\tmp\...)
LOCAL_FILE_DIR=<FILL_IN_OR_LEAVE_EMPTY>

# ==================== 通知邮件 [可选-若启用邮件通知] ====================
# 来源: 历史 ihui-ai-edu-notification-service
