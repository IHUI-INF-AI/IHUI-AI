# ====== ZHS Platform 生产环境配置模板 ======
# 用法:
#   cp .env.production.template .env.production
#   填写所有 <FILL_IN> 占位项 (标注 [必填] 的必须填写, 否则服务无法启动或功能不可用)
#   docker compose --env-file .env.production up -d
#
# 标记说明:
#   <FILL_IN> : 敏感值占位符, 部署前必须替换为真实值
#   [必填]     : 生产环境必须配置, 缺失会导致启动失败或核心功能不可用
#   [可选]     : 未启用对应功能时可留空
#
# 安全提醒:
#   - 本文件可纳入 git (仅含占位符); .env.production 已被 .gitignore 忽略, 切勿提交真实密钥
#   - 所有密钥/密码请通过 Docker env / K8s Secret 注入, 不要硬编码到镜像

# ==================== 环境配置 ====================
ENV=production

# ==================== 数据库 (PostgreSQL) [必填] ====================
# 生产环境必须使用 PostgreSQL, 禁止 SQLite fallback
# DB1: 主库 (AI 项目 / 中心库)
DB1_URL=postgresql+psycopg://<DB_USER>:<DB1_PASSWORD>@<DB_HOST>:5432/<DB1_NAME>
DB1_POOL_SIZE=50
DB1_MAX_OVERFLOW=200
DB1_POOL_RECYCLE=3600
DB1_PRE_PING=true
# DB2: 社区 / 用户库
DB2_URL=postgresql+psycopg://<DB_USER>:<DB2_PASSWORD>@<DB_HOST>:5432/<DB2_NAME>
DB2_POOL_SIZE=20
DB2_MAX_OVERFLOW=80
DB2_POOL_RECYCLE=3600
DB2_PRE_PING=true
# DB3: 日志库
DB3_URL=postgresql+psycopg://<DB_USER>:<DB3_PASSWORD>@<DB_HOST>:5432/<DB3_NAME>
DB3_POOL_SIZE=15
DB3_MAX_OVERFLOW=45
DB3_POOL_RECYCLE=3600
DB3_PRE_PING=true
# 生产环境禁止 SQLite fallback
DB_ALLOW_SQLITE_FALLBACK=false
DB_SQLITE_FALLBACK_FILENAME=

# ==================== Redis [必填] ====================
REDIS_HOST=<FILL_IN>
REDIS_PORT=6379
REDIS_PASSWORD=<FILL_IN>
REDIS_DB=0
REDIS_PREFIX=public_socket:

# ==================== 应用配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false
API_WORKERS=4
API_TITLE=ZHS Platform

# ==================== 安全配置 (JWT / Session / CORS) [必填] ====================
# JWT 密钥 - 生成命令: openssl rand -hex 32 (至少 32 字符)
JWT_SECRET_KEY=<FILL_IN>
JWT_EXPIRE_MINUTES=60
# Session 密钥 - 生成命令: openssl rand -hex 32
SESSION_SECRET_KEY=<FILL_IN>
# CORS 跨域 - 生产环境必须设置 (逗号分隔域名列表, 不允许通配符 *)
CORS_ORIGINS=<FILL_IN>

# ==================== AI Providers ====================
# 智谱 GLM [必填-若启用 AI 对话]
ZHIPU_API_KEY=<FILL_IN>
# 通义千问 / DashScope [可选]
DASHSCOPE_API_KEY=<FILL_IN>
# 豆包 (火山引擎) [可选]
DOUBAO_API_KEY=<FILL_IN>
DOUBAO_MODEL_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_JM_API_KEY=<FILL_IN>
DOUBAO_JM_SECRET_KEY=<FILL_IN>
# DeepSeek [可选]
DEEPSEEK_API_KEY=<FILL_IN>
# 可灵 (视频生成) [可选]
KLING_ACCESS_KEY=<FILL_IN>
KLING_SECRET_KEY=<FILL_IN>
KLING_ALT_ACCESS_KEY=<FILL_IN>
KLING_ALT_SECRET_KEY=<FILL_IN>
# OpenRouter [可选]
OPENROUTER_API_KEY=<FILL_IN>
# 其他模型供应商 [可选]
LUYALA_API_KEY=<FILL_IN>
TENCENT_SECRET_ID=<FILL_IN>
TENCENT_SECRET_KEY=<FILL_IN>
BAIDU_API_KEY=<FILL_IN>
SUNO_API_KEY=<FILL_IN>
SORA2_API_KEY=<FILL_IN>
GEMINI_API_KEY=<FILL_IN>
BAILIAN_APP_ID=<FILL_IN>

# ==================== Coze API [可选] ====================
COZE_API_BASE=https://api.coze.cn
COZE_COM_BASE_URL=https://api.coze.com
COZE_OAUTH_APP_ID=<FILL_IN>
COZE_OAUTH_APP_AUD=api.coze.cn
