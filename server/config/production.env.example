# P29-4 生产中间件适配层环境变量配置示例
#
# 用法:
#   cp config/production.env.example config/production.env
#   # 编辑 config/production.env 填入真实值
#   set -a && source config/production.env && set +a
#
# 适配层:
#   - app/security/vault_adapter.py
#   - app/services/clickhouse_adapter.py
#   - app/architecture/service_registry_adapter.py
#   - app/config/adapters.py

# ============================================================
# Vault 密钥管理
# ============================================================
# 启用真实 Vault (true 启用, false/空 使用内存模拟)
VAULT_ENABLED=true
USE_REAL_VAULT=true
# Vault 地址 (HTTP API)
VAULT_ADDR=http://127.0.0.1:8200
# Vault 认证 token (dev 模式默认 dev-root-token, 生产请用正式 token)
VAULT_TOKEN=dev-root-token

# ============================================================
# ClickHouse OLAP 数仓
# ============================================================
# 启用真实 ClickHouse (true 启用, false/空 使用内存模拟)
CLICKHOUSE_ENABLED=true
USE_REAL_CLICKHOUSE=true
# ClickHouse 主机
CLICKHOUSE_HOST=127.0.0.1
# ClickHouse Native 端口 (clickhouse-driver)
CLICKHOUSE_PORT=9000
# ClickHouse HTTP 端口 (初始化脚本使用)
CLICKHOUSE_HTTP_PORT=8123
# 目标数据库
CLICKHOUSE_DATABASE=zhs_analytics
# 用户名 / 密码
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ============================================================
# 服务注册中心 (memory / consul / etcd)
# ============================================================
# 后端类型: memory (内存模拟) / consul / etcd
SERVICE_REGISTRY_TYPE=consul
SERVICE_REGISTRY_BACKEND=consul
# Consul 地址 (HTTP API + UI)
CONSUL_ADDR=http://127.0.0.1:8500
# etcd 端点列表 (逗号分隔, 仅 SERVICE_REGISTRY_BACKEND=etcd 时使用)
ETCD_ADDR=http://127.0.0.1:2379
ETCD_ENDPOINTS=http://127.0.0.1:2379
