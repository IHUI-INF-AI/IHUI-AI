# P29-6 可观测性生产配置示例
# 复制为 .env (或 observability.env) 并按需修改
# 所有可观测性组件均支持 graceful degradation: 配置缺失或依赖未安装时不影响应用启动

# ============================================================
# Sentry 错误追踪
# ============================================================
# Sentry DSN (留空则不启用 Sentry)
SENTRY_DSN=
# 环境名 (dev/staging/production)
SENTRY_ENVIRONMENT=dev
# 事务采样率 0.0-1.0 (生产建议 0.1, 开发可设 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
# 性能分析采样率 0.0-1.0 (默认 0.0 关闭)
SENTRY_PROFILES_SAMPLE_RATE=0.0
# 是否启用 Sentry (留空时由 SENTRY_DSN 是否非空自动判定)
SENTRY_ENABLED=

# ============================================================
# OpenTelemetry 分布式追踪
# ============================================================
# OTLP collector 地址 (留空则不启用 OTel, 例: http://otel-collector:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=
# 导出协议: grpc / http_protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# 服务名 (用于资源标识)
OTEL_SERVICE_NAME=zhs-platform
# 资源属性 (key=value,key=value 格式)
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=dev
# 是否启用 OTel (留空时由 OTEL_EXPORTER_OTLP_ENDPOINT 是否非空自动判定)
OTEL_ENABLED=

# ============================================================
# Prometheus 指标导出
# ============================================================
# 是否启用 Prometheus 指标端点
PROMETHEUS_ENABLED=true
# 指标导出路径
PROMETHEUS_METRICS_PATH=/metrics

# ============================================================
# 日志配置
# ============================================================
# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# 日志格式: json (生产推荐) / text (开发友好)
LOG_FORMAT=json
