# ============================================================
# Oracle Cloud 生产环境配置模板 (Always Free ARM 实例自建 PG)
# ============================================================
# 使用方法:
# 1. 在 Oracle Cloud 创建 Always Free ARM 实例 (4 OCPU / 24GB RAM)
#    区域推荐: 日本东京 (ap-tokyo-1) 或 韩国首尔 (ap-seoul-1), 国内延迟 50-80ms
# 2. 用 deploy/oracle/docker-compose.yml 部署 PG + Redis
# 3. 复制本文件为 .env.production
# 4. 替换所有 CHANGE_ME 占位符为强密码/密钥
# 5. DB_KEEP_ALIVE_ENABLED=False (自建 PG 不休眠)

ENV=production

# --- Oracle Cloud 自建 PostgreSQL ---
# 同机部署 (FastAPI + PG 同一台 ARM 实例): 用 127.0.0.1
# 分机部署: 用 Oracle 实例的私有 IP (VCN 内网 10.x.x.x)
DB1_URL=postgresql+psycopg2://zhs:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/zhs_platform
DB2_URL=postgresql+psycopg2://zhs:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/zhs_platform
DB3_URL=postgresql+psycopg2://zhs:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/zhs_platform

# 生产连接池 (4 OCPU / 24GB RAM 可承载较大池)
DB1_POOL_SIZE=30
DB1_MAX_OVERFLOW=100
DB2_POOL_SIZE=15
DB2_MAX_OVERFLOW=50
DB3_POOL_SIZE=10
DB3_MAX_OVERFLOW=30

# 自建 PG 不休眠, 不需要保活
DB_KEEP_ALIVE_ENABLED=False

# --- Redis (同机 Docker 部署) ---
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379/0

# --- JWT (生产必须用强随机密钥, 至少 64 字符) ---
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_64_CHAR_RANDOM_HEX
SESSION_SECRET_KEY=CHANGE_ME_TO_64_CHAR_RANDOM_HEX

# --- 生产配置 ---
API_DEBUG=False
API_RELOAD=False
API_WORKERS=4

# --- CORS (替换为你的域名, 逗号分隔) ---
CORS_ORIGINS=https://your-domain.com

# --- 对象存储 (可选: 用 Oracle Object Storage 替代阿里云 OSS) ---
# Oracle Cloud Object Storage 兼容 S3 API, 免费层含 20GB
# 需要先在 Oracle 控制台创建 S3 兼容凭证 (Customer Secret Key)
OSS_ENDPOINT=https://objectstorage.ap-tokyo-1.oraclecloud.com
OSS_ACCESS_KEY_ID=YOUR_ORACLE_S3_ACCESS_KEY
OSS_ACCESS_KEY_SECRET=YOUR_ORACLE_S3_SECRET_KEY
OSS_BUCKET=your-bucket-name

# --- MinIO (可选: 同机 Docker 部署替代 OSS) ---
# MINIO_URL=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
# MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
# MINIO_BUCKET=zhs-platform

# --- 多租户 (生产默认关闭) ---
MULTI_TENANT_ENABLED=False
