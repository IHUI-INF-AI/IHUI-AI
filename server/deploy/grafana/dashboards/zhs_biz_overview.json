{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "zhs-platform 业务总览 — QPS / 错误率 / 延迟 / 用户活跃度 (基于 zhs_biz_* 指标)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "业务 QPS (按 endpoint, 5xx 用红)",
      "description": "zhs_biz_requests_total 按 endpoint 维度拆分, status=5xx 用红色.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(zhs_biz_requests_total{status!~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{endpoint}} 2xx",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "sum by (endpoint) (rate(zhs_biz_requests_total{status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{endpoint}} 5xx",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*5xx"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "业务延迟 P50 / P95 / P99 (秒)",
      "description": "zhs_biz_request_duration_seconds 直方图分位数.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(zhs_biz_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50 {{endpoint}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(zhs_biz_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{endpoint}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(zhs_biz_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99 {{endpoint}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}}
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "业务 QPS 按租户拆分 (建议 117, 含 anonymous)",
      "description": "zhs_biz_requests_total 按 tenant_id 维度拆分. 注意: anonymous 表示无租户上下文的流量.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant_id) (rate(zhs_biz_requests_total{status!~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{tenant_id}} 2xx",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "sum by (tenant_id) (rate(zhs_biz_requests_total{status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{tenant_id}} 5xx",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*5xx"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "业务异常速率 (每分钟)",
      "description": "zhs_biz_errors_total 按 error_type 求和.",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zhs_biz_errors_total[5m]))",
          "legendFormat": "errors/5m",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "总用户数 / 24h 活跃",
      "description": "zhs_biz_users_total / zhs_biz_users_active_24h.",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "max(zhs_biz_users_total)",
          "legendFormat": "Total",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "max(zhs_biz_users_active_24h)",
          "legendFormat": "24h Active",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "WS 活跃连接 / 通知订阅",
      "description": "zhs_biz_ws_connections / zhs_biz_ws_notice_subscriptions.",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "max(zhs_biz_ws_connections)",
          "legendFormat": "WS Conn",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "max(zhs_biz_ws_notice_subscriptions)",
          "legendFormat": "Notice Subs",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "支付金额累计 (元)",
      "description": "zhs_biz_payment_amount_yuan (按 channel/status 拆分).",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (channel) (zhs_biz_payment_amount_yuan{status=\"success\"})",
          "legendFormat": "{{channel}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "yuan"}},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Top 10 慢 SQL 表 (按 5m 内频次, 建议 89)",
      "description": "zhs_slow_sql_with_trace_total 5 分钟 increase 排序 Top 10. 含 trace_id 可定位到具体业务调用.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (engine, table) (increase(zhs_slow_sql_with_trace_total[5m])))",
          "legendFormat": "{{engine}}.{{table}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "legend": {"displayMode": "list", "placement": "right"},
        "tooltip": {"mode": "single"}
      },
      "links": [
        {
          "title": "Trace 探索 (Tempo/Jaeger)",
          "url": "${DS_TEMPO}/explore?orgId=1&left=${__url_time_range}&datasource=${DS_TEMPO}&queries[0].refId=service_traces&queries[0].query={service.name=\"${ZHS_SERVICE_NAME}\"}&queries[0].queryType=traceql",
          "targetBlank": true,
          "includeVars": false
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB 连接池 in_use vs size (建议 78)",
      "description": "zhs_db_pool_in_use vs zhs_db_pool_size, 按 engine 拆分. 持续 95% 触 ZHSDBPoolInUseHighSingle.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "zhs_db_pool_in_use",
          "legendFormat": "{{engine}} in_use",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "zhs_db_pool_size",
          "legendFormat": "{{engine}} size",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["zhs", "business", "overview"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      },
      {
        "name": "DS_TEMPO",
        "label": "Trace 后端 (Tempo/Jaeger)",
        "type": "datasource",
        "query": "tempo",
        "current": {"selected": false, "text": "Tempo", "value": "Tempo"},
        "hide": 0,
        "description": "建议 94: 慢 SQL panel 点击跳转至此数据源 explore 页"
      },
      {
        "name": "ZHS_SERVICE_NAME",
        "label": "服务名 (OTel)",
        "type": "textbox",
        "current": {"selected": false, "text": "zhs-platform", "value": "zhs-platform"},
        "options": [],
        "query": "zhs-platform",
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
