{
  "annotations": {"list": []},
  "description": "zhs-platform WebSocket 实时连接监控 — 活跃连接 / 通知推送速率 / 主题订阅 / 投递率",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "WS 活跃连接数 / 通知订阅数",
      "description": "zhs_biz_ws_connections / zhs_biz_ws_notice_subscriptions.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "zhs_biz_ws_connections",
          "legendFormat": "Connections",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "zhs_biz_ws_notice_subscriptions",
          "legendFormat": "Notice Subs",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "min"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "通知推送速率 (按 topic + scope)",
      "description": "zhs_biz_notice_pushed_total 按 topic / scope 维度拆分.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (topic) (rate(zhs_biz_notice_pushed_total{scope=\"topic\"}[$__rate_interval]))",
          "legendFormat": "topic.{{topic}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "sum by () (rate(zhs_biz_notice_pushed_total{scope=\"user\"}[$__rate_interval]))",
          "legendFormat": "user.*",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "通知投递速率 (按 topic)",
      "description": "zhs_biz_notice_delivered_total 每连接投递次数, 可推算人均.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (topic) (rate(zhs_biz_notice_delivered_total[$__rate_interval]))",
          "legendFormat": "{{topic}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "推送 / 投递比 (5min)",
      "description": "推送后被投递的倍率 (理想 ≈ 订阅者数).",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(zhs_biz_notice_delivered_total[5m])) / clamp_min(sum(rate(zhs_biz_notice_pushed_total{scope=\"topic\"}[5m])), 0.001)",
          "legendFormat": "fanout",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "WS 异常速率",
      "description": "zhs_biz_errors_total 中 endpoint 含 ws_* 的部分.",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_type) (rate(zhs_biz_errors_total{endpoint=~\"ws_.*\"}[$__rate_interval]))",
          "legendFormat": "{{error_type}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 30}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["zhs", "websocket", "realtime"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "zhs-platform / WebSocket 实时连接",
  "uid": "zhs-ws",
  "version": 1,
  "weekStart": ""
}
