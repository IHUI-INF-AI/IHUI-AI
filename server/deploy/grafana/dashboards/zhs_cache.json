{
  "annotations": {"list": []},
  "description": "zhs-platform 缓存监控 — 命中率 / 命中 vs 缺失速率 / 各 key_prefix 拆分",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "缓存命中率 (按 key_prefix)",
      "description": "zhs_biz_cache_hit_ratio gauge (0-1).",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "zhs_biz_cache_hit_ratio",
          "legendFormat": "{{key_prefix}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "命中 vs 缺失 QPS (按 key_prefix, 堆叠)",
      "description": "zhs_biz_cache_hits_total / zhs_biz_cache_misses_total 速率.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (key_prefix) (rate(zhs_biz_cache_hits_total[$__rate_interval]))",
          "legendFormat": "hit {{key_prefix}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "sum by (key_prefix) (rate(zhs_biz_cache_misses_total[$__rate_interval]))",
          "legendFormat": "miss {{key_prefix}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "miss .*"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "全局命中率 (avg)",
      "description": "所有 key_prefix 平均命中率.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "avg(zhs_biz_cache_hit_ratio)",
          "legendFormat": "avg hit ratio",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "green", "value": 0.9}
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "各 key_prefix 命中率排行",
      "description": "按命中率从高到低展示, 含累计命中/缺失.",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "zhs_biz_cache_hit_ratio",
          "format": "table",
          "instant": true,
          "legendFormat": "{{key_prefix}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "sum by (key_prefix) (zhs_biz_cache_hits_total)",
          "format": "table",
          "instant": true,
          "legendFormat": "hits",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "C",
          "expr": "sum by (key_prefix) (zhs_biz_cache_misses_total)",
          "format": "table",
          "instant": true,
          "legendFormat": "misses",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "transformations": [
        {"id": "merge", "options": {}}
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Value", "desc": true}]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["zhs", "cache", "redis"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
