{
  "annotations": {"list": []},
  "description": "zhs-platform PostgreSQL 监控 — 连接池 / 慢SQL / 数据库大小 / 事务 / 死锁 / exporter 原生指标",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PostgreSQL 实例状态",
      "description": "pg_up: 1=存活, 0=不可达.",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_up",
          "legendFormat": "pg_up",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "活跃连接数",
      "description": "pg_stat_activity_count: 当前活跃会话数.",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_stat_activity_count",
          "legendFormat": "active",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 100}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "最大连接数",
      "description": "pg_settings_max_connections: PostgreSQL 配置的最大连接数.",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_settings_max_connections",
          "legendFormat": "max",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "数据库大小 (总)",
      "description": "pg_database_size_bytes 求和, 人类可读.",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_database_size_bytes)",
          "legendFormat": "total",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10737418240},
              {"color": "red", "value": 53687091200}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "死锁累计",
      "description": "pg_stat_database_deadlocks 累计值.",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_database_deadlocks)",
          "legendFormat": "deadlocks",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "回滚累计",
      "description": "pg_stat_database_rollback 累计值.",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_database_rollback)",
          "legendFormat": "rollbacks",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 1000}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "应用 DB 连接池使用率 (按 engine)",
      "description": "zhs_db_pool_in_use / zhs_db_pool_size, 阈值 90%.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "zhs_db_pool_in_use / zhs_db_pool_size",
          "legendFormat": "{{engine}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          },
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "慢 SQL 速率 (带 trace)",
      "description": "zhs_slow_sql_with_trace_total 速率, 按 engine/table 拆分.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (engine, table) (rate(zhs_slow_sql_with_trace_total[$__rate_interval]))",
          "legendFormat": "{{engine}}.{{table}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "PostgreSQL 活跃连接数趋势",
      "description": "pg_stat_activity_count 按 state 拆分.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (state) (pg_stat_activity_count)",
          "legendFormat": "{{state}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "事务速率 (提交 + 回滚)",
      "description": "pg_stat_database_xact_commit / xact_rollback 速率.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit[$__rate_interval]))",
          "legendFormat": "commit {{datname}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback[$__rate_interval]))",
          "legendFormat": "rollback {{datname}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15}
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "rollback .*"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "数据库大小排行",
      "description": "pg_database_size_bytes 按库排序.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 22},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_database_size_bytes",
          "format": "table",
          "instant": true,
          "legendFormat": "{{datname}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Value", "desc": true}]
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Top 10 慢 SQL (按表)",
      "description": "近 5 分钟慢 SQL 累计, 按 engine/table 排序.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 22},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (engine, table) (increase(zhs_slow_sql_with_trace_total[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{engine}}.{{table}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Value", "desc": true}]
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "DB 连接池 overflow 趋势",
      "description": "zhs_db_pool_overflow, 超出 pool_size 的连接数.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "zhs_db_pool_overflow",
          "legendFormat": "{{engine}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          },
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "DB checkout 超时累计",
      "description": "increase(zhs_db_pool_checkout_timeouts_total[5m]), 业务可能雪崩指标.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 31},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "increase(zhs_db_pool_checkout_timeouts_total[5m])",
          "legendFormat": "{{engine}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "custom": {"drawStyle": "bars", "lineInterpolation": "linear", "fillOpacity": 50}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "缓存块命中率 (pg_stat_database_blks_hit)",
      "description": "blks_hit / (blks_hit + blks_read), 共享缓冲区命中率.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 39},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_blks_hit[$__rate_interval])) / (sum by (datname) (rate(pg_stat_database_blks_hit[$__rate_interval])) + sum by (datname) (rate(pg_stat_database_blks_read[$__rate_interval])))",
          "legendFormat": "{{datname}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.9},
              {"color": "green", "value": 0.99}
            ]
          },
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min"]},
        "tooltip": {"mode": "multi"}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["zhs", "postgresql", "database"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "zhs-platform / PostgreSQL 监控",
  "uid": "zhs-postgresql",
  "version": 1,
  "weekStart": ""
}
