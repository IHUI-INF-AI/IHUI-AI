  "description": "Phase 1-6 历史项目迁移 router 指标可视化 (coze_zhs_py + ZHS_Server_java + ai-smart-society-java)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Migrated Router 请求速率 (req/s, 按 router 分类)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (router) (rate(zhs_migrated_router_requests_total[5m]))",
          "legendFormat": "{{router}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Migrated Router P95 延迟 (秒)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (router, le) (rate(zhs_migrated_router_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{router}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "错误率 (5xx / total, 按 router)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (router) (rate(zhs_migrated_router_requests_total{status=~\"5..\"}[5m])) / sum by (router) (rate(zhs_migrated_router_requests_total[5m]))",
          "legendFormat": "{{router}} err%",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "LLM WebSocket 活跃连接数",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(zhs_migrated_websocket_connections{router=\"llm_ws\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 1000}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Timbre WS 活跃连接数",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(zhs_migrated_websocket_connections{router=\"timbre_generate\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 200},
              {"color": "red", "value": 500}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "WebSocket 消息速率 (msg/s, 按 router + direction)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (router, direction) (rate(zhs_migrated_websocket_messages_total[5m]))",
          "legendFormat": "{{router}} {{direction}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 7,
      "type": "table",
      "title": "Router 实时状态总览 (按 router)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (router) (rate(zhs_migrated_router_requests_total[5m]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (router) (rate(zhs_migrated_router_requests_total{status=~\"5..\"}[5m])) / sum by (router) (rate(zhs_migrated_router_requests_total[5m]))",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (router, le) (rate(zhs_migrated_router_request_duration_seconds_bucket[5m])))",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "options": {"showHeader": true}
    }
