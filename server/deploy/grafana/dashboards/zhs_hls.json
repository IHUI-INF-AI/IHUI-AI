{
  "annotations": {"list": []},
  "description": "zhs-platform 视频 HLS 转码监控 — 转码耗时分布 / 分片生成速率 / 转码结果 (success / cached / failed)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HLS 转码 P50 / P95 / P99 (秒)",
      "description": "zhs_biz_hls_transcode_seconds 直方图分位数.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(zhs_biz_hls_transcode_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zhs_biz_hls_transcode_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(zhs_biz_hls_transcode_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HLS 分片生成速率 (按码率)",
      "description": "zhs_biz_hls_segments_total 按 bitrate 维度拆分.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (bitrate) (rate(zhs_biz_hls_segments_total[$__rate_interval]))",
          "legendFormat": "{{bitrate}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HLS 转码结果分布 (success / cached / failed)",
      "description": "zhs_biz_hls_transcode_total 按 result 维度拆分, 堆叠面积.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(zhs_biz_hls_transcode_total[$__rate_interval]))",
          "legendFormat": "{{result}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "failed"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "success"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          },
          {
            "matcher": {"id": "byName", "options": "cached"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "转码失败率 (5min)",
      "description": "失败占比 = failed / (success+cached+failed).",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(zhs_biz_hls_transcode_total{result=\"failed\"}[5m])) / clamp_min(sum(rate(zhs_biz_hls_transcode_total[5m])), 0.001)",
          "legendFormat": "失败率",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.02},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HLS 转码耗时 Heatmap (P95)",
      "description": "用直方图分位数展示耗时热力.",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zhs_biz_hls_transcode_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "thresholds"}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["zhs", "hls", "video"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "zhs-platform / HLS 视频切片",
  "uid": "zhs-hls",
  "version": 1,
  "weekStart": ""
}
