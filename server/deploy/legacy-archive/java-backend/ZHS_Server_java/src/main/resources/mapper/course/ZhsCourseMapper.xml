        </trim>
    </insert>

    <update id="edit" parameterType="com.ai.manager.course.domain.ZhsCourse">
        update zhs_course
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="subtitle != null">subtitle = #{subtitle},</if>
            <if test="content != null">content = #{content},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="remarkFile != null">remark_file = #{remarkFile},</if>
            <if test="binding != null">binding = #{binding},</if>
            <if test="stage != null">stage = #{stage},</if>
            <if test="isHidden != null">is_hidden = #{isHidden},</if>
            <if test="isDel != null">is_del = #{isDel},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="creator != null">creator = #{creator},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updator != null">updator = #{updator},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
            <if test="label != null">label = #{label},</if>
            <if test="auditStatus != null">audit_status = #{auditStatus},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="delById" parameterType="String">
        delete from zhs_course where id = #{id}
    </delete>

    <delete id="delByIds">
        delete from zhs_course where
        creator = #{uuid}
        <foreach item="id" collection="ids" open="and id in (" separator="," close=")">
            #{id}
        </foreach>

    </delete>
    <update id="delByIds2">
        update zhs_course set audit_status = 1 where creator = #{uuid} and id in
       <foreach collection="ids" item="id" open="(" close=")" separator=",">
           #{id}
       </foreach>
    </update>
