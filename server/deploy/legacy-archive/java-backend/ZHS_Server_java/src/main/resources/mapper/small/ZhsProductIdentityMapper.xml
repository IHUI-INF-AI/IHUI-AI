<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.manager.small.mapper.ZhsProductIdentityMapper">
    
    <resultMap type="com.ai.manager.small.domain.ZhsProductIdentity" id="ZhsProductIdentityResult">
        <result property="id" column="id"/>
        <result property="amount" column="amount"/>
        <result property="beginTime" column="begin_time"/>
        <result property="endTime" column="end_time"/>
        <result property="defAmount" column="def_amount"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="creator" column="creator"/>
        <result property="createdTime" column="created_time"/>
        <result property="updator" column="updator"/>
        <result property="updatedTime" column="updated_time"/>
        <result property="remark" column="remark"/>
        <result property="expireAt" column="expire_at"/>

        <result property="labelPic" column="label_pic"/>
        <result property="giveToken" column="give_token"/>
        <result property="detail" column="detail"/>
    </resultMap>

    <sql id="selectZhsProductIdentityVo">
        select id, amount, begin_time, end_time, def_amount, status, creator, created_time, updator, updated_time, remark, expire_at, label_pic, give_token, type, detail from zhs_product_identity
    </sql>

    <select id="selectZhsProductIdentityList" parameterType="com.ai.manager.small.domain.ZhsProductIdentity" resultMap="ZhsProductIdentityResult">
        <include refid="selectZhsProductIdentityVo"/>
        <where>  
            <if test="beginTime != null "> and begin_time = #{beginTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
            <if test="creator != null  and creator != ''"> and creator = #{creator}</if>
        </where>
    </select>
    
    <select id="selectZhsProductIdentityById" parameterType="String" resultMap="ZhsProductIdentityResult">
        <include refid="selectZhsProductIdentityVo"/>
        where id = #{id}
    </select>
    <select id="getDeveloperPrice" resultType="com.ai.manager.small.domain.ZhsProductIdentity">
        select * from zhs_product_identity where `type` = 2 order by created_time
    </select>
    <select id="getConsecutivelyProduct" resultMap="ZhsProductIdentityResult" >
        <include refid="selectZhsProductIdentityVo"/>
        <where>
            (type = 3 or type = 4)
        </where>
            order by created_time desc
    </select>

    <insert id="insertZhsProductIdentity" parameterType="com.ai.manager.small.domain.ZhsProductIdentity">
        insert into zhs_product_identity
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="amount != null">amount,</if>
            <if test="beginTime != null">begin_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="defAmount != null">def_amount,</if>
            <if test="status != null">`status`,</if>
            <if test="creator != null">creator,</if>
            <if test="createdTime != null">created_time,</if>
            <if test="updator != null">updator,</if>
            <if test="updatedTime != null">updated_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="amount != null">#{amount},</if>
            <if test="beginTime != null">#{beginTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="defAmount != null">#{defAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="creator != null">#{creator},</if>
            <if test="createdTime != null">#{createdTime},</if>
            <if test="updator != null">#{updator},</if>
            <if test="updatedTime != null">#{updatedTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateZhsProductIdentity" parameterType="com.ai.manager.small.domain.ZhsProductIdentity">
        update zhs_product_identity
        <trim prefix="SET" suffixOverrides=",">
            <if test="amount != null">amount = #{amount},</if>
            <if test="beginTime != null">begin_time = #{beginTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="defAmount != null">def_amount = #{defAmount},</if>
            <if test="status != null">`status` = #{status},</if>
            <if test="creator != null">creator = #{creator},</if>
            <if test="createdTime != null">created_time = #{createdTime},</if>
            <if test="updator != null">updator = #{updator},</if>
            <if test="updatedTime != null">updated_time = #{updatedTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteZhsProductIdentityById" parameterType="String">
        delete from zhs_product_identity where id = #{id}
    </delete>

    <delete id="deleteZhsProductIdentityByIds" parameterType="String">
        delete from zhs_product_identity where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>