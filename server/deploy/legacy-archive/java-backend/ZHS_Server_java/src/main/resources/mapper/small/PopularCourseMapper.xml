<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.manager.small.mapper.PopularCourseMapper">

    <!-- PopularCourse 实体类的 resultMap -->
    <resultMap id="PopularCourseMap" type="com.ai.manager.small.domain.PopularCourse">
        <id property="id" column="id"/>
        <result property="cover" column="cover"/>
        <result property="url" column="url"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
    </resultMap>

    <!-- TODO: 在这里定义 PopularCourseMapper 接口中方法的 SQL 实现 -->

    <select id="selectAll" resultMap="PopularCourseMap">
        SELECT * FROM zhs_popular_courses
        <!-- TODO: 根据需要添加 WHERE 或 ORDER BY 子句 -->
    </select>

    <!-- 合并后的通用查询方法 -->
    <select id="selectCoursesByCriteria" resultMap="PopularCourseMap" parameterType="com.ai.manager.small.domain.dto.PopularCourseCriteria">
        SELECT *
        FROM zhs_popular_courses
        <where>
            <if test="type != null">
                type = #{type}
            </if>
            <!-- Add more conditions here if needed based on PHP logic -->
            <!-- For example, if there were filters for keywords, date range, etc. -->
        </where>
        <if test="orderBy != null">
            ORDER BY ${orderBy}
            <if test="orderDirection != null">
                ${orderDirection}
            </if>
        </if>
        <if test="limit != null">
            LIMIT
                #{limit}
        </if>
    </select>
    <select id="selectByType" resultType="com.ai.manager.small.domain.PopularCourse">
        SELECT * FROM zhs_popular_courses
        <if test="timeOrVisitors==0">
            where `type` = #{type} order by `time` desc
        </if>
        <if test="timeOrVisitors!=0">
            order by `NumberOfVisitors` desc
        </if>
        LIMIT #{limit}
    </select>

