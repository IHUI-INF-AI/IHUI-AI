<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.manager.small.mapper.ProductMapper">

    <!-- Product 实体类的 resultMap -->
    <resultMap id="ProductMap" type="com.ai.manager.small.domain.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="token" column="token"/>
        <result property="type" column="type"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="denomination" column="denomination"/>
        <result property="denominationVip" column="denomination_vip"/>
        <result property="denominationOperate" column="denomination_operate"/>
        <!-- Add other product fields if needed -->
    </resultMap>

    <!-- TODO: 在这里定义 ProductMapper 接口中方法的 SQL 实现 -->

    <!-- 根据类型查询商品列表 (Service 层调用) -->
    <select id="selectByType" resultMap="ProductMap">
        SELECT *
        FROM zhs_product
        WHERE type = #{type}
    </select>

    <!-- Removed SQL for methods not used by ResourceService -->
    
    <select id="selectById" resultMap="ProductMap">
        SELECT *
        FROM zhs_product
        WHERE id = #{id}
    </select>

    <!-- TODO: Add SQL for selectAll, insert, update, delete if needed based on PHP -->

</mapper> 