<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.manager.course.mapper.ZhsUserCommentLogMapper">
    
    <resultMap type="com.ai.manager.course.domain.ZhsUserCommentLog" id="ZhsUserCommentLogResult">
        <result property="id"    column="id"    />
        <result property="userUuid"    column="user_uuid"    />
        <result property="commentId"    column="comment_id"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectZhsUserCommentLogVo">
        select id, user_uuid, comment_id, created_at
    </sql>
    <sql id="fromZhsUserCommentLogTable">
        from zhs_user_comment_log
    </sql>

    <select id="getList" parameterType="com.ai.manager.course.domain.ZhsUserCommentLog" resultMap="ZhsUserCommentLogResult">
        <include refid="selectZhsUserCommentLogVo"/>
        <include refid="fromZhsUserCommentLogTable"/>
        <where>
            <if test="userUuid != null  and userUuid != ''"> and user_uuid = #{userUuid}</if>
            <if test="commentId != null  and commentId != ''"> and comment_id = #{commentId}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
        </where>
    </select>
    
    <select id="getById" parameterType="Integer" resultMap="ZhsUserCommentLogResult">
        <include refid="selectZhsUserCommentLogVo"/>
        <include refid="fromZhsUserCommentLogTable"/>
        where id = #{id}
    </select>

    <insert id="addZhsUserCommentLog" parameterType="com.ai.manager.course.domain.ZhsUserCommentLog" useGeneratedKeys="true" keyProperty="id">
        insert into zhs_user_comment_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userUuid != null">user_uuid,</if>
            <if test="commentId != null">comment_id,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userUuid != null">#{userUuid},</if>
            <if test="commentId != null">#{commentId},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="edit" parameterType="com.ai.manager.course.domain.ZhsUserCommentLog">
        update zhs_user_comment_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="userUuid != null">user_uuid = #{userUuid},</if>
            <if test="commentId != null">comment_id = #{commentId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="delById" parameterType="Integer">
        delete from zhs_user_comment_log where id = #{id}
    </delete>

    <delete id="delByIds" parameterType="String">
        delete from zhs_user_comment_log where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>