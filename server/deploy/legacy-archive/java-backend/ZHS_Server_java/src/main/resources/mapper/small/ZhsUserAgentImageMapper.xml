    </insert>

    <update id="edit" parameterType="com.ai.manager.small.domain.ZhsUserAgentImage">
        update zhs_user_agent_image
        <trim prefix="SET" suffixOverrides=",">
            <if test="userUuid != null and userUuid != ''">user_uuid = #{userUuid},</if>
            <if test="imageId != null  and imageId != ''">image_id = #{imageId},</if>
            <if test="imagePath != null">image_path = #{imagePath},</if>
            <if test="imageName != null">image_name = #{imageName},</if>
            <if test="type != null">type = #{type},</if>
            <if test="platform != null">platform = #{platform},</if>
            <if test="modelName != null">model_name = #{modelName},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="delById" parameterType="Long">
        delete from zhs_user_agent_image where id = #{id}
    </delete>

    <delete id="delByIds" parameterType="String">
        delete from zhs_user_agent_image where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>