    <update id="updateUserThirdPartyAccounts" parameterType="com.ai.manager.app.domain.UserThirdPartyAccounts">
        update user_third_party_accounts
        <trim prefix="SET" suffixOverrides=",">
            <if test="platform != null and platform != ''">platform = #{platform},</if>
            <if test="openId != null and openId != ''">open_id = #{openId},</if>
            <if test="platformName != null">platform_name = #{platformName},</if>
            <if test="accessToken != null">access_token = #{accessToken},</if>
            <if test="refreshToken != null">refresh_token = #{refreshToken},</if>
            <if test="expiresAt != null">expires_at = #{expiresAt},</if>
            <if test="refreshExpiresAt != null">refresh_expires_at = #{refreshExpiresAt},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="bindTime != null">bind_time = #{bindTime},</if>
            <if test="card != null">card = #{card},</if>
        </trim>
        <where>
            <if test="id != null">
                and id = #{id}
            </if>
            <if test="userUuid != null and userUuid != ''">
                and user_uuid = #{userUuid}
            </if>
        </where>
    </update>

    <delete id="deleteUserThirdPartyAccountsById" parameterType="Long">
        delete from user_third_party_accounts where id = #{id}
    </delete>

    <delete id="deleteUserThirdPartyAccountsByIds" parameterType="String">
        DELETE u, tpa, m, ai, uv  FROM users u
        LEFT JOIN user_third_party_accounts tpa ON tpa.user_uuid = u.uuid
        LEFT JOIN user_margin m ON m.user_uuid = u.uuid
        LEFT JOIN user_auth_info ai ON ai.user_uuid = u.uuid
        LEFT JOIN user_vip uv ON uv.user_uuid = u.uuid
        WHERE tpa.id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <delete id="delAuth">
        DELETE FROM user_third_party_accounts where user_uuid = #{uuid} and platform = #{platform}
    </delete>
</mapper>