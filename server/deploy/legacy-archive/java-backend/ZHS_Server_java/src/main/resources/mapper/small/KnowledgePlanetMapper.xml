    <!-- 合并后的通用查询方法 -->
    <select id="selectPlanetsByCriteria" resultMap="KnowledgePlanetMap" parameterType="com.ai.manager.small.domain.dto.KnowledgePlanetCriteria">
        SELECT
        <choose>
            <when test="selectIdAndTitleOnly == true">
                id, title
            </when>
            <otherwise>
                *
            </otherwise>
        </choose>
        FROM zhs_knowledge_planet
        <where>
            <if test="type != null">
                type = #{type}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <!-- Add more conditions here if needed based on PHP logic -->
        </where>
        <if test="orderBy != null">
            ORDER BY ${orderBy}
            <if test="orderDirection != null">
                ${orderDirection}
            </if>
        </if>
        <if test="limit != null">
            LIMIT
            #{limit}
        </if>
    </select>

    <!-- Insert method (addSharePlanetPublicBatch 调用) -->
    <insert id="insert" parameterType="com.ai.manager.small.domain.KnowledgePlanet" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO zhs_knowledge_planet (img, title, time, classification, type, created_at, updated_at, businesses, businessesImage, status, likes, NumberOfVisitors)
        VALUES (#{img}, #{title}, #{time}, #{classification}, #{type}, #{createdAt}, #{updatedAt}, #{businesses}, #{businessesImage}, #{status}, #{likes}, #{numberOfVisitors})
    </insert>

