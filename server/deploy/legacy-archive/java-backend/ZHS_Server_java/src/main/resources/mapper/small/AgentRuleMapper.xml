    </resultMap>
    <resultMap type="com.ai.manager.small.domain.ZhsAgentCategory" id="ZhsAgentCategoryResult">
        <result property="id" column="zac_id"/>
        <result property="agentId" column="zac_agent_id"/>
        <result property="agentName" column="zac_agent_name"/>
        <result property="createUuid" column="zac_create_uuid"/>
        <result property="createName" column="zac_create_name"/>
        <result property="createTime" column="zac_create_time"/>
        <result property="agentMainCategory" column="zac_agent_main_category"/>
        <result property="agentCategory" column="zac_agent_category"/>
        <result property="type" column="zac_type"/>
        <result property="account" column="zac_account"/>
        <result property="group" column="zac_group"/>
        <result property="limitFree" column="zac_limit_free"/>
        <result property="discountMonth" column="zac_discount_month"/>
        <result property="prologue" column="zac_prologue"/>
        <result property="typeChild" column="zac_type_child"/>
    </resultMap>

    <sql id="selectAgentRuleVo">
        select r.`id`, r.`title`, r.`remark`, r.`type`, r.`field1`, r.`is_hidden`, r.`creator`, r.`created_at`
    </sql>
    <sql id="fromAgentRuleTable">
        from agent_rule r
    </sql>

    <select id="getList" parameterType="com.ai.manager.small.domain.AgentRule" resultMap="AgentRuleResult">
        <include refid="selectAgentRuleVo"/>
        , rp.`id` rp_id, rp.`rule_id` rp_rule_id, rp.`context` rp_context, rp.`param_name` rp_param_name, rp.`type` rp_type, rp.`sortord` rp_sortord, rp.`is_use` rp_is_use, rp.`remark` rp_remark, rp.`creator` rp_creator, rp.`created_at` rp_created_at
        <include refid="fromAgentRuleTable"/>
        left join agent_rule_param rp on r.id = rp.rule_id
        <where>
            <if test="title != null  and title != ''"> and r.title = #{title}</if>
            <if test="type != null "> and r.type = #{type}</if>
        </where>
    </select>
    
    <select id="getById" parameterType="Long" resultMap="AgentRuleResult">
        <include refid="selectAgentRuleVo"/>
        , rp.`id` rp_id, rp.`rule_id` rp_rule_id, rp.`context` rp_context, rp.`param_name` rp_param_name, rp.`type` rp_type, rp.`sortord` rp_sortord, rp.`is_use` rp_is_use, rp.`remark` rp_remark, rp.`creator` rp_creator, rp.`created_at` rp_created_at
        <include refid="fromAgentRuleTable"/>
        left join agent_rule_param rp on r.id = rp.rule_id
        where r.id = #{id}
    </select>
    <select id="getAgentListByRuleId" resultMap="AgentsResult" >
        select a.*,
        a.user_name user_nickname,
        (select u.avatar from zhs_center_project.users u where u.uuid = a.connector_user_id) user_avatar
        ,zac.id AS zac_id,
        zac.agent_id AS zac_agent_id,
        zac.agent_name AS zac_agent_name,
        zac.create_uuid AS zac_create_uuid,
        zac.create_name AS zac_create_name,
        zac.create_time AS zac_create_time,
        zac.agent_main_category AS zac_agent_main_category,
        zac.agent_category AS zac_agent_category,
        zac.type AS zac_type,
        zac.account AS zac_account,
        zac.`group` AS zac_group,
        zac.limit_free AS zac_limit_free,
        zac.discount_month AS zac_discount_month,
        zac.prologue AS zac_prologue,
        zac.type_child AS zac_type_child
        ,IF(EXISTS(select 1 from zhs_agent_collect c where a.bot_id = c.bot_id AND c.uuid = #{uuid}), 1,0)  is_collect
        ,IF(EXISTS(select 1 from zhs_agent_thumbs t where a.bot_id = t.bot_id AND t.uuid = #{uuid}), 1,0)  is_thumbs

        from agents a
        left join zhs_agent_category zac on a.agent_id = zac.agent_id

        <where>
            a.publish_status = 'published'
            <if test="paramList != null">
                <foreach collection="paramList" item="param" separator=" or " open=" and (" close=")">
                    <if test="param.isUse == 0">
                        (a.${param.paramName} LIKE CONCAT('%', #{param.context},'%'))
                    </if>
                </foreach>
            </if>
            <if test="agentCategory != null and agentCategory != ''">
                and zac.agent_category like CONCAT('%', #{agentCategory},'%')
            </if>
            <if test="agentMainCategory != null and agentMainCategory != ''">
                and zac.agent_main_category like CONCAT('%', #{agentMainCategory},'%')
            </if>
        </where>
        <if test="orderList != null">
            <foreach collection="orderList" item="ord" open="order by" separator=",">
                a.${ord.paramName}
                <if test="ord.sortord == 1"> desc </if>
            </foreach>
        </if>

    </select>

    <insert id="addAgentRule" parameterType="com.ai.manager.small.domain.AgentRule" useGeneratedKeys="true" keyProperty="id">
        insert into agent_rule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="remark != null">remark,</if>
            <if test="type != null">type,</if>
            <if test="field1 != null">field1,</if>
            <if test="isHidden != null">is_hidden,</if>
            <if test="creator != null">creator,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="remark != null">#{remark},</if>
            <if test="type != null">#{type},</if>
            <if test="field1 != null">#{field1},</if>
            <if test="isHidden != null">#{isHidden},</if>
            <if test="creator != null">#{creator},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="edit" parameterType="com.ai.manager.small.domain.AgentRule">
        update agent_rule
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="type != null">type = #{type},</if>
            <if test="field1 != null">field1 = #{field1},</if>
            <if test="isHidden != null">is_hidden = #{isHidden},</if>
            <if test="creator != null">creator = #{creator},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="delById" parameterType="Long">
        delete from agent_rule where id = #{id}
    </delete>

    <delete id="delByIds" parameterType="String">
        delete from agent_rule where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="getListByLink" parameterType="com.ai.manager.small.domain.AgentRule" resultMap="AgentRuleResult">
        <include refid="selectAgentRuleVo"/>
        , rp.`id` rp_id, rp.`rule_id` rp_rule_id, rp.`context` rp_context, rp.`param_name` rp_param_name, rp.`type` rp_type, rp.`sortord` rp_sortord, rp.`is_use` rp_is_use, rp.`remark` rp_remark, rp.`creator` rp_creator, rp.`created_at` rp_created_at
        from agent_rule r
        <!-- left join agent_rule_link arl on r.id = arl.rule_id -->
        left join agent_rule_param rp on r.id = rp.rule_id
        <where>
            <if test="title != null  and title != ''"> and r.title = #{title}</if>
            <if test="type != null "> and r.type = #{type}</if>
        </where>
        <!-- group by r.id -->
    </select>
    
    <resultMap type="com.ai.manager.small.domain.AgentRule" id="AgentRuleWithLinkResult">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="remark" column="remark"/>
        <result property="type" column="type"/>
        <result property="field1" column="field1"/>
        <result property="isHidden" column="is_hidden"/>
        <result property="creator" column="creator"/>
        <result property="createdAt" column="created_at"/>
        <collection property="ruleLinks" ofType="com.ai.manager.small.domain.AgentRuleLink">
            <result property="agentId" column="arl_agent_id"/>
            <result property="ruleId" column="arl_rule_id"/>
        </collection>
    </resultMap>
    
    <select id="getRuleByIdWithLink" parameterType="Long" resultMap="AgentRuleWithLinkResult">
        <include refid="selectAgentRuleVo"/>
        from agent_rule r
        <!-- left join agent_rule_link arl on r.id = arl.rule_id -->
        where r.id = #{id}
    </select>
    
    <select id="getAgentsByLink" resultMap="AgentsResult">
        select a.*,
        a.user_name user_nickname,
        (select u.avatar from zhs_center_project.users u where u.`uuid` = a.connector_user_id) user_avatar
        ,zac.id AS zac_id,
        zac.agent_id AS zac_agent_id,
        zac.agent_name AS zac_agent_name,
        zac.create_uuid AS zac_create_uuid,
        zac.create_name AS zac_create_name,
        zac.create_time AS zac_create_time,
        zac.agent_main_category AS zac_agent_main_category,
        zac.agent_category AS zac_agent_category,
        zac.type AS zac_type,
        zac.account AS zac_account,
        zac.`group` AS zac_group,
        zac.limit_free AS zac_limit_free,
        zac.discount_month AS zac_discount_month,
        zac.prologue AS zac_prologue,
        zac.type_child AS zac_type_child
        ,IF(EXISTS(select 1 from zhs_agent_collect c where a.bot_id = c.bot_id AND c.uuid = #{uuid}), 1,0)  is_collect
        ,IF(EXISTS(select 1 from zhs_agent_thumbs t where a.bot_id = t.bot_id AND t.uuid = #{uuid}), 1,0)  is_thumbs

        from agents a
        left join zhs_agent_category zac on a.agent_id = zac.agent_id
        left join agent_rule_link arl on a.agent_id = arl.agent_id

        <where>
            a.publish_status = 'published'
            <if test="ruleId != null">
                and arl.rule_id = #{ruleId}
            </if>
            <if test="agentCategory != null and agentCategory != ''">
                and zac.agent_category like CONCAT('%', #{agentCategory},'%')
            </if>
            <if test="agentMainCategory != null and agentMainCategory != ''">
                and zac.agent_main_category like CONCAT('%', #{agentMainCategory},'%')
            </if>
        </where>
    </select>
    <select id="useHistory" resultMap="AgentsResult">
        select a.* from agents a left join zhs_agent_useDetail uac on a.agent_id = uac.bot_id where uac.uuid = #{userUuid} order by uac.last_time desc limit #{useHistory}
    </select>
</mapper>