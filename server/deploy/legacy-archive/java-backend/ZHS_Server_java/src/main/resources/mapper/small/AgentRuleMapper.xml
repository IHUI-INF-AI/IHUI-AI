        <result property="suggestedQuestions" column="suggested_questions"/>

        <association property="agentBuy" resultMap="ZhsAgentBuyResult"/>
        <association property="categoryList" resultMap="ZhsAgentCategoryResult"/>
    </resultMap>
    <resultMap type="com.ai.manager.small.domain.ZhsAgentBuy" id="ZhsAgentBuyResult">
        <result property="id" column="ab_id"/>
        <result property="agentId" column="ab_agent_id"/>
        <result property="agentName" column="ab_agent_name"/>
        <result property="agentOrderUuid" column="ab_agent_order_uuid"/>
        <result property="bugUuid" column="ab_bug_uuid"/>
        <result property="bugName" column="ab_bug_name"/>
        <result property="bugTime" column="ab_bug_time"/>
