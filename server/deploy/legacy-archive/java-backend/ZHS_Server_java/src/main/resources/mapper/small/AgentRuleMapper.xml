        <result property="agentPrompt" column="agent_prompt"/>
        <result property="agentModel" column="agent_model"/>
        <result property="agentTemperature" column="agent_temperature"/>
        <result property="agentMaxTokens" column="agent_max_tokens"/>
        <result property="agentVariables" column="agent_variables"/>
        <result property="publishStatus" column="publish_status"/>
        <result property="publishChannel" column="publish_channel"/>
