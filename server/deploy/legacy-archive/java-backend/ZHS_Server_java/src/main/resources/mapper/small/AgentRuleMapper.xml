        <result property="realPrice" column="ab_real_price"/>
        <result property="price" column="ab_price"/>
        <result property="count" column="ab_count"/>
        <result property="expirationDate" column="ab_expiration_date"/>
        <result property="status" column="ab_status"/>
        <result property="orderNo" column="ab_order_no"/>
        <result property="settlement" column="ab_settlement"/>
