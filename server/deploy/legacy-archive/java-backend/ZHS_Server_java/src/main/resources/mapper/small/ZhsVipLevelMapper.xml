<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.manager.small.mapper.ZhsVipLevelMapper">
    
    <resultMap type="com.ai.manager.small.domain.ZhsVipLevel" id="ZhsVipLevelResult">
        <result property="id"    column="id"    />
        <result property="title"    column="title"    />
        <result property="level"    column="level"    />
        <result property="remark"    column="remark"    />
        <result property="progress"    column="progress"    />
        <result property="model1"    column="model1"    />
        <result property="model2"    column="model2"    />
        <result property="creator"    column="creator"    />
        <result property="createdTime"    column="created_time"    />
        <result property="updator"    column="updator"    />
        <result property="updatedTime"    column="updated_time"    />
    </resultMap>

    <sql id="selectZhsVipLevelVo">
        select id, title, level, remark, progress, model1, model2, creator, created_time, updator, updated_time from zhs_vip_level
    </sql>

    <select id="selectZhsVipLevelList" parameterType="com.ai.manager.small.domain.ZhsVipLevel" resultMap="ZhsVipLevelResult">
        <include refid="selectZhsVipLevelVo"/>
        <where>  
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="level != null "> and `level` = #{level}</if>
            <if test="progress != null  and progress != ''"> and progress = #{progress}</if>
            <if test="model1 != null  and model1 != ''"> and model1 = #{model1}</if>
        </where>
        order by `level` desc
    </select>
    
    <select id="selectZhsVipLevelById" parameterType="String" resultMap="ZhsVipLevelResult">
        <include refid="selectZhsVipLevelVo"/>
        where id = #{id}
    </select>
