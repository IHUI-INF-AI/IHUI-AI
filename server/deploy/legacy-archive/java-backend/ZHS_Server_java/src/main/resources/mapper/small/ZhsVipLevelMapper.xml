        <result property="progress"    column="progress"    />
        <result property="creator"    column="creator"    />
        <result property="createdTime"    column="created_time"    />
        <result property="updator"    column="updator"    />
        <result property="updatedTime"    column="updated_time"    />
    </resultMap>
    <sql id="getUserVip">
        select `id`, `user_id`, `open_id`, `vip_id`, `progress`, `creator`, `created_time`, `updator`, `updated_time` from zhs_user_vip
    </sql>
    <select id="getUserProgeress" resultMap="userVipBean">
        <include refid="getUserVip"/>
        <where>
            <if test="openId != null">AND open_id = #{openId}</if>
        </where>
    </select>

    <insert id="insertZhsVipLevel" parameterType="com.ai.manager.small.domain.ZhsVipLevel">
        insert into zhs_vip_level
