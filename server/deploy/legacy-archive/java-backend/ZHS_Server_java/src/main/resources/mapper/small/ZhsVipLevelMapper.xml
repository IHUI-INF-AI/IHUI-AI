            <if test="id != null">id,</if>
            <if test="title != null">title,</if>
            <if test="level != null">`level`,</if>
            <if test="remark != null">remark,</if>
            <if test="progress != null">progress,</if>
            <if test="model1 != null">model1,</if>
            <if test="model2 != null">model2,</if>
            <if test="creator != null">creator,</if>
            <if test="createdTime != null">created_time,</if>
            <if test="updator != null">updator,</if>
            <if test="updatedTime != null">updated_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="title != null">#{title},</if>
            <if test="level != null">#{level},</if>
            <if test="remark != null">#{remark},</if>
            <if test="progress != null">#{progress},</if>
            <if test="model1 != null">#{model1},</if>
            <if test="model2 != null">#{model2},</if>
            <if test="creator != null">#{creator},</if>
            <if test="createdTime != null">#{createdTime},</if>
            <if test="updator != null">#{updator},</if>
            <if test="updatedTime != null">#{updatedTime},</if>
         </trim>
    </insert>

    <update id="updateZhsVipLevel" parameterType="com.ai.manager.small.domain.ZhsVipLevel">
        update zhs_vip_level
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="level != null">`level` = #{level},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="model1 != null">model1 = #{model1},</if>
            <if test="model2 != null">model2 = #{model2},</if>
            <if test="creator != null">creator = #{creator},</if>
            <if test="createdTime != null">created_time = #{createdTime},</if>
            <if test="updator != null">updator = #{updator},</if>
            <if test="updatedTime != null">updated_time = #{updatedTime},</if>
        </trim>
        where id = #{id}
    </update>
    <update id="editUserVIP">
        update zhs_user_vip
        <trim prefix="SET" suffixOverrides=",">
            <if test="vipId != null">vip_id = #{vipId},</if>
            <if test="progress != null">`progress` = #{progress},</if>
            <if test="updator != null">updator = #{openId},</if>
        </trim>
        where open_id = #{openId}
    </update>

    <delete id="deleteZhsVipLevelById" parameterType="String">
        delete from zhs_vip_level where id = #{id}
    </delete>

    <delete id="deleteZhsVipLevelByIds" parameterType="String">
        delete from zhs_vip_level where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
