    </select>
    <select id="getTraderTeam2" resultMap="TraderTeamResult">
        select
            oNum.uuid,
            oNum.order_num,
            c.commission,
            t.transaction_volume
        from
        (
            <!-- 求成交单数orderNum -->
            SELECT
                o.open_id uuid,
                COUNT(1) order_num
            FROM
                zhs_order o
            WHERE
                o.open_id IN
                (
                <foreach collection="uuids" item="uuid" separator=",">
                    #{uuid}
                </foreach>
                )
                AND o.`status` = 3
                <if test="beginTime != null">
                    AND o.`paid_at` <![CDATA[<=]]> #{beginTime}
                </if>
                <if test="endTime != null">
                    AND u.`paid_at` <![CDATA[>=]]> #{endTime}
                </if>
            group by
                o.open_id
        ) oNum
        left join (
            <!-- 求佣金总数commission -->
            SELECT
                f.belongers_open_id uuid,
                SUM(f.amount) commission
            FROM
                zhs_commission_flow f
                LEFT JOIN zhs_order o ON f.order_id = o.id
            WHERE
                f.belongers_open_id IN
                (
                <foreach collection="uuids" item="uuid" separator=",">
                    #{uuid}
                </foreach>
                )
                AND o.`status` = 3
                <if test="beginTime != null">
                    AND o.`paid_at` <![CDATA[<=]]> #{beginTime}
                </if>
                <if test="endTime != null">
                    AND u.`paid_at` <![CDATA[>=]]> #{endTime}
                </if>
            group by
                f.belongers_open_id
        ) c on oNum.uuid = c.uuid
        left join (
            <!-- 求成交金额transactionVolume -->
            SELECT
                o.open_id uuid,
                SUM(o.amount) transaction_volume
            FROM
                zhs_order o
            WHERE
                o.open_id IN
                (
                <foreach collection="uuids" item="uuid" separator=",">
                    #{uuid}
                </foreach>
                )
                and o.`status` = 3
                <if test="beginTime != null">
                    AND o.`paid_at` <![CDATA[<=]]> #{beginTime}
                </if>
                <if test="endTime != null">
                    AND u.`paid_at` <![CDATA[>=]]> #{endTime}
                </if>
            group by
                o.open_id
        ) t  on oNum.uuid = t.uuid


    </select>
</mapper>