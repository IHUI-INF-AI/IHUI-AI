            <if test="avatar != null  and avatar != ''"> and avatar = #{avatar}</if>
            <!--<if test="card != null  and card != ''"> and card = #{card}</if>-->
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="inviteCode != null  and inviteCode != ''"> and invite_code = #{inviteCode}</if>
            <if test="parentId != null  and parentId != ''"> and parent_id = #{parentId}</if>
            <if test="balance != null "> and balance = #{balance}</if>
            <if test="totalEarnings != null "> and total_earnings = #{totalEarnings}</if>
            <if test="isVIP != null "> and is_VIP = #{isVIP}</if>
            <if test="identityTypy != null "> and identity_typy = #{identityTypy}</if>
            <if test="tokenQuantity != null "> and token_quantity = #{tokenQuantity}</if>
            <if test="tokenFree != null "> and token_free = #{tokenFree}</if>
        </where>
    </select>
    <select id="getParentUser" resultMap="UserMap">
        SELECT
            *
        FROM
            zhs_user
        WHERE
            FIND_IN_SET(
                    id,
                    (
                        SELECT
                            CONCAT(parentU.id, ',', COALESCE(grandU.id, ''))
                        FROM
                            zhs_user thisU
                                INNER JOIN zhs_user parentU ON thisU.parent_id = parentU.invite_code
                                LEFT JOIN zhs_user grandU ON parentU.parent_id = grandU.invite_code
                        WHERE
                            thisU.open_id = #{openId}
                    )
                )
    </select>
    <!-- 更新用户完整信息 -->
    <update id="updateUser" parameterType="com.ai.manager.small.domain.User">
        UPDATE zhs_user
        <set>
            <if test="openId != null">open_id = #{openId},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <!--<if test="mobile != null">mobile = #{mobile},</if>-->
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="inviteCode != null">invite_code = #{inviteCode},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="totalEarnings != null">total_earnings = #{totalEarnings},</if>
            <if test="balance != null">balance = #{balance},</if>
            <if test="isVIP != null">is_vip = #{isVIP},</if>
            <if test="tokenQuantity != null">token_quantity = #{tokenQuantity},</if>
            <if test="identityTypy != null">identity_typy = #{identityTypy},</if>
            <if test="tokenFree != null">token_free = #{tokenFree},</if>
        </set>
        WHERE id = #{id}
    </update>
    <update id="updateStatus">
        UPDATE zhs_user set token_quantity = token_quantity + #{tokenQuantity}
        <if test="isVIP != null">
            , is_VIP = #{isVIP}
        </if>
        <if test="identityTypy != null">
            , identity_typy = #{identityTypy}
        </if>
        where open_id=#{openId}
    </update>
    <update id="setNumber">
        UPDATE zhs_user set phone = #{phone}, token_quantity = (select pi.def_amount from zhs_product_identity pi where pi.id = '20954cb5-7179-4985-b9d8-1d0b5c956005')
        <if test="isVIP != null">
            , is_VIP = if(is_VIP = 1, is_VIP, #{isVIP})
        </if>
        where open_id=#{openId}
    </update>
    <update id="editWxOpenId">
        update zhs_user set open_id = #{openId} where phone = #{phone}
    </update>
    <update id="updateParent">
        update zhs_user pu left join zhs_user u on pu.invite_code = u.parent_id
        set pu.token_quantity = pu.token_quantity +
                                if(
                                    pu.identity_typy = 1,
                                    #{crankUpProportion.traderGift},
                                    if(pu.is_VIP = 1, #{crankUpProportion.vipGift}, #{crankUpProportion.gift})
                                    )
        where u.open_id = #{openId}
    </update>
    <update id="firstShare">
        update zhs_center_project.user_margin set token_quantity = token_quantity + #{token} where user_uuid = #{uuid}
    </update>


    <select id="getChildUser" resultMap="UserMap">
        SELECT
