    <select id="getTraderTeam" resultMap="TraderTeamResult">
        SELECT
            u.`id`,
            u.`token` open_id,
            u.`nickname`,
            u.created_at,
            u.avatar,
            u.phone,
            v.id AS vip_id,
            v.title AS vip_name,
            (
                SELECT
                    SUM(o.amount)
                FROM
                    zhs_order o
                WHERE
                    o.open_id IN (select u.open_id UNION SELECT cu.open_id FROM zhs_user cu WHERE cu.parent_id = u.invite_code)
                    and o.`status` = 3
                    <if test="beginTime != null">
                        AND o.`paid_at` <![CDATA[<=]]> #{beginTime}
                    </if>
                    <if test="endTime != null">
                        AND u.`paid_at` <![CDATA[>=]]> #{endTime}
                    </if>
            ) AS transaction_volume
            ,(
                SELECT
                    SUM(f.amount)
                FROM
                    zhs_commission_flow f
                    LEFT JOIN zhs_order o ON f.order_id = o.id
                WHERE
                    f.belongers_open_id = u.token
                    AND o.`status` = 3
                    <if test="beginTime != null">
                        AND o.`paid_at` <![CDATA[<=]]> #{beginTime}
                    </if>
                    <if test="endTime != null">
                        AND u.`paid_at` <![CDATA[>=]]> #{endTime}
                    </if>
            ) AS commission
            ,(
                SELECT
                    COUNT(1)
                FROM
                    zhs_order o
                WHERE
                    o.open_id IN (select u.token UNION SELECT cu.token FROM zhs_user cu WHERE cu.parent_id = u.invite_code)
                    AND o.`status` = 3
                    <if test="beginTime != null">
                        AND o.`paid_at` <![CDATA[<=]]> #{beginTime}
                    </if>
                    <if test="endTime != null">
                        AND u.`paid_at` <![CDATA[>=]]> #{endTime}
                    </if>
            ) AS order_num,
            pu.nickname AS parent_name
<!--        u.`id`,
            u.`token`,
            u.`open_id`,
            u.`nickname`,
            u.`user_name`,
            u.`user_password`,
            u.`avatar`,
            u.`card`,
            u.`phone`,
            u.`invite_code`,
            u.`parent_id`,
            u.`balance`,
            u.`total_earnings`,
            u.`created_at`,
            u.`updated_at`,
            u.`is_VIP`,
            u.`is_vip_time`,
            u.`identity_typy`,
            u.`identity_typy_time`,
            u.`commission_ratio`,
            u.`token_quantity`,
            u.`token_free`,
            u.`app_id`,
            ()

            cu.`id` AS child_id,
            cu.`token` AS child_token,
            cu.`open_id` AS child_open_id,
            cu.`nickname` AS child_nickname,
            cu.`user_name` AS child_user_name,
            cu.`user_password` AS child_user_password,
            cu.`avatar` AS child_avatar,
            cu.`card` AS child_card,
            cu.`phone` AS child_phone,
            cu.`invite_code` AS child_invite_code,
            cu.`parent_id` AS child_parent_id,
            cu.`balance` AS child_balance,
            cu.`total_earnings` AS child_total_earnings,
            cu.`created_at` AS child_created_at,
            cu.`updated_at` AS child_updated_at,
            cu.`is_VIP` AS child_is_VIP,
            cu.`is_vip_time` AS child_is_vip_time,
            cu.`identity_typy` AS child_identity_typy,
            cu.`identity_typy_time` AS child_identity_typy_time,
            cu.`commission_ratio` AS child_commission_ratio,
            cu.`token_quantity` AS child_token_quantity,
            cu.`token_free` AS child_token_free,
            cu.`app_id` AS child_app_i-->
        FROM
            zhs_user u
            <!--LEFT JOIN zhs_user cu ON cu.parent_id = u.invite_code-->
            left join  zhs_user pu on pu.invite_code = u.parent_id
            <!-- 查询VIP等级 -->
            LEFT JOIN zhs_user_vip uv ON uv.open_id = u.token
            LEFT JOIN zhs_vip_level v ON v.id = uv.vip_id
        <where>
            <if test="token != null">
                AND pu.token = #{token}
            </if>
            <if test="search != null and search != ''">
                AND (u.nickname LIKE CONCAT('%',#{search},'%') or u.phone LIKE CONCAT(#{search},'%'))
            </if>
            <if test="beginTime != null">
                AND u.`created_at` <![CDATA[<=]]> #{beginTime}
            </if>
            <if test="endTime != null">
                AND u.`created_at` <![CDATA[>=]]> #{endTime}
            </if>
        </where>
        <choose>
            <when test="byOrderNum != null and byOrderNum == 1">
                ORDER BY order_num ASC
            </when>
            <when test="byOrderNum != null and byOrderNum == 2">
                ORDER BY order_num DESC
            </when>
        </choose>
    </select>
    <select id="getByPhone" resultMap="UserMap">
