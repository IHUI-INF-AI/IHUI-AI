<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.manager.small.mapper.UserMapper">

    <!-- zhs_user 实体类的 resultMap -->
    <resultMap id="UserMap" type="com.ai.manager.small.domain.User">
        <id property="id" column="id"/>
        <result property="openId" column="open_id"/>
        <result property="nickname" column="nickname"/>
        <result property="token" column="token"/>
<!--        <result property="mobile" column="mobile"/>-->
        <result property="userPassword" column="user_password"/>
        <result property="avatar" column="avatar"/>
        <result property="inviteCode" column="invite_code"/>
        <result property="parentId" column="parent_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="phone" column="phone"/>
        <result property="totalEarnings" column="total_earnings"/>
        <result property="balance" column="balance"/>
        <result property="isVIP" column="is_vip"/>
        <result property="tokenQuantity" column="token_quantity"/>
        <result property="identityTypy" column="identity_typy"/>
        <result property="tokenFree" column="token_free"/>
        <result property="userName" column="user_name"/>

        <result property="title" column="title"/>
        <result property="progress" column="progress"/>
        
        <association property="vipLevel" javaType="com.ai.manager.small.domain.ZhsVipLevel">
            <id property="id" column="vip_id"/>
            <result property="title" column="vip_title"/>
            <result property="level" column="vip_level"/>
            <result property="remark" column="vip_remark"/>
            <result property="progress" column="vip_progress"/>
            <result property="model1" column="vip_model1"/>
        </association>
<!--        <result property="superiorId" column="superior_id"/>-->
<!--        <result property="identityTypyStr" column="identity_typy_str"/>-->
    </resultMap>

    <!-- TODO: 在这里定义 zhs_userMapper 接口中方法的 SQL 实现 -->
    <!-- SQL based on methods used in ResourceService -->
    <sql id="selectZhsUserVo">
        select id, token, open_id, nickname, user_name, user_password, avatar, card, phone, invite_code, parent_id, balance, total_earnings, created_at, updated_at, is_VIP, identity_typy, commission_ratio, token_quantity, token_free
             ,IF(identity_typy=1, "操盘手", IF(identity_typy=9, "管理员", "用户")) identity_typy_str
        from zhs_user
    </sql>
    <delete id="delVisitor">
        delete from zhs_user where open_id = #{openId}
    </delete>
    <update id="cancelUser">
        update users u left join user_auth_info uai on u.uuid = uai.user_uuid set u.status = 3, uai.cancel_phone = uai.phone, uai.phone = null where u.uuid = #{uuid}
    </update>

    <!-- ResourceService -> getUserAgentFreeTimeInfo 调用 selectById -->
    <select id="selectById" resultMap="UserMap">
        SELECT id, open_id, is_vip, token_quantity, total_earnings, balance, invite_code, identity_typy, token_free
        FROM zhs_user
        WHERE id = #{userId}
    </select>

    <!-- ResourceService -> recharge 调用 selectOpenIdById -->
    <select id="selectOpenIdById" resultType="String">
        SELECT open_id
        FROM zhs_user
        WHERE id = #{userId}
    </select>

    <!-- ResourceService -> recharge 调用 selectIsVipByOpenId -->
    <select id="selectIsVipByOpenId" resultType="Integer">
        SELECT is_vip
        FROM zhs_user
        WHERE open_id = #{openId}
    </select>

    <!-- ResourceService -> getTokenCount 调用 selectTokenQuantityById -->
    <select id="selectTokenQuantityById" resultType="Integer">
        SELECT token_quantity + token_free
        FROM zhs_user
        WHERE id = #{userId}
    </select>

    <!-- ResourceService -> getTokenCount 调用 updateTokenQuantityById -->
    <update id="updateTokenQuantityById">
        UPDATE zhs_user
        SET token_quantity = #{tokenQuantity}, token_free = #{tokenFree}
        WHERE id = #{id}
    </update>

    <!-- 根据 open_id 查询用户 -->
    <select id="selectByOpenId" resultMap="UserMap">
        SELECT
            u.*
            , uv.progress
            , vl.id vip_id
            , vl.title vip_title
            , vl.level  vip_level
            , vl.remark vip_remark
            , vl.progress vip_progress
            , vl.model1 vip_model1
        FROM zhs_user u
            left join zhs_user_vip uv on uv.open_id = u.token
            left join zhs_vip_level vl on vl.id = uv.vip_id
        WHERE u.open_id = #{openId}
    </select>

    <!-- 插入用户并返回自增ID -->
    <insert id="insertUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO zhs_user (open_id, token, nickname, invite_code, parent_id, created_at, updated_at)
        VALUES (#{openId}, #{token}, #{nickname}, #{inviteCode}, #{parentId}, #{createdAt}, #{updatedAt})
    </insert>
    <insert id="addUserLevel" parameterType="com.ai.manager.small.domain.ZhsUserVip">
        INSERT INTO `zhs_user_vip`
            (`id`, `user_id`, `open_id`, `vip_id`, `progress`, `creator`)
        VALUES
            (#{id}, #{userId}, #{openId}, #{vipId}, #{progress}, #{creator});
    </insert>

    <!-- 根据 open_id 更新用户 -->
    <update id="updateByOpenId">
        UPDATE zhs_user
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE open_id = #{openId}
    </update>

    <!-- 根据 id 更新用户 card 字段 -->
     <update id="updateUserCard">
        UPDATE zhs_user
        SET card = #{card}, updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!-- DistributionService 调用 -->
    <!-- 根据 parent_id 查询用户，支持分页 -->
    <select id="selectByParentId" resultMap="UserMap">
        SELECT id, open_id, nickname, avatar, phone, created_at, total_earnings, is_VIP, identity_typy, token_free
        FROM zhs_user
        WHERE parent_id = #{parentId}
        ORDER BY created_at desc
        <if test="limit != null">
            LIMIT #{limit}
        </if>
        <if test="offset != null">
            OFFSET #{offset}
        </if>
    </select>

    <!-- 根据 parent_id 统计用户数量 -->
    <select id="countByParentId" resultType="long">
        SELECT COUNT(*) FROM zhs_user WHERE parent_id = #{parentId}
         <if test="createdAtGreaterThanEqual != null">
             AND created_at &gt;= #{createdAtGreaterThanEqual}
         </if>
    </select>

    <!-- 根据 parent_id 获取下级用户ID -->
    <select id="selectIdsByParentId" resultType="java.lang.Integer">
        SELECT id
        FROM zhs_user
        WHERE parent_id = #{parentId}
    </select>

    <!-- 根据用户ID列表查询用户 -->
    <select id="selectByIdIn" resultMap="UserMap">
        SELECT id, nickname
        FROM zhs_user
        WHERE id IN
        <foreach item="userId" collection="userIds" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </select>

