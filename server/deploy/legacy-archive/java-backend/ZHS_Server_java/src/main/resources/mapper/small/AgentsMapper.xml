            <if test="userIdStr != null  and userIdStr != ''"> and a.user_id_str = #{userIdStr}</if>
            <if test="userName != null  and userName != ''"> and a.user_name like concat('%', #{userName}, '%')</if>
            <if test="agentPrompt != null  and agentPrompt != ''"> and a.agent_prompt = #{agentPrompt}</if>
            <if test="agentModel != null  and agentModel != ''"> and a.agent_model = #{agentModel}</if>
            <if test="agentTemperature != null  and agentTemperature != ''"> and a.agent_temperature = #{agentTemperature}</if>
            <if test="agentMaxTokens != null "> and a.agent_max_tokens = #{agentMaxTokens}</if>
            <if test="agentVariables != null  and agentVariables != ''"> and a.agent_variables = #{agentVariables}</if>
            <if test="publishStatus != null  and publishStatus != ''"> and a.publish_status = #{publishStatus}</if>
            <if test="publishChannel != null  and publishChannel != ''"> and a.publish_channel = #{publishChannel}</if>
            <if test="publishTime != null "> and a.publish_time = #{publishTime}</if>
