        ,zac.agent_id AS zac_agent_id,
        zac.agent_main_category AS label_ids,
        zac.agent_category AS category_id
        <include refid="fromAgentsTable"/>
        left join zhs_agent_category zac on zac.agent_id = a.agent_id
        <where>
            <if test="agentName != null  and agentName != ''"> and a.agent_name like concat('%', #{agentName}, '%')</if>
            <if test="agentDescription != null  and agentDescription != ''"> and a.agent_description = #{agentDescription}</if>
            <if test="agentAvatar != null  and agentAvatar != ''"> and a.agent_avatar = #{agentAvatar}</if>
            <if test="agentVersion != null  and agentVersion != ''"> and a.agent_version = #{agentVersion}</if>
            <if test="botId != null  and botId != ''"> and a.bot_id = #{botId}</if>
            <if test="botIdStr != null  and botIdStr != ''"> and a.bot_id_str = #{botIdStr}</if>
            <if test="botName != null  and botName != ''"> and a.bot_name like concat('%', #{botName}, '%')</if>
            <if test="connectorId != null  and connectorId != ''"> and a.connector_id = #{connectorId}</if>
            <if test="connectorUserId != null  and connectorUserId != ''"> and a.connector_user_id = #{connectorUserId}</if>
