            <if test="type != null  and type != ''"> and a.type = #{type}</if>

            <if test="categoryId != null  and categoryId != ''"> and zac.agent_category = #{categoryId}</if>
            <if test="labelIds != null  and labelIds != ''">
                <foreach collection="labelIdList" item="labelId" open="and (" close=")" separator=" or ">
                    (zac.agent_main_category like concat('%', #{labelId}, '%'))
                </foreach>
            </if>
        </where>
        order by sort desc
    </select>

    <select id="getByAgentId" parameterType="String" resultMap="AgentsResult">
        <include refid="selectAgentsVo"/>
        <include refid="fromAgentsTable"/>
        where a.agent_id = #{agentId}
    </select>
    <select id="getAgentByCode" resultMap="AgentsResult" >
        <include refid="selectAgentsVo"/>
        <include refid="fromAgentsTable"/>
        left join zhs_agent_category cl on cl.agent_id = a.agent_id
        left join agent_category c on cl.agent_category = c.id
        <where>
            <if test="search != null  and search != ''"> and a.agent_name like concat('%', #{search}, '%')</if>
            <if test="code != null  and code != ''"> and c.code = #{code}</if>
        </where>
    </select>
    <select id="getAgentyCollect" resultMap="AgentsResult" >
        <include refid="selectAgentsVo"/>
        <include refid="fromAgentsTable"/>
        left join zhs_agent_collect ac on ac.bot_id = a.agent_id
        <where>
            <if test="search != null  and search != ''"> and a.agent_name like concat('%', #{search}, '%')</if>
            <if test="uuid != null  and uuid != ''"> and ac.uuid = #{uuid}</if>
        </where>
        order by a.sort asc
    </select>
    <select id="agentListsByPay" resultMap="AgentsResult">
        <include refid="selectAgentsVo"/>
        <include refid="fromAgentsTable"/>
        left join zhs_agent_buy ab on ab.agent_id = a.agent_id
        <where>
            <if test="search != null  and search != ''"> and a.agent_name like concat('%', #{search}, '%')</if>
            <if test="uuid != null  and uuid != ''"> and ab.bug_uuid = #{uuid}</if>
            <if test="type == 1"> and DATE_FORMAT(ab.expiration_date,'%Y-%m-%d') <![CDATA[<]]> DATE_FORMAT(NOW(),'%Y-%m-%d') </if>
            <if test="date != null and date != ''"> and DATE_FORMAT(ab.expiration_date,'%Y-%m-%d') <![CDATA[=]]> #{date} </if>
        </where>
        order by ab.bug_time desc
    </select>
    <select id="getLabel" resultType="java.lang.String">
        select a.agent_id from agents a left join zhs_agent_category zac on zac.agent_id = a.agent_id where agent_main_category like CONCAT('%',#{label},'%')
    </select>
