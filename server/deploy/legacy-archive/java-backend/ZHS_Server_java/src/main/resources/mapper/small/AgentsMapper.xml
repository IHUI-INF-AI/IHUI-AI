    <sql id="selectAgentsVo">
        select a.agent_id, a.agent_name, a.agent_description, a.agent_avatar, a.agent_version, a.bot_id, a.bot_id_str, a.bot_name, a.connector_id, a.connector_user_id, a.user_id, a.user_id_str, a.user_name, a.agent_prompt, a.agent_model, a.agent_temperature, a.agent_max_tokens, a.agent_variables, a.publish_status, a.publish_channel, a.publish_time, a.category, a.tags, a.is_public, a.access_level, a.usage_count, a.like_count, a.share_count, a.creator_id, a.creator_name, a.callback_data_1, a.callback_data_2, a.callback_data_3, a.created_at, a.updated_at, a.prologue, a.all_token, a.sort, a.coze_account_id, a.type
    </sql>
    <sql id="fromAgentsTable">
