            <if test="creatorName != null  and creatorName != ''"> and a.creator_name like concat('%', #{creatorName}, '%')</if>
            <if test="callbackData1 != null  and callbackData1 != ''"> and a.callback_data_1 = #{callbackData1}</if>
            <if test="callbackData2 != null  and callbackData2 != ''"> and a.callback_data_2 = #{callbackData2}</if>
