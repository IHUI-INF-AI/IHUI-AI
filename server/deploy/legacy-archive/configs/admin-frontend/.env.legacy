# OAuth2.1 配置（可选）
# 设置为 true 启用 OAuth2.1 标准端点，false 或未设置则使用旧版端点
VITE_USE_OAUTH21=true

# OAuth2.1 Token 端点（可选，默认 /oauth/token）
# VITE_OAUTH21_TOKEN_ENDPOINT=/oauth/token

# OAuth2.1 授权端点（可选，默认 /oauth/authorize）
# VITE_OAUTH21_AUTHORIZATION_ENDPOINT=/oauth/authorize

# OAuth2 配置（向后兼容，如果 OAuth2.1 不可用则使用）
# VITE_USE_OAUTH2=true
# VITE_OAUTH2_TOKEN_ENDPOINT=/oauth/token
