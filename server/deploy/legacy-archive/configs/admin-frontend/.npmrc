# pnpm 存储目录配置
# 统一使用项目主目录下的 pnpm-store
store-dir=H:\ihui-ai-officialsite-frontend\.pnpm-store

# 注册表配置
registry=https://registry.npmmirror.com
strict-ssl=false

# 性能优化
prefer-offline=true
progress=false
fetch-retries=3
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
timeout=300000

# pnpm 特定配置
shamefully-hoist=true
strict-peer-deps=false
legacy-peer-deps=false

# 禁用不必要的功能
audit=false
fund=false

