{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Phase 10 建议 4: 通过 incident_id 变量反向追溯所有关联 annotation / runbook / 工单 / 告警",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Runbook 索引", "url": "https://wiki.zhs.top/runbook/phase8", "type": "link" },
    { "title": "告警总览", "url": "/d/zhs-alerts-overview", "type": "link" }
  ],
  "panels": [
    {
      "type": "text",
      "title": "Incident 标题 + 摘要 (用 $incident_id 变量)",
      "id": 1,
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "content": "## Incident: $incident_id\n\n此面板根据 URL `?var-incident_id=INC-20260616-928A1F` 中的 incident_id 过滤所有 annotation / 告警 / 工单 / runbook。"
      }
    },
    {
      "type": "table",
      "title": "1. 关联 Annotations (按时间倒序)",
      "id": 2,
      "datasource": { "type": "grafana", "uid": "grafana" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "annotations",
          "datasource": { "type": "grafana", "uid": "grafana" },
          "queryType": "annotations",
          "dashboardUID": "zhs-monitor-health",
          "tags": "incident:${incident_id}"
        }
      ]
    },
    {
      "type": "table",
      "title": "2. 关联告警 (从 alertmanager 数据源查 alertname)",
      "id": 3,
      "datasource": { "type": "grafana", "uid": "alertmanager" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "alerts",
          "datasource": { "type": "alertmanager", "uid": "alertmanager" },
          "queryType": "alerts",
          "alertnameFilter": "{incident=\"${incident_id}\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "3. Flapping Score 趋势 (抑制工单评估指标)",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "flapping",
          "expr": "avg(alertmanager_alert_flapping_score{incident_id=\"$incident_id\"})",
          "legendFormat": "flapping"
        }
      ]
    },
    {
      "type": "logs",
      "title": "4. 演练日志 (按 incident_id 过滤)",
      "id": 5,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "options": { "showTime": true, "showLabels": false },
      "targets": [
        {
          "refId": "logs",
          "expr": "{app=\"zhs-platform\"} |= \"$incident_id\""
        }
      ]
    },
    {
      "type": "text",
      "title": "5. 关联跳转 (工单 / Runbook / Status Page)",
      "id": 6,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "options": {
        "content": "### 跳板链接\n\n- [新建工单](https://jira.zhs.top/browse/ZHS-$incident_id)\n- [Status Page](https://status.zhs.top/incidents/$incident_id)\n- [Runbook 索引](https://wiki.zhs.top/runbook/phase8)\n- [Grafana 主面板](/d/zhs-monitor-health)"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["phase10", "incident", "trace"],
  "templating": {
    "list": [
      {
        "name": "incident_id",
        "type": "textbox",
        "label": "Incident ID (例: INC-20260616-928A1F)",
        "description": "Phase 10 建议 4: 通过 URL `?var-incident_id=INC-XXX` 传入, 所有 panel 自动过滤",
        "current": { "value": "INC-20260616-928A1F", "text": "INC-20260616-928A1F" },
        "options": [{ "value": "INC-20260616-928A1F", "text": "INC-20260616-928A1F" }],
        "query": "",
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Phase 10 Incident Trace (incident_id 反向追溯)",
  "uid": "zhs-incident-trace",
  "version": 1,
  "weekStart": ""
}
