#!/usr/bin/env sh
# Pre-push 钩子：完整 TypeScript 类型检查 + 高特异性检测
# 防止有类型错误或样式问题的代码进入远端分支

set -e

echo "▶ Running vue-tsc type check (this may take a while)..."
npm run typecheck --silent

echo "▶ Running high specificity selector check..."
HIGH_SPECIFICITY_THRESHOLD=0 npm run check:high-specificity --silent
