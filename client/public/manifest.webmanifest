        { "src": "/images/logo.png", "sizes": "192x192" }
      ]
    }
  ],
  "categories": ["productivity", "education", "business", "utilities"],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "screenshots": [
    {
      "src": "/screenshots/home-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "首页 - 桌面端"
    },
    {
      "src": "/screenshots/agents-mobile.png",
