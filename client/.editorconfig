# EditorConfig配置文件
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,vue}]
indent_style = space
indent_size = 2

[*.json]
indent_style = tab
indent_size = 1

[defaultSettings.json]
# 忽略Cursor编辑器的全局配置文件
# 此文件应放在编辑器配置目录，不应在项目中检查


