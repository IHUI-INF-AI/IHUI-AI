{
  "name": "ihui-agi-inf-web",
  "version": "1.0.0",
  "description": "智汇AI社区 (iHui AI) - 专业的AI工具集成平台（Monorepo：官网 + 微信小程序）",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.vue",
    "src/main.ts"
  ],
  "scripts": {
    "dev": "chcp 65001 >NUL && vite --port 8888",
    "dev:backend": "cd ../server && python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload --env-file local_data/dev-config.ini",
    "dev:vize": "chcp 65001 >NUL && cross-env VITE_USE_VIZE=true vite --port 8888",
    "dev:web": "chcp 65001 >NUL && cross-env BUILD_PLATFORM=web vite --port 8888",
    "dev:h5": "chcp 65001 >NUL && cross-env BUILD_PLATFORM=h5 vite --port 8888",
    "dev:alipay": "chcp 65001 >NUL && cross-env BUILD_PLATFORM=alipay vite --port 8888",
    "dev:electron": "chcp 65001 >NUL && cross-env BUILD_PLATFORM=electron vite --port 8888",
    "build": "chcp 65001 >NUL && vite build && npm run generate:sitemap",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "build:typecheck": "chcp 65001 >NUL && vue-tsc && vite build",
    "build:vize": "chcp 65001 >NUL && cross-env-shell VITE_USE_VIZE=true \"vue-tsc && vite build\"",
    "build:web": "chcp 65001 >NUL && cross-env-shell BUILD_PLATFORM=web \"vue-tsc && vite build\"",
    "build:h5": "chcp 65001 >NUL && cross-env-shell BUILD_PLATFORM=h5 \"vue-tsc && vite build\"",
    "build:wx": "npm run build:mp-weixin",
    "build:alipay": "chcp 65001 >NUL && cross-env-shell BUILD_PLATFORM=alipay \"vue-tsc && vite build\"",
    "build:electron": "chcp 65001 >NUL && cross-env-shell BUILD_PLATFORM=electron \"vue-tsc && vite build\"",
    "electron:dev": "chcp 65001 >NUL && cross-env NODE_ENV=development electron electron/main.cjs",
    "electron:build": "chcp 65001 >NUL && npm run build:electron && electron-builder",
    "build:fast": "vite build --mode production",
    "preview": "vite preview --port 4173 --host 127.0.0.1 --outDir dist/web",
    "build:shared": "npm run build -w @aizhs/shared-api && npm run build -w @aizhs/shared-types && npm run build -w @aizhs/shared-auth && npm run build -w @aizhs/shared-services && node scripts/bundle-shared-api-for-miniapp.mjs",
    "dev:mp-weixin": "npm run build:shared && cd miniapp && npm run dev:mp-weixin",
    "build:mp-weixin": "npm run build:shared && cd miniapp && npm run build:mp-weixin",
    "miniapp:install": "cd miniapp && npm install",
    "build:all": "npm run build:shared && npm run build:web && npm run build:h5 && npm run build:alipay && npm run build:electron && npm run build:mp-weixin",
    "postinstall": "npm run build:shared",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "typecheck": "vue-tsc --noEmit",
    "vize:lint": "vize lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "check:i18n:keys": "tsx scripts/check-i18n-keys.ts",
    "i18n:sync": "node scripts/sync-i18n.cjs",
    "i18n:sync:dry": "node scripts/sync-i18n.cjs --dry-run",
    "check:no-important": "tsx scripts/check-no-important.ts",
    "check:high-specificity": "node scripts/check-high-specificity-staged.mjs --all",
    "check:high-specificity:fast": "node scripts/check-high-specificity-staged.mjs --all",
    "check:el-token": "node scripts/check-el-token-staged.mjs",
    "check:csp": "tsx scripts/check-csp.ts",
    "csp:hash": "tsx scripts/csp-hash.ts",
    "check:port-drift": "node scripts/check-port-drift.mjs",
    "check:outdated": "node scripts/check-outdated.mjs",
    "check:outdated:miniapp": "node scripts/check-outdated.mjs --miniapp",
    "check:outdated:strict": "node scripts/check-outdated.mjs --fail-on-major",
    "audit": "npm audit --registry=https://registry.npmjs.org/ --legacy-peer-deps",
    "audit:column-flex-buttons": "node scripts/debug/audit-column-flex-buttons.cjs",
    "check:line-endings": "node ../scripts/check-line-endings.mjs",
    "sync:csp": "tsx scripts/sync-csp.ts",
    "monitor:perf": "node scripts/performance-monitor.js",
    "optimize:fonts": "node scripts/optimize-fonts.js",
    "optimize:images": "node scripts/optimize-images.js",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --project=chromium --reporter=line",
    "e2e:report": "npx playwright show-report playwright-report",
    "pre-deploy": "node scripts/pre-deploy-check.js",
    "lighthouse": "lhci autorun",
    "prepare": "simple-git-hooks",
    "dev:events": "node ../scripts/dev-events.mjs",
    "dev:events:last": "node ../scripts/dev-events.mjs --last 50",
    "dev:events:web": "node ../scripts/dev-events-server.mjs",
    "dev:sync": "node packages/shared-logic/sync.js",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "clean": "node scripts/clean.mjs",
    "clean:dist": "rimraf dist dist-ssr .vite",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run check:no-important --silent && node scripts/check-nul.mjs && node scripts/check-markraw-staged.mjs && HIGH_SPECIFICITY_THRESHOLD=0 node scripts/check-high-specificity-staged.mjs && npm run check:i18n:keys --silent",
    "pre-push": "npm run typecheck --silent && HIGH_SPECIFICITY_THRESHOLD=0 npm run check:high-specificity --silent"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=-1"
    ],
    "*.{js,jsx}": [
      "eslint --fix --max-warnings=-1"
    ],
    "*.{vue}": [
      "eslint --fix --max-warnings=-1",
      "stylelint --fix"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ],
    "vite.config.ts": [
      "node scripts/check-port-drift.mjs"
    ],
    "playwright.config.ts": [
      "node scripts/check-port-drift.mjs"
    ],
    "config/ports.ts": [
      "node scripts/check-port-drift.mjs"
    ],
    "scripts/dev-up.ps1": [
      "node scripts/check-port-drift.mjs"
    ],
    "scripts/ci-env-setup.ps1": [
      "node scripts/check-port-drift.mjs"
    ],
    "../.github/workflows/*.yml": [
      "node scripts/check-port-drift.mjs"
    ],
    "../.github/workflows/*.yaml": [
      "node scripts/check-port-drift.mjs"
    ],
    "../scripts/dev-up.ps1": [
      "node scripts/check-port-drift.mjs"
    ],
    "../scripts/ci-env-setup.ps1": [
      "node scripts/check-port-drift.mjs"
    ]
  },
  "dependencies": {
    "@aizhs/shared-api": "1.0.0",
    "@aizhs/shared-services": "^1.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@vue-office/docx": "^1.6.3",
    "@vue-office/excel": "^1.7.14",
    "@vue-office/pptx": "^1.0.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "js-cookie": "^3.0.8",
    "jszip": "^3.10.1",
    "marked": "^17.0.6",
    "markstream-vue": "0.0.3-beta.4",
    "pdfjs-dist": "^5.7.284",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "quill": "2.0.2",
    "socket.io-client": "^4.8.3",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@storybook/builder-vite": "^10.4.6",
    "@storybook/vue3": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/crypto-js": "^4.2.2",
    "@types/js-cookie": "^3.0.6",
    "@types/jszip": "^3.4.1",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.0.18",
    "@vizejs/vite-plugin": "^0.9.0",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "canvas": "^3.2.3",
    "chromatic": "^11.0.0",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "element-plus": "^2.14.2",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^27.4.0",
    "less": "^4.6.6",
    "lint-staged": "^16.4.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "pizzip": "^3.2.0",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.4",
    "puppeteer": "^24.43.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "sass": "^1.101.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.6",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "subset-font": "^2.5.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.48.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^8.0.16",
    "vite-plus": "^0.2.1",
    "vitest": "^4.0.18",
    "vize": "^0.9.0",
    "vue-demi": "^0.14.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5",
    "web-vitals": "^5.3.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "rimraf": "^6.0.1",
    "@csstools/css-parser-algorithms": "^4.0.0",
    "@csstools/css-tokenizer": "^4.0.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.2"
  },
  "keywords": [
    "AI",
    "人工智能",
    "工具平台",
    "Vue3",
    "TypeScript"
  ],
  "author": "智汇AI集团，吉林省爱智汇人工智能科技有限公司",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
