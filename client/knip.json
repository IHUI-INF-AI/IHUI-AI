{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.ts"
  ],
  "project": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.vue",
    "config/**/*.ts"
  ],
  "ignore": [
    "src/**/__tests__/*",
    "src/open-platform/**",
    "src/shared/**",
    "packages/**",
    "scripts/**",
    "e2e/**",
    ".storybook/**"
  ],
  "ignoreBinaries": [
    "chcp",
    "python",
    "lhci",
    "rimraf"
  ],
  "ignoreDependencies": [
    "@aizhs/shared-logic",
    "@vue/reactivity"
  ]
}
