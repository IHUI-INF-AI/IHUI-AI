{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "project": [
        "src/**/*.{ts,js,vue}",
        "!src/main.ts",
        "config/**/*.ts"
      ]
    }
  },
  "ignore": [
    "src/**/__tests__/*",
    "src/open-platform/**",
    "packages/**",
    "scripts/**",
    "e2e/**",
    ".storybook/**"
  ],
  "ignoreBinaries": [
    "chcp",
    "python",
    "lhci",
    "rimraf"
  ],
  "ignoreDependencies": [
    "@aizhs/shared-logic"
  ]
}
