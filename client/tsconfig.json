{
  "include": [
    "env.d.ts",
    "src/auto-imports.d.ts",
    "src/components.d.ts",
    "src/shims-vue.d.ts",
    "src/vue-shim.d.ts",
    "src/vue-module.d.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.vue",
    "src/**/*.d.ts",
    "src/**/*.json",
    "*.ts",
    "*.js",
    "config/**/*.ts"
  ],
  "exclude": [
    "src/api/admin/**",
    "src/store/admin/**",
    "src/utils/admin/**",
    "src/views/admin-ruoyi/**",
    "src/layout-admin/**",
    "src/plugins/admin/**",
    "src/components/admin-ruoyi/**",
    "src/**/__tests__/*",
    "**/defaultSettings.json",
    "defaultSettings.json",
    "fix-*.js",
    "playwright.config.ts",
    "playwright.visual.config.ts",
    "src/components/FontTest.vue",
    "src/components/common/ClusterHealth.vue",
    "src/components/VolumeControl.vue",
    "src/components/login/CountryCodeSelector.vue",
    "src/components/ui/ComponentShowcase.vue",
    "src/open-platform/components/document/DocumentViewer.vue",
    "src/shared/document/DocumentEditorToolbar.vue",
    "src/shared/document/ExcelEditor.vue",
    "src/shared/document/MonacoEditor.vue",
    "src/shared/document/MultiTableEditor.vue",
    "src/shared/document/PDFViewer.vue",
    "src/shared/document/PPTEditor.vue",
    "src/shared/document/WordEditor.vue",
    "src/views/ComponentsLibrary.vue",
    "src/views/migrated/**",
    "scripts/news-crawler/**",
    "src/open-platform/views/FeatureCenter.vue",
    "src/utils/guides/**",
    "packages/shared-logic/**"
  ],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@aizhs/shared-api": ["./packages/shared-api/src/index.ts"],
      "@aizhs/shared-auth": ["./packages/shared-auth/src/index.ts"],
      "@aizhs/shared-services": ["./packages/shared-services/src/index.ts"],
      "@aizhs/shared-types": ["./packages/shared-types/src/index.ts"],
      "@aizhs/shared-logic": ["./packages/shared-logic/src/index.ts"],
      "@/*": ["./src/*"],
      "lucide-vue-next": ["./src/lib/lucide-fallback.ts"],
      "open/*": ["./src/open-platform/*"],
      "~projects/*": ["./projects/*"]
    },
    "types": ["vite/client", "node"],
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": false,
    "forceConsistentCasingInFileNames": false,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": false,
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "useDefineForClassFields": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true
  }
}
