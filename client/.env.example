# ========================================
# 环境变量配置模板
# ========================================
# 复制此文件为 .env.local 并填写实际值
# .env.local 不会被提交到 Git

# ========================================
# API 配置
# ========================================
VITE_API_BASE_URL=/api
VITE_APP_TITLE=智汇AGI社区
VITE_APP_VERSION=1.0.0

# Java 后端 API (2026-06-20 全部迁移完成, 无 Java 依赖)
# 所有路由均已迁移到 Python 后端:
#   statistics/developer/openclaw/socket.io/prod-api/ai -> Python 后端
#   /prod-api, /system, /message, /dev-api -> Python 后端 (RuoYi 核心 API 完整迁移)
#   /api/code -> Python 后端 (auth_middleware 映射到 /api/v1/auth/captcha)
# 此变量仅作为历史兼容保留, 生产环境可留空
VITE_JAVA_API_BASE_URL=https://your-api-domain.com

# Python 后端 API
VITE_PYTHON_API_BASE_URL=https://your-python-api.com

# 登录 API
VITE_LOGIN_API_BASE_URL=https://your-api-domain.com/ai

# 上传 URL
VITE_UPLOAD_URL=https://your-api-domain.com/upload

# WebSocket
VITE_WS_URL=wss://your-api-domain.com/ws
VITE_WS_BASE_URL=wss://your-api-domain.com

# ========================================
# 安全配置 - 敏感信息
# ========================================
# 加密密钥 - 请修改为您的实际密钥
VITE_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# ========================================
# OAuth2 认证配置 - 敏感信息
# ========================================
VITE_OAUTH2_CLIENT_ID=admin
VITE_OAUTH2_CLIENT_SECRET=YOUR_OAUTH2_CLIENT_SECRET
VITE_OAUTH2_TOKEN_URL=https://your-api-domain.com/auth/oauth/token
VITE_OAUTH2_GRANT_TYPE=password

# ========================================
# 第三方登录配置 - 敏感信息
# ========================================

# 微信配置
VITE_WECHAT_APP_ID=YOUR_WECHAT_APP_ID
VITE_WECHAT_APP_SECRET=YOUR_WECHAT_APP_SECRET
VITE_WECHAT_PC_REDIRECT_URI=https://your-domain.com/prod-api/ai/login/wechat/pc/wxCode

# 华为配置
VITE_HUAWEI_CLIENT_ID=YOUR_HUAWEI_CLIENT_ID
VITE_HUAWEI_REDIRECT_URI=https://your-domain.com/huawei/callback

# 企业微信配置（加密存储）
VITE_WORKWECHAT_ENABLED=true
VITE_WORKWECHAT_APP_ID_ENCRYPTED=YOUR_ENCRYPTED_APP_ID
VITE_WORKWECHAT_AGENT_ID_ENCRYPTED=YOUR_ENCRYPTED_AGENT_ID
VITE_WORKWECHAT_SECRET_ENCRYPTED=YOUR_ENCRYPTED_SECRET
VITE_WORKWECHAT_REDIRECT_URI=https://your-domain.com/workwechat/callback
VITE_WORKWECHAT_SCOPE=snsapi_login

# Google 配置
VITE_GOOGLE_ENABLED=true
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
VITE_GOOGLE_REDIRECT_URI=https://your-domain.com/prod-api/ai/login/google/pc/wxCode
VITE_GOOGLE_SCOPE=openid email profile

# ========================================
# Coze API 配置
# ========================================
VITE_COZE_API_TOKEN=YOUR_COZE_API_TOKEN
VITE_COZE_WORKFLOW_ID=YOUR_WORKFLOW_ID

# ========================================
# 管理员配置
# ========================================
VITE_ADMIN_OVERRIDE=false

# ========================================
# 应用模式配置
# ========================================
VITE_APP_DEMO_MODE=false
VITE_DEMO_MODE=false
VITE_ENABLE_MOCK=false
VITE_LOG_LEVEL=error
VITE_ENABLE_UTM=false

# 学员档案模块 mock 切换 (2026-07-03)
# true (默认): 使用前端 mock 数据 (notes/offline-records/uploaded-certs/uploaded-papers/ai-report/stats)
# false: 调用真实后端 API (/edu/* 路由)
# 后端就绪后在 .env.local 设置 VITE_USE_EDU_MOCK=false 即可切换
VITE_USE_EDU_MOCK=true

# ========================================
# 国际化配置
# ========================================
VITE_ENABLE_LOCALES_SYNC=true

# ========================================
# CDN 配置
# ========================================
VITE_CDN_ENABLED=false
VITE_CDN_BASE_URL=https://cdn.your-domain.com

# 主项目 URL
VITE_MAIN_PROJECT_URL=https://your-domain.com

# ========================================
# E2E 测试配置
# ========================================
VITE_APP_E2E=false

# ========================================
# 调试配置
# ========================================
VITE_DEBUG_VISIBILITY=false

# ========================================
# 监控配置
# ========================================
VITE_ENABLE_MONITOR=true
VITE_MONITOR_REPORT_URL=/api/monitor/collect
VITE_SENTRY_DSN=
VITE_ERROR_TRACKER_ENV=production
VITE_ERROR_TRACKER_SAMPLE_RATE=1.0
VITE_WEB_VITALS_ALERT_URL=/api/rum
VITE_WEB_VITALS_ALERT_EMAIL=
VITE_MONITORING_WS_URL=wss://your-api-domain.com/ws/monitoring
VITE_CSP_REPORT_URI=/api/csp-report
