# ========================================
# IHUI-AI 生产环境配置模板
# ========================================
# 来源: 整合 H:\历史项目存档 中所有子项目的 .env.production
# 创建日期: 2026-06-25
# 部署前请复制为 .env.production 并填入实际敏感值
#
# 历史域名映射（已验证可访问，2026-06-25）:
#   kou.aizhs.top     - 前端主入口（客服/工单/分享）
#   bsm.aizhs.top     - 后台管理 API（/prod-api 前缀，已迁移到 Python 后端）
#   zca.aizhs.top     - 智能体 API + Coze WebSocket
# ========================================

# ========================================
# 应用基本信息
# ========================================
VITE_APP_TITLE=智汇AGI社区
VITE_APP_VERSION=1.0.0
ENV=production

# ========================================
# 后端 API 基础地址
# ========================================
# 历史 Base URL 1 (kou.aizhs.top) - 客服/工单/分享/前端
VITE_API_BASE_URL=https://kou.aizhs.top

# 历史 Base URL 2 (bsm.aizhs.top/prod-api/ai) - 后台管理 API
# 2026-06-20 已迁移到 Python 后端 (Vite proxy 重写到 /api/v1/*)
# 此变量保留用于前端兼容
VITE_LOGIN_API_BASE_URL=https://bsm.aizhs.top/prod-api/ai

# 历史 Base URL 3 (zca.aizhs.top) - 智能体 / Coze WebSocket
# WebSocket 端点: wss://zca.aizhs.top/cozeZhsApi
VITE_PYTHON_API_BASE_URL=https://zca.aizhs.top

# 历史 Base URL 4 (bsm.aizhs.top/prod-api) - 后台 RuoYi 兼容
# 2026-06-20 已迁移到 Python 后端 (app/api/mock 实现 /prod-api/* 镜像)
VITE_ADMIN_API_BASE=/prod-api
VITE_BASE_API=/prod-api
VITE_APP_BASE_API=/prod-api

# 教育平台 API/SSO (P18 联调: vite.config.ts /api/edu 代理 target)
VITE_EDU_API_BASE=https://edu-api.aizhs.top
VITE_EDU_SSO_BASE=https://edu-sso.aizhs.top

# ========================================
# 文件上传
# ========================================
# 历史: FILE_UPLOAD_URL = https://bsm.aizhs.top/prod-api/file/upload
VITE_UPLOAD_URL=https://bsm.aizhs.top/prod-api/file/upload

# ========================================
# WebSocket
# ========================================
# 历史 Coze WebSocket: wss://zca.aizhs.top/cozeZhsApi
VITE_WS_URL=wss://zca.aizhs.top/cozeZhsApi/ws
VITE_WS_BASE_URL=wss://zca.aizhs.top
VITE_COZE_WS_URL=wss://zca.aizhs.top/cozeZhsApi

# 监控 WebSocket
VITE_MONITORING_WS_URL=wss://zca.aizhs.top/ws/monitoring

# ========================================
# 主项目 URL（用于 OAuth 回调、跨域跳转）
# ========================================
VITE_MAIN_PROJECT_URL=https://kou.aizhs.top
VITE_WEB_URL=https://kou.aizhs.top
VITE_MAIN_APP_URL=https://kou.aizhs.top

# ========================================
# 安全 / 加密配置
# ========================================
VITE_ENCRYPTION_KEY=replace-with-32-char-random-key

# ========================================
# OAuth2 / OAuth2.1 认证
# ========================================
VITE_OAUTH2_CLIENT_ID=admin
VITE_OAUTH2_CLIENT_SECRET=replace-with-oauth2-secret
VITE_OAUTH2_TOKEN_URL=https://bsm.aizhs.top/prod-api/auth/oauth/token
VITE_OAUTH2_GRANT_TYPE=password

# OAuth2.1 扩展（历史 admin-frontend 迁移）
VITE_OAUTH2_TOKEN_ENDPOINT=https://bsm.aizhs.top/prod-api/oauth/token
VITE_OAUTH2_AUTHORIZATION_ENDPOINT=https://bsm.aizhs.top/prod-api/oauth/authorize
VITE_USE_OAUTH21=true

# 历史别名
VITE_KOU_PROXY_PATH=/api-kou
VITE_LLM_CHAT_URL=https://zca.aizhs.top

# ========================================
# 第三方登录
# ========================================

# 微信配置
# 小程序 AppID: wx27028e276ffdbc5d
# AppSecret 见 PRODUCTION_CREDENTIALS.md（gitignored）
VITE_WECHAT_APP_ID=wx27028e276ffdbc5d
VITE_WECHAT_PC_REDIRECT_URI=https://kou.aizhs.top/prod-api/ai/login/wechat/pc/wxCode

# 支付宝配置
# 绑定应用 ID: 2021005181618474
VITE_ALIPAY_APP_ID=2021005181618474
VITE_ALIPAY_REDIRECT_URI=https://kou.aizhs.top/prod-api/ai/login/ali/web/wxCode
VITE_ALIPAY_SCOPE=auth_user
VITE_ALIPAY_SANDBOX_MODE=false

# 华为配置
VITE_HUAWEI_CLIENT_ID=replace-with-huawei-client-id
VITE_HUAWEI_REDIRECT_URI=https://kou.aizhs.top/huawei/callback

# 飞书配置
VITE_FEISHU_APP_ID=replace-with-feishu-app-id
VITE_FEISHU_REDIRECT_URI=https://kou.aizhs.top/prod-api/ai/login/feishu/pc/wxCode
VITE_FEISHU_SCOPE=contact:user.id:readonly

# 企业微信配置（加密存储）
VITE_WORKWECHAT_ENABLED=true
VITE_WORKWECHAT_APP_ID_ENCRYPTED=replace-with-encrypted-app-id
VITE_WORKWECHAT_AGENT_ID_ENCRYPTED=replace-with-encrypted-agent-id
VITE_WORKWECHAT_SECRET_ENCRYPTED=replace-with-encrypted-secret
VITE_WORKWECHAT_REDIRECT_URI=https://kou.aizhs.top/workwechat/callback
VITE_WORKWECHAT_SCOPE=snsapi_login

# Google 配置
VITE_GOOGLE_ENABLED=true
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id
VITE_GOOGLE_REDIRECT_URI=https://kou.aizhs.top/prod-api/ai/login/google/pc/wxCode
VITE_GOOGLE_SCOPE=openid email profile

# ========================================
# Coze API（生产 Coze 集成）
# ========================================
# Public Key ID: idDd5jxHsinzD3bh1yfTwEaPjs0MXiHZxssb3d0AwyA
# 完整私钥见 PRODUCTION_CREDENTIALS.md（gitignored）
VITE_COZE_API_TOKEN=replace-with-coze-api-token
VITE_COZE_WORKFLOW_ID=replace-with-workflow-id
VITE_COZE_API_BASE=https://api.coze.cn
VITE_COZE_PUBLIC_KEY_ID=idDd5jxHsinzD3bh1yfTwEaPjs0MXiHZxssb3d0AwyA

# ========================================
# 应用模式
# ========================================
VITE_ADMIN_OVERRIDE=false
VITE_APP_DEMO_MODE=false
VITE_DEMO_MODE=false
VITE_ENABLE_MOCK=false
VITE_LOG_LEVEL=error
VITE_ENABLE_UTM=false
VITE_APP_E2E=false
VITE_DEBUG_VISIBILITY=false

# ========================================
# 国际化
# ========================================
VITE_ENABLE_LOCALES_SYNC=true

# ========================================
# CDN
# ========================================
VITE_CDN_ENABLED=false
VITE_CDN_BASE_URL=https://cdn.aizhs.top

# ========================================
# 监控 / 错误追踪
# ========================================
VITE_ENABLE_MONITOR=true
VITE_MONITOR_REPORT_URL=/api/monitor/collect
VITE_SENTRY_DSN=
VITE_ERROR_TRACKER_ENV=production
VITE_ERROR_TRACKER_SAMPLE_RATE=1.0
VITE_WEB_VITALS_ALERT_URL=/api/rum
VITE_WEB_VITALS_ALERT_EMAIL=ops@aizhs.top
VITE_CSP_REPORT_URI=/api/csp-report

# ========================================
# SRS 媒体服务（直播/视频推流）
# ========================================
# 历史: SRS_HOST=127.0.0.1, SRS_RTMP_PORT=1935, SRS_HTTP_API_PORT=1985
# 生产部署时改为实际公网地址
VITE_SRS_HOST=https://live.aizhs.top
VITE_SRS_RTMP_PORT=1935
VITE_SRS_HTTP_API_PORT=1985
VITE_SRS_WEBRTC_URL=wss://live.aizhs.top/rtc/

# ========================================
# MinIO 存储（生产）
# ========================================
# 桶名: sys-resource, sys-basks, sys-mini
VITE_MINIO_ENDPOINT=https://minio.aizhs.top
VITE_MINIO_PUBLIC_BUCKET=sys-resource
VITE_MINIO_ADMIN_BUCKET=sys-basks
VITE_MINIO_MINI_BUCKET=sys-mini

# ========================================
# 平台构建（CI/CD）
# ========================================
# 历史: BUILD_PLATFORM=web|h5|alipay|electron
# 默认 web, h5 用于分享页
BUILD_PLATFORM=web
