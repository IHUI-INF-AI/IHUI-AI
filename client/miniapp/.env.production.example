# ========================================
# IHUI-AI 微信小程序 生产环境配置模板
# ========================================
# 来源: 整合 H:\历史项目存档\zhs_app-ZZ\Ai-WXMiniVue\.env.production
# 创建日期: 2026-06-25
# 部署前请复制为 .env.production 并填入实际敏感值
# 真实敏感凭证: docs/PRODUCTION_CREDENTIALS.md（gitignored）
# ========================================

# ========================================
# 小程序基本信息
# ========================================
# AppID (已确认: wx27028e276ffdbc5d)
UNI_PLATFORM=mp-weixin
VITE_WX_APPID=wx27028e276ffdbc5d
VITE_WECHAT_APPID=wx27028e276ffdbc5d

# 项目名
VITE_APP_NAME=智汇AGI社区
VITE_PROJECT_NAME=aizhs

# ========================================
# 后端 API 基础地址
# ========================================
# 生产后端 (Python FastAPI)
VITE_API_BASE_URL=https://<BACKEND_DOMAIN>
VITE_PYTHON_API_BASE_URL=https://<BACKEND_DOMAIN>
VITE_LOGIN_API_BASE_URL=https://<BACKEND_DOMAIN>
VITE_ADMIN_API_BASE=/prod-api
VITE_BASE_API=/prod-api

# uniCloud (如使用)
VITE_UNI_CLOUD_ENABLED=false

# ========================================
# 第三方登录
# ========================================
# 微信
VITE_WX_SECRET=<WX_MINI_SECRET>

# 支付宝
VITE_ALIPAY_APP_ID=<ALIPAY_APP_ID>
VITE_ALIPAY_SCOPE=auth_user
VITE_ALIPAY_SANDBOX_MODE=false

# 飞书
VITE_FEISHU_APP_ID=<FEISHU_APP_ID>
VITE_FEISHU_SCOPE=contact:user.id:readonly

# ========================================
# 主项目 URL
# ========================================
VITE_MAIN_PROJECT_URL=https://<FRONTEND_DOMAIN>
VITE_WEB_URL=https://<FRONTEND_DOMAIN>

# ========================================
# Coze
# ========================================
VITE_COZE_API_BASE=https://api.coze.cn
VITE_COZE_API_TOKEN=<COZE_API_TOKEN>
VITE_COZE_PUBLIC_KEY_ID=<COZE_PUBLIC_KEY_ID>

# ========================================
# 监控
# ========================================
VITE_ENABLE_MONITOR=true
VITE_MONITOR_REPORT_URL=https://<BACKEND_DOMAIN>/api/monitor/collect
VITE_SENTRY_DSN=
VITE_ERROR_TRACKER_ENV=production

# ========================================
# 文件上传
# ========================================
VITE_UPLOAD_URL=https://<BACKEND_DOMAIN>/api/v1/upload/file

# ========================================
# MinIO
# ========================================
VITE_MINIO_ENDPOINT=https://minio.<DOMAIN>
VITE_MINIO_MINI_BUCKET=sys-mini
VITE_MINIO_PUBLIC_BUCKET=sys-resource
VITE_MINIO_FILE_URL=https://minio.<DOMAIN>/sys-mini

# ========================================
# 直播
# ========================================
VITE_SRS_HOST=https://live.<DOMAIN>
VITE_SRS_RTMP_PORT=1935
VITE_SRS_HTTP_API_PORT=1985

# ========================================
# 应用模式
# ========================================
VITE_APP_DEMO_MODE=false
VITE_DEMO_MODE=false
VITE_ENABLE_MOCK=false
VITE_LOG_LEVEL=error
VITE_DEBUG_VISIBILITY=false

# ========================================
# 国际化
# ========================================
VITE_ENABLE_LOCALES_SYNC=true
VITE_DEFAULT_LOCALE=zh-CN

# ========================================
# 构建
# ========================================
BUILD_PLATFORM=mp-weixin
ENV=production

# ========================================
# 安全
# ========================================
VITE_ENCRYPTION_KEY=<ENCRYPTION_KEY>
