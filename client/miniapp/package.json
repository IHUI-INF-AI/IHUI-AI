{
  "name": "@aizhs/miniapp",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0 <=22.x"
  },
  "scripts": {
    "serve": "npm run dev:h5",
    "build": "npm run build:h5",
    "build:app-plus": "uni -p app-plus",
    "build:h5": "uni build --platform h5",
    "build:mp-weixin": "uni build --platform mp-weixin",
    "build:mp-alipay": "uni build --platform mp-alipay",
    "build:mp-baidu": "uni build --platform mp-baidu",
    "build:mp-toutiao": "uni build --platform mp-toutiao",
    "build:mp-qq": "uni build --platform mp-qq",
    "dev:app-plus": "uni -p app-plus",
    "dev:h5": "uni --platform h5",
    "dev:mp-weixin": "uni --platform mp-weixin",
    "dev:mp-alipay": "uni --platform mp-alipay",
    "dev:mp-baidu": "uni --platform mp-baidu",
    "dev:mp-toutiao": "uni --platform mp-toutiao",
    "dev:mp-qq": "uni --platform mp-qq",
    "info": "uni info",
    "test:mp-weixin": "cross-env UNI_PLATFORM=mp-weixin jest -i",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:style": "stylelint \"src/**/*.{vue,scss,css}\" --fix",
    "lint:style:check": "stylelint \"src/**/*.{vue,scss,css}\"",
    "typecheck": "vue-tsc --noEmit",
    "mp:preview": "npm run build:mp-weixin && tsx scripts/upload-miniprogram.ts preview",
    "mp:upload": "npm run build:mp-weixin && tsx scripts/upload-miniprogram.ts upload",
    "lint:staged": "lint-staged",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "commitlint:check": "commitlint --edit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "node scripts/install-hooks.mjs",
    "hooks:uninstall": "node scripts/install-hooks.mjs uninstall"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,jsx}": [
      "eslint --fix --max-warnings=-1"
    ],
    "*.{vue}": [
      "stylelint --fix"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4060620250520001",
    "@dcloudio/uni-app-plus": "3.0.0-4060620250520001",
    "@dcloudio/uni-components": "3.0.0-4060620250520001",
    "@dcloudio/uni-h5": "3.0.0-4060620250520001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4060620250520001",
    "pinia": "^2.3.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.0",
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4060620250520001",
    "@dcloudio/uni-cli-shared": "3.0.0-4060620250520001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4060620250520001",
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "fs-extra": "^11.3.5",
    "lint-staged": "^16.4.0",
    "miniprogram-ci": "^1.9.16",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass": "^1.83.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.1.0"
  },
  "uni-app": {
    "scripts": {}
  }
}
