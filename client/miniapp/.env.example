# ==================== 微信小程序 / App 原生 AppID 配置 ====================
# 说明：manifest.json 中的 AppID 为编译期默认值（uni-app 要求），运行时统一从
#       src/config/wechat.config.ts 读取，环境变量优先，回退到 manifest 默认值。
#       服务端 (server/app/config.py) 与云函数 (cloudfunctions/login/index.js)
#       使用相同命名，确保全栈一致。

# App 原生微信 AppID（Android/iOS 原生 OAuth/支付/分享）
# 对应 manifest.json → app-plus.distribute.sdkConfigs.oauth.weixin.appid
# 服务端对应: server/app/config.py → WX_APP_APPID
WX_APP_APPID=

# 微信小程序 AppID（mp-weixin 平台）
# 对应 manifest.json → mp-weixin.appid
# 云函数对应: cloudfunctions/login/index.js → process.env.WX_MINIAPP_APPID
WX_MINIAPP_APPID=

# 微信小程序 Secret（云函数登录使用）
# 服务端对应: server/app/config.py → WX_MINI_SECRET
WX_MINIAPP_SECRET=
