{
  "customSyntax": "postcss-html",
  "extends": [
    "stylelint-config-standard-scss"
  ],
  "plugins": [
    "./stylelint-plugin-no-css-typos.cjs",
    "./stylelint-plugin-no-flex-column-el-button-without-stack.cjs",
    "./stylelint-plugin-no-input-glow.cjs",
    "./stylelint-plugin-no-where-dark-css-var.cjs"
  ],
  "rules": {
    "aizhs/no-css-typos": true,
    "aizhs/no-flex-column-el-button-without-stack": true,
    "aizhs/no-input-glow": true,
    "aizhs/no-where-dark-css-var": true,
    "declaration-no-important": null,
    "selector-max-id": null,
    "no-descending-specificity": null,
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "variants",
          "responsive",
          "screen"
        ]
      }
    ],
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": [
          "global",
          "deep",
          "slotted",
          "v-deep",
          "v-global",
          "v-slotted",
          "loading",
          "export"
        ]
      }
    ],
    "property-no-vendor-prefix": null,
    "value-no-vendor-prefix": null,
    "selector-class-pattern": null,
    "scss/dollar-variable-pattern": null,
    "scss/percent-placeholder-pattern": null,
    "scss/at-mixin-pattern": null,
    "scss/at-function-pattern": null,
    "color-hex-length": "short",
    "color-named": null,
    "keyframes-name-pattern": null,
    "block-no-empty": null,
    "max-nesting-depth": null,
    "property-no-deprecated": null,
    "scss/comment-no-empty": null,
    "scss/load-no-partial-leading-underscore": null,
    "font-family-name-quotes": "always-where-recommended",
    "font-weight-notation": null,
    "declaration-block-no-duplicate-properties": [
      true,
      {
        "ignore": [
          "consecutive-duplicates-with-different-values"
        ]
      }
    ],
    "no-duplicate-selectors": null,
    "selector-max-compound-selectors": null,
    "selector-max-type": null,
    "shorthand-property-no-redundant-values": true,
    "declaration-block-no-shorthand-property-overrides": null,
    "declaration-property-value-keyword-no-deprecated": null,
    "declaration-block-single-line-max-declarations": null,
    "color-function-notation": "modern",
    "alpha-value-notation": "number",
    "hue-degree-notation": "angle",
    "custom-property-pattern": null,
    "no-invalid-double-slash-comments": null,
    "unit-no-unknown": [
      true,
      {
        "ignoreUnits": [
          "rpx",
          "upx"
        ]
      }
    ],
    "declaration-block-no-duplicate-custom-properties": null,
    "font-family-no-missing-generic-family-keyword": null,
    "selector-id-pattern": null,
    "selector-pseudo-element-no-unknown": [
      true,
      {
        "ignorePseudoElements": [
          "v-deep",
          "v-global",
          "v-slotted"
        ]
      }
    ],
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": [
          "container-type",
          "container-name",
          "tap-highlight-color",
          "-webkit-tap-highlight-color",
          "primaryColor",
          "successColor",
          "warningColor",
          "errorColor",
          "infoColor",
          "text-security"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/*.vue"
      ],
      "customSyntax": "postcss-html"
    },
    {
      "files": [
        "**/*.scss"
      ],
      "customSyntax": "postcss-scss"
    },
    {
      "files": [
        "src/views/**/*.vue",
        "src/views/**/*.scss",
        "src/components/**/*.vue",
        "src/components/**/*.scss"
      ],
      "rules": {
        "color-no-hex": true
      }
    },
    {
      "files": [
        "miniapp/**/*.vue",
        "miniapp/**/*.scss"
      ],
      "rules": {
        "color-no-hex": true
      }
    },
    {
      "files": [
        "src/components/edu/**/*.vue",
        "src/components/edu/**/*.scss"
      ],
      "rules": {
        "color-no-hex": null
      }
    }
  ],
  "ignoreFiles": [
    "dist/**/*",
    "node_modules/**/*",
    "*.min.css",
    "src/views/admin/EventBusMonitor.vue",
    "src/components/admin/CacheKeyAnalyzerPanel.vue",
    "src/components/admin/CacheWarmupPanel.vue",
    "src/App.vue",
    "src/components/header/HeaderNavigation.vue",
    "src/views/Plaza.vue",
    "src/components/ai/AIChat.vue",
    "src/components/login/UniversalLogin.vue",
    "src/components/login/components/AccountBindDialog.vue",
    "src/components/agents/AgentsSquareList.vue",
    "src/templates/CardTemplate.vue",
    "src/views/AIAssistant.vue",
    "src/views/AICommunity.vue"
  ]
}
