{
  "annotations": { "list": [] },
  "description": "IHUI-AI Jaeger 链路追踪 (trace / span / 慢查询 / 服务依赖)",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Trace 总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(jaeger_traces_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Traces 5m",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Span 总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(jaeger_spans_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Spans 5m",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "错误率",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(jaeger_traces_total{instance=~\"$instance\", error=\"true\"}[5m])) / sum(increase(jaeger_traces_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "错误率",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "P95 延迟",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (jaeger_trace_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Trace 数趋势",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (service) (rate(jaeger_traces_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "title": "延迟分布 (P50/P95/P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, service) (jaeger_trace_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P50 {{service}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (jaeger_trace_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P95 {{service}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, service) (jaeger_trace_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P99 {{service}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Span 统计 (按服务)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (service) (rate(jaeger_spans_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "title": "服务依赖图 (调用次数)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "topk(20, sum by (service, parent_service) (rate(jaeger_spans_total{instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{parent_service}} -> {{service}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "慢查询 Top10 (P99 by operation)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.99, sum by (le, service, operation) (jaeger_trace_duration_seconds_bucket{instance=~\"$instance\"})))",
          "legendFormat": "{{service}} {{operation}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ihui-ai", "domain:tracing", "jaeger"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(jaeger_traces_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IHUI-AI Jaeger 链路追踪",
  "uid": "ihui-ai-jaeger",
  "version": 1,
  "weekStart": ""
}
