{
  "annotations": { "list": [] },
  "description": "IHUI-AI BullMQ 队列深度监控 (延迟/失败/重试/dead letter)",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "队列总长度",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(bullmq_waiting_total{instance=~\"$instance\"}) + sum(bullmq_active_total{instance=~\"$instance\"}) + sum(bullmq_delayed_total{instance=~\"$instance\"})",
          "legendFormat": "队列长度",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "活跃 Worker 数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(bullmq_workers_active{instance=~\"$instance\"})",
          "legendFormat": "Workers",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "失败任务数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(bullmq_failed_total{instance=~\"$instance\"})",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Dead Letter 队列长度",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(bullmq_deadletter_total{instance=~\"$instance\"})",
          "legendFormat": "DLQ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "队列长度趋势 (按队列)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (queue) (bullmq_waiting_total{instance=~\"$instance\"})",
          "legendFormat": "waiting {{queue}}",
          "refId": "A"
        },
        {
          "expr": "sum by (queue) (bullmq_active_total{instance=~\"$instance\"})",
          "legendFormat": "active {{queue}}",
          "refId": "B"
        },
        {
          "expr": "sum by (queue) (bullmq_delayed_total{instance=~\"$instance\"})",
          "legendFormat": "delayed {{queue}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "处理速度 (jobs/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (queue) (rate(bullmq_completed_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "completed {{queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "title": "失败率趋势",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (queue) (rate(bullmq_failed_total{instance=~\"$instance\"}[5m])) / (sum by (queue) (rate(bullmq_completed_total{instance=~\"$instance\"}[5m])) + sum by (queue) (rate(bullmq_failed_total{instance=~\"$instance\"}[5m])))",
          "legendFormat": "失败率 {{queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "title": "重试次数 (按队列)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum by (queue) (increase(bullmq_retry_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "retry {{queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "延迟分布 (P50/P95/P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, queue) (bullmq_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P50 {{queue}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, queue) (bullmq_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P95 {{queue}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, queue) (bullmq_duration_seconds_bucket{instance=~\"$instance\"}))",
          "legendFormat": "P99 {{queue}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Worker 状态表",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "bullmq_workers_active{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} {{queue}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ihui-ai", "domain:queue", "bullmq"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(bullmq_waiting_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IHUI-AI BullMQ 队列监控",
  "uid": "ihui-ai-bullmq",
  "version": 1,
  "weekStart": ""
}
