{
  "annotations": { "list": [] },
  "description": "IHUI-AI 对象存储监控 (存储用量 / 带宽 / 文件数 / 跨区 / 错误 / 生命周期)",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "存储用量 (GB)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(ihui_oss_storage_used_bytes{instance=~\"$instance\"}) / 1024 / 1024 / 1024",
          "legendFormat": "用量",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "文件总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(ihui_oss_file_count{instance=~\"$instance\"})",
          "legendFormat": "文件",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "错误率",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ihui_oss_errors_total{instance=~\"$instance\"}[5m])) / (sum(rate(ihui_oss_requests_total{instance=~\"$instance\"}[5m])))",
          "legendFormat": "错误率",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "生命周期规则命中数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(ihui_oss_lifecycle_hits_total{instance=~\"$instance\"}[1h]))",
          "legendFormat": "生命周期",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "存储用量趋势 (按 bucket)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (bucket) (ihui_oss_storage_used_bytes{instance=~\"$instance\"}) / 1024 / 1024 / 1024",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decgbytes" }, "overrides": [] }
    },
    {
      "title": "上传/下载带宽",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(ihui_oss_upload_bytes_total{instance=~\"$instance\"}[5m])) * 8",
          "legendFormat": "upload {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(ihui_oss_download_bytes_total{instance=~\"$instance\"}[5m])) * 8",
          "legendFormat": "download {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] }
    },
    {
      "title": "文件数趋势 (按 bucket)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (bucket) (ihui_oss_file_count{instance=~\"$instance\"})",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "跨区流量趋势",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum by (src_region, dst_region) (rate(ihui_oss_cross_region_bytes_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{src_region}} -> {{dst_region}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "title": "错误率趋势 (按类型)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(ihui_oss_errors_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "title": "生命周期规则命中明细",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "topk(20, sum by (bucket, rule) (increase(ihui_oss_lifecycle_hits_total{instance=~\"$instance\"}[1h])))",
          "legendFormat": "{{bucket}} {{rule}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ihui-ai", "domain:storage", "oss"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(ihui_oss_storage_used_bytes, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IHUI-AI 对象存储监控",
  "uid": "ihui-ai-oss-storage",
  "version": 1,
  "weekStart": ""
}
